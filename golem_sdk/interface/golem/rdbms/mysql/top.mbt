        mbt_ffi_store32(iter_base + 12, payload29.length())
        mbt_ffi_store32(iter_base + 8, ptr30)
        cleanup_list.push(ptr30)

        ()
      }
      Binary(payload31) => {
        mbt_ffi_store8(iter_base + 0, 25)

        let ptr32 = mbt_ffi_bytes2ptr(payload31)

        mbt_ffi_store32(iter_base + 12, payload31.length())
        mbt_ffi_store32(iter_base + 8, ptr32)
        cleanup_list.push(ptr32)

        ()
      }
      Varbinary(payload33) => {
        mbt_ffi_store8(iter_base + 0, 26)

        let ptr34 = mbt_ffi_bytes2ptr(payload33)

        mbt_ffi_store32(iter_base + 12, payload33.length())
        mbt_ffi_store32(iter_base + 8, ptr34)
        cleanup_list.push(ptr34)

        ()
      }
      Tinyblob(payload35) => {
        mbt_ffi_store8(iter_base + 0, 27)

        let ptr36 = mbt_ffi_bytes2ptr(payload35)

        mbt_ffi_store32(iter_base + 12, payload35.length())
        mbt_ffi_store32(iter_base + 8, ptr36)
        cleanup_list.push(ptr36)

        ()
      }
      Blob(payload37) => {
        mbt_ffi_store8(iter_base + 0, 28)

        let ptr38 = mbt_ffi_bytes2ptr(payload37)

        mbt_ffi_store32(iter_base + 12, payload37.length())
        mbt_ffi_store32(iter_base + 8, ptr38)
        cleanup_list.push(ptr38)

        ()
      }
      Mediumblob(payload39) => {
        mbt_ffi_store8(iter_base + 0, 29)

        let ptr40 = mbt_ffi_bytes2ptr(payload39)

        mbt_ffi_store32(iter_base + 12, payload39.length())
        mbt_ffi_store32(iter_base + 8, ptr40)
        cleanup_list.push(ptr40)

        ()
      }
      Longblob(payload41) => {
        mbt_ffi_store8(iter_base + 0, 30)

        let ptr42 = mbt_ffi_bytes2ptr(payload41)

        mbt_ffi_store32(iter_base + 12, payload41.length())
        mbt_ffi_store32(iter_base + 8, ptr42)
        cleanup_list.push(ptr42)

        ()
      }
      Enumeration(payload43) => {
        mbt_ffi_store8(iter_base + 0, 31)

        let ptr44 = mbt_ffi_str2ptr(payload43)
        mbt_ffi_store32(iter_base + 12, payload43.length())
        mbt_ffi_store32(iter_base + 8, ptr44)
        cleanup_list.push(ptr44)

        ()
      }
      Set(payload45) => {
        mbt_ffi_store8(iter_base + 0, 32)

        let ptr46 = mbt_ffi_str2ptr(payload45)
        mbt_ffi_store32(iter_base + 12, payload45.length())
        mbt_ffi_store32(iter_base + 8, ptr46)
        cleanup_list.push(ptr46)

        ()
      }
      Bit(payload47) => {
        mbt_ffi_store8(iter_base + 0, 33)

        let address = mbt_ffi_malloc(payload47.length() * 1)
        for index = 0; index < payload47.length(); index = index + 1 {
          let iter_elem : Bool = payload47[index]
          let iter_base = address + index * 1
          mbt_ffi_store8(iter_base + 0, if iter_elem { 1 } else { 0 })
        }
        mbt_ffi_store32(iter_base + 12, payload47.length())
        mbt_ffi_store32(iter_base + 8, address)
        cleanup_list.push(address)

        ()
      }
      Json(payload48) => {
        mbt_ffi_store8(iter_base + 0, 34)

        let ptr49 = mbt_ffi_str2ptr(payload48)
        mbt_ffi_store32(iter_base + 12, payload48.length())
        mbt_ffi_store32(iter_base + 8, ptr49)
        cleanup_list.push(ptr49)

        ()
      }
      Null => {
        mbt_ffi_store8(iter_base + 0, 35)

        ()
      }
    }
  }
  let return_area = mbt_ffi_malloc(20)
  wasmImportMethodDbConnectionQuery(
    handle,
    ptr,
    statement.length(),
    address51,
    params.length(),
    return_area,
  )

  let lifted84 = match mbt_ffi_load8_u(return_area + 0) {
    0 => {
      let array : Array[DbColumn] = []
      for index54 = 0
          index54 < mbt_ffi_load32(return_area + 8)
          index54 = index54 + 1 {
        let iter_base = mbt_ffi_load32(return_area + 4) + index54 * 32

        let result = mbt_ffi_ptr2str(
          mbt_ffi_load32(iter_base + 8),
          mbt_ffi_load32(iter_base + 12),
        )

        let lifted = match mbt_ffi_load8_u(iter_base + 16) {
          0 => DbColumnType::Boolean
          1 => DbColumnType::Tinyint
          2 => DbColumnType::Smallint
          3 => DbColumnType::Mediumint
          4 => DbColumnType::Int
          5 => DbColumnType::Bigint
          6 => DbColumnType::TinyintUnsigned
          7 => DbColumnType::SmallintUnsigned
          8 => DbColumnType::MediumintUnsigned
          9 => DbColumnType::IntUnsigned
          10 => DbColumnType::BigintUnsigned
          11 => DbColumnType::Float
          12 => DbColumnType::Double
          13 => DbColumnType::Decimal
          14 => DbColumnType::Date
          15 => DbColumnType::Datetime
          16 => DbColumnType::Timestamp
          17 => DbColumnType::Time
          18 => DbColumnType::Year
          19 => DbColumnType::Fixchar
          20 => DbColumnType::Varchar
          21 => DbColumnType::Tinytext
          22 => DbColumnType::Text
          23 => DbColumnType::Mediumtext
          24 => DbColumnType::Longtext
          25 => DbColumnType::Binary
          26 => DbColumnType::Varbinary
          27 => DbColumnType::Tinyblob
          28 => DbColumnType::Blob
          29 => DbColumnType::Mediumblob
          30 => DbColumnType::Longblob
          31 => DbColumnType::Enumeration
          32 => DbColumnType::Set
          33 => DbColumnType::Bit
          34 => DbColumnType::Json
          _ => panic()
        }

        let result53 = mbt_ffi_ptr2str(
          mbt_ffi_load32(iter_base + 20),
          mbt_ffi_load32(iter_base + 24),
        )

        array.push(DbColumn::{
          ordinal: mbt_ffi_load64(iter_base + 0).reinterpret_as_uint64(),
          name: result,
          db_type: lifted,
          db_type_name: result53,
        })
      }
      mbt_ffi_free(mbt_ffi_load32(return_area + 4))

      let array76 : Array[DbRow] = []
      for index77 = 0
          index77 < mbt_ffi_load32(return_area + 16)
          index77 = index77 + 1 {
        let iter_base = mbt_ffi_load32(return_area + 12) + index77 * 8

        let array74 : Array[DbValue] = []
        for index75 = 0
            index75 < mbt_ffi_load32(iter_base + 4)
            index75 = index75 + 1 {
          let iter_base = mbt_ffi_load32(iter_base + 0) + index75 * 24

          let lifted73 = match mbt_ffi_load8_u(iter_base + 0) {
            0 => DbValue::Boolean(mbt_ffi_load8_u(iter_base + 8) != 0)
            1 => DbValue::Tinyint(mbt_ffi_load8(iter_base + 8) - 0x100)
            2 => DbValue::Smallint(mbt_ffi_load16(iter_base + 8) - 0x10000)
            3 => DbValue::Mediumint(mbt_ffi_load32(iter_base + 8))
            4 => DbValue::Int(mbt_ffi_load32(iter_base + 8))
            5 => DbValue::Bigint(mbt_ffi_load64(iter_base + 8))
            6 =>
              DbValue::TinyintUnsigned(mbt_ffi_load8_u(iter_base + 8).to_byte())
            7 =>
              DbValue::SmallintUnsigned(
                mbt_ffi_load16_u(iter_base + 8)
                .land(0xFFFF)
                .reinterpret_as_uint(),
              )
            8 =>
              DbValue::MediumintUnsigned(
                mbt_ffi_load32(iter_base + 8).reinterpret_as_uint(),
              )
            9 =>
              DbValue::IntUnsigned(
                mbt_ffi_load32(iter_base + 8).reinterpret_as_uint(),
              )
            10 =>
              DbValue::BigintUnsigned(
                mbt_ffi_load64(iter_base + 8).reinterpret_as_uint64(),
              )
            11 => DbValue::Float(mbt_ffi_loadf32(iter_base + 8))
            12 => DbValue::Double(mbt_ffi_loadf64(iter_base + 8))
            13 => {
              let result55 = mbt_ffi_ptr2str(
                mbt_ffi_load32(iter_base + 8),
                mbt_ffi_load32(iter_base + 12),
              )

              DbValue::Decimal(result55)
            }
            14 =>
              DbValue::Date(@types.Date::{
                year: mbt_ffi_load32(iter_base + 8),
                month: mbt_ffi_load8_u(iter_base + 12).to_byte(),
                day: mbt_ffi_load8_u(iter_base + 13).to_byte(),
              })
            15 =>
              DbValue::Datetime(@types.Timestamp::{
                date: @types.Date::{
                  year: mbt_ffi_load32(iter_base + 8),
                  month: mbt_ffi_load8_u(iter_base + 12).to_byte(),
                  day: mbt_ffi_load8_u(iter_base + 13).to_byte(),
                },
                time: @types.Time::{
                  hour: mbt_ffi_load8_u(iter_base + 16).to_byte(),
                  minute: mbt_ffi_load8_u(iter_base + 17).to_byte(),
                  second: mbt_ffi_load8_u(iter_base + 18).to_byte(),
                  nanosecond: mbt_ffi_load32(iter_base + 20).reinterpret_as_uint(),
                },
              })
            16 =>
              DbValue::Timestamp(@types.Timestamp::{
                date: @types.Date::{
                  year: mbt_ffi_load32(iter_base + 8),
                  month: mbt_ffi_load8_u(iter_base + 12).to_byte(),
                  day: mbt_ffi_load8_u(iter_base + 13).to_byte(),
                },
                time: @types.Time::{
                  hour: mbt_ffi_load8_u(iter_base + 16).to_byte(),
                  minute: mbt_ffi_load8_u(iter_base + 17).to_byte(),
                  second: mbt_ffi_load8_u(iter_base + 18).to_byte(),
                  nanosecond: mbt_ffi_load32(iter_base + 20).reinterpret_as_uint(),
                },
              })
            17 =>
              DbValue::Time(@types.Time::{
                hour: mbt_ffi_load8_u(iter_base + 8).to_byte(),
                minute: mbt_ffi_load8_u(iter_base + 9).to_byte(),
                second: mbt_ffi_load8_u(iter_base + 10).to_byte(),
                nanosecond: mbt_ffi_load32(iter_base + 12).reinterpret_as_uint(),
              })
            18 =>
              DbValue::Year(
                mbt_ffi_load16_u(iter_base + 8)
                .land(0xFFFF)
                .reinterpret_as_uint(),
              )
            19 => {
              let result56 = mbt_ffi_ptr2str(
                mbt_ffi_load32(iter_base + 8),
                mbt_ffi_load32(iter_base + 12),
              )

              DbValue::Fixchar(result56)
            }
            20 => {
              let result57 = mbt_ffi_ptr2str(
                mbt_ffi_load32(iter_base + 8),
                mbt_ffi_load32(iter_base + 12),
              )

              DbValue::Varchar(result57)
            }
            21 => {
              let result58 = mbt_ffi_ptr2str(
                mbt_ffi_load32(iter_base + 8),
                mbt_ffi_load32(iter_base + 12),
              )

              DbValue::Tinytext(result58)
            }
            22 => {
              let result59 = mbt_ffi_ptr2str(
                mbt_ffi_load32(iter_base + 8),
                mbt_ffi_load32(iter_base + 12),
              )

              DbValue::Text(result59)
            }
            23 => {
              let result60 = mbt_ffi_ptr2str(
                mbt_ffi_load32(iter_base + 8),
                mbt_ffi_load32(iter_base + 12),
              )

              DbValue::Mediumtext(result60)
            }
            24 => {
              let result61 = mbt_ffi_ptr2str(
                mbt_ffi_load32(iter_base + 8),
                mbt_ffi_load32(iter_base + 12),
              )

              DbValue::Longtext(result61)
            }
            25 => {
              let result62 = mbt_ffi_ptr2bytes(
                mbt_ffi_load32(iter_base + 8),
                mbt_ffi_load32(iter_base + 12),
              )

              DbValue::Binary(result62)
            }
            26 => {
              let result63 = mbt_ffi_ptr2bytes(
                mbt_ffi_load32(iter_base + 8),
                mbt_ffi_load32(iter_base + 12),
              )

              DbValue::Varbinary(result63)
            }
            27 => {
              let result64 = mbt_ffi_ptr2bytes(
                mbt_ffi_load32(iter_base + 8),
                mbt_ffi_load32(iter_base + 12),
              )

              DbValue::Tinyblob(result64)
            }
            28 => {
              let result65 = mbt_ffi_ptr2bytes(
                mbt_ffi_load32(iter_base + 8),
                mbt_ffi_load32(iter_base + 12),
              )

              DbValue::Blob(result65)
            }
            29 => {
              let result66 = mbt_ffi_ptr2bytes(
                mbt_ffi_load32(iter_base + 8),
                mbt_ffi_load32(iter_base + 12),
              )

              DbValue::Mediumblob(result66)
            }
            30 => {
              let result67 = mbt_ffi_ptr2bytes(
                mbt_ffi_load32(iter_base + 8),
                mbt_ffi_load32(iter_base + 12),
              )

              DbValue::Longblob(result67)
            }
            31 => {
              let result68 = mbt_ffi_ptr2str(
                mbt_ffi_load32(iter_base + 8),
                mbt_ffi_load32(iter_base + 12),
              )

              DbValue::Enumeration(result68)
            }
            32 => {
              let result69 = mbt_ffi_ptr2str(
                mbt_ffi_load32(iter_base + 8),
                mbt_ffi_load32(iter_base + 12),
              )

              DbValue::Set(result69)
            }
            33 => {
              let array70 : Array[Bool] = []
              for index71 = 0
                  index71 < mbt_ffi_load32(iter_base + 12)
                  index71 = index71 + 1 {
                let iter_base = mbt_ffi_load32(iter_base + 8) + index71 * 1

                array70.push(mbt_ffi_load8_u(iter_base + 0) != 0)
              }
              mbt_ffi_free(mbt_ffi_load32(iter_base + 8))

              DbValue::Bit(array70)
            }
            34 => {
              let result72 = mbt_ffi_ptr2str(
                mbt_ffi_load32(iter_base + 8),
                mbt_ffi_load32(iter_base + 12),
              )

              DbValue::Json(result72)
            }
            35 => DbValue::Null
            _ => panic()
          }

          array74.push(lifted73)
        }
        mbt_ffi_free(mbt_ffi_load32(iter_base + 0))

        array76.push(DbRow::{ values: array74 })
      }
      mbt_ffi_free(mbt_ffi_load32(return_area + 12))

      Result::Ok(DbResult::{ columns: array, rows: array76 })
    }
    1 => {
      let lifted83 = match mbt_ffi_load8_u(return_area + 4) {
        0 => {
          let result78 = mbt_ffi_ptr2str(
            mbt_ffi_load32(return_area + 8),
            mbt_ffi_load32(return_area + 12),
          )

          Error_::ConnectionFailure(result78)
        }
        1 => {
          let result79 = mbt_ffi_ptr2str(
            mbt_ffi_load32(return_area + 8),
            mbt_ffi_load32(return_area + 12),
          )

          Error_::QueryParameterFailure(result79)
        }
        2 => {
          let result80 = mbt_ffi_ptr2str(
            mbt_ffi_load32(return_area + 8),
            mbt_ffi_load32(return_area + 12),
          )

          Error_::QueryExecutionFailure(result80)
        }
        3 => {
          let result81 = mbt_ffi_ptr2str(
            mbt_ffi_load32(return_area + 8),
            mbt_ffi_load32(return_area + 12),
          )

          Error_::QueryResponseFailure(result81)
        }
        4 => {
          let result82 = mbt_ffi_ptr2str(
            mbt_ffi_load32(return_area + 8),
            mbt_ffi_load32(return_area + 12),
          )

          Error_::Other(result82)
        }
        _ => panic()
      }

      Result::Err(lifted83)
    }
    _ => panic()
  }
  let ret = lifted84
  mbt_ffi_free(ptr)
  mbt_ffi_free(address51)
  mbt_ffi_free(return_area)
  cleanup_list.each(mbt_ffi_free)
  return ret
}

///|
pub fn DbConnection::query_stream(
  self : DbConnection,
  statement : String,
  params : Array[DbValue],
) -> Result[DbResultStream, Error_] {
  let cleanup_list : Array[Int] = []

  let DbConnection(handle) = self

  let ptr = mbt_ffi_str2ptr(statement)

  let address51 = mbt_ffi_malloc(params.length() * 24)
  for index52 = 0; index52 < params.length(); index52 = index52 + 1 {
    let iter_elem : DbValue = params[index52]
    let iter_base = address51 + index52 * 24

    match iter_elem {
      Boolean(payload) => {
        mbt_ffi_store8(iter_base + 0, 0)
        mbt_ffi_store8(iter_base + 8, if payload { 1 } else { 0 })

        ()
      }
      Tinyint(payload0) => {
        mbt_ffi_store8(iter_base + 0, 1)
        mbt_ffi_store8(iter_base + 8, mbt_ffi_extend8(payload0))

        ()
      }
      Smallint(payload1) => {
        mbt_ffi_store8(iter_base + 0, 2)
        mbt_ffi_store16(iter_base + 8, mbt_ffi_extend16(payload1))

        ()
      }
      Mediumint(payload2) => {
        mbt_ffi_store8(iter_base + 0, 3)
        mbt_ffi_store32(iter_base + 8, payload2)

        ()
      }
      Int(payload3) => {
        mbt_ffi_store8(iter_base + 0, 4)
        mbt_ffi_store32(iter_base + 8, payload3)

        ()
      }
      Bigint(payload4) => {
        mbt_ffi_store8(iter_base + 0, 5)
        mbt_ffi_store64(iter_base + 8, payload4)

        ()
      }
      TinyintUnsigned(payload5) => {
        mbt_ffi_store8(iter_base + 0, 6)
        mbt_ffi_store8(iter_base + 8, payload5.to_int())

        ()
      }
      SmallintUnsigned(payload6) => {
        mbt_ffi_store8(iter_base + 0, 7)
        mbt_ffi_store16(iter_base + 8, payload6.reinterpret_as_int())

        ()
      }
      MediumintUnsigned(payload7) => {
        mbt_ffi_store8(iter_base + 0, 8)
        mbt_ffi_store32(iter_base + 8, payload7.reinterpret_as_int())

        ()
      }
      IntUnsigned(payload8) => {
        mbt_ffi_store8(iter_base + 0, 9)
        mbt_ffi_store32(iter_base + 8, payload8.reinterpret_as_int())

        ()
      }
      BigintUnsigned(payload9) => {
        mbt_ffi_store8(iter_base + 0, 10)
        mbt_ffi_store64(iter_base + 8, payload9.reinterpret_as_int64())

        ()
      }
      Float(payload10) => {
        mbt_ffi_store8(iter_base + 0, 11)
        mbt_ffi_storef32(iter_base + 8, payload10)

        ()
      }
      Double(payload11) => {
        mbt_ffi_store8(iter_base + 0, 12)
        mbt_ffi_storef64(iter_base + 8, payload11)

        ()
      }
      Decimal(payload12) => {
        mbt_ffi_store8(iter_base + 0, 13)

        let ptr13 = mbt_ffi_str2ptr(payload12)
        mbt_ffi_store32(iter_base + 12, payload12.length())
        mbt_ffi_store32(iter_base + 8, ptr13)
        cleanup_list.push(ptr13)

        ()
      }
      Date(payload14) => {
        mbt_ffi_store8(iter_base + 0, 14)
        mbt_ffi_store32(iter_base + 8, payload14.year)
        mbt_ffi_store8(iter_base + 12, payload14.month.to_int())
        mbt_ffi_store8(iter_base + 13, payload14.day.to_int())

        ()
      }
      Datetime(payload15) => {
        mbt_ffi_store8(iter_base + 0, 15)
        mbt_ffi_store32(iter_base + 8, payload15.date.year)
        mbt_ffi_store8(iter_base + 12, payload15.date.month.to_int())
        mbt_ffi_store8(iter_base + 13, payload15.date.day.to_int())
        mbt_ffi_store8(iter_base + 16, payload15.time.hour.to_int())
        mbt_ffi_store8(iter_base + 17, payload15.time.minute.to_int())
        mbt_ffi_store8(iter_base + 18, payload15.time.second.to_int())
        mbt_ffi_store32(
          iter_base + 20,
          payload15.time.nanosecond.reinterpret_as_int(),
        )

        ()
      }
      Timestamp(payload16) => {
        mbt_ffi_store8(iter_base + 0, 16)
        mbt_ffi_store32(iter_base + 8, payload16.date.year)
        mbt_ffi_store8(iter_base + 12, payload16.date.month.to_int())
        mbt_ffi_store8(iter_base + 13, payload16.date.day.to_int())
        mbt_ffi_store8(iter_base + 16, payload16.time.hour.to_int())
        mbt_ffi_store8(iter_base + 17, payload16.time.minute.to_int())
        mbt_ffi_store8(iter_base + 18, payload16.time.second.to_int())
        mbt_ffi_store32(
          iter_base + 20,
          payload16.time.nanosecond.reinterpret_as_int(),
        )

        ()
      }
      Time(payload17) => {
        mbt_ffi_store8(iter_base + 0, 17)
        mbt_ffi_store8(iter_base + 8, payload17.hour.to_int())
        mbt_ffi_store8(iter_base + 9, payload17.minute.to_int())
        mbt_ffi_store8(iter_base + 10, payload17.second.to_int())
        mbt_ffi_store32(
          iter_base + 12,
          payload17.nanosecond.reinterpret_as_int(),
        )

        ()
      }
      Year(payload18) => {
        mbt_ffi_store8(iter_base + 0, 18)
        mbt_ffi_store16(iter_base + 8, payload18.reinterpret_as_int())

        ()
      }
      Fixchar(payload19) => {
        mbt_ffi_store8(iter_base + 0, 19)

        let ptr20 = mbt_ffi_str2ptr(payload19)
        mbt_ffi_store32(iter_base + 12, payload19.length())
        mbt_ffi_store32(iter_base + 8, ptr20)
        cleanup_list.push(ptr20)

        ()
      }
      Varchar(payload21) => {
        mbt_ffi_store8(iter_base + 0, 20)

        let ptr22 = mbt_ffi_str2ptr(payload21)
        mbt_ffi_store32(iter_base + 12, payload21.length())
        mbt_ffi_store32(iter_base + 8, ptr22)
        cleanup_list.push(ptr22)

        ()
      }
      Tinytext(payload23) => {
        mbt_ffi_store8(iter_base + 0, 21)

        let ptr24 = mbt_ffi_str2ptr(payload23)
        mbt_ffi_store32(iter_base + 12, payload23.length())
        mbt_ffi_store32(iter_base + 8, ptr24)
        cleanup_list.push(ptr24)

        ()
      }
      Text(payload25) => {
        mbt_ffi_store8(iter_base + 0, 22)

        let ptr26 = mbt_ffi_str2ptr(payload25)
        mbt_ffi_store32(iter_base + 12, payload25.length())
        mbt_ffi_store32(iter_base + 8, ptr26)
        cleanup_list.push(ptr26)

        ()
      }
      Mediumtext(payload27) => {
