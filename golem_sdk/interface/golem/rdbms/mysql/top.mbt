      }
      IntUnsigned(payload8) => {
        mbt_ffi_store8(iter_base + 0, 9)
        mbt_ffi_store32(iter_base + 8, payload8.reinterpret_as_int())

        ()
      }
      BigintUnsigned(payload9) => {
        mbt_ffi_store8(iter_base + 0, 10)
        mbt_ffi_store64(iter_base + 8, payload9.reinterpret_as_int64())

        ()
      }
      Float(payload10) => {
        mbt_ffi_store8(iter_base + 0, 11)
        mbt_ffi_storef32(iter_base + 8, payload10)

        ()
      }
      Double(payload11) => {
        mbt_ffi_store8(iter_base + 0, 12)
        mbt_ffi_storef64(iter_base + 8, payload11)

        ()
      }
      Decimal(payload12) => {
        mbt_ffi_store8(iter_base + 0, 13)

        let ptr13 = mbt_ffi_str2ptr(payload12)
        mbt_ffi_store32(iter_base + 12, payload12.length())
        mbt_ffi_store32(iter_base + 8, ptr13)
        cleanup_list.push(ptr13)

        ()
      }
      Date(payload14) => {
        mbt_ffi_store8(iter_base + 0, 14)
        mbt_ffi_store32(iter_base + 8, payload14.year)
        mbt_ffi_store8(iter_base + 12, payload14.month.to_int())
        mbt_ffi_store8(iter_base + 13, payload14.day.to_int())

        ()
      }
      Datetime(payload15) => {
        mbt_ffi_store8(iter_base + 0, 15)
        mbt_ffi_store32(iter_base + 8, payload15.date.year)
        mbt_ffi_store8(iter_base + 12, payload15.date.month.to_int())
        mbt_ffi_store8(iter_base + 13, payload15.date.day.to_int())
        mbt_ffi_store8(iter_base + 16, payload15.time.hour.to_int())
        mbt_ffi_store8(iter_base + 17, payload15.time.minute.to_int())
        mbt_ffi_store8(iter_base + 18, payload15.time.second.to_int())
        mbt_ffi_store32(
          iter_base + 20,
          payload15.time.nanosecond.reinterpret_as_int(),
        )

        ()
      }
      Timestamp(payload16) => {
        mbt_ffi_store8(iter_base + 0, 16)
        mbt_ffi_store32(iter_base + 8, payload16.date.year)
        mbt_ffi_store8(iter_base + 12, payload16.date.month.to_int())
        mbt_ffi_store8(iter_base + 13, payload16.date.day.to_int())
        mbt_ffi_store8(iter_base + 16, payload16.time.hour.to_int())
        mbt_ffi_store8(iter_base + 17, payload16.time.minute.to_int())
        mbt_ffi_store8(iter_base + 18, payload16.time.second.to_int())
        mbt_ffi_store32(
          iter_base + 20,
          payload16.time.nanosecond.reinterpret_as_int(),
        )

