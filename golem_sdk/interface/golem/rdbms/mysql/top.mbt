      }
      Bit(payload47) => {
        mbt_ffi_store8(iter_base + 0, 33)

        let address = mbt_ffi_malloc(payload47.length() * 1)
        for index = 0; index < payload47.length(); index = index + 1 {
          let iter_elem : Bool = payload47[index]
          let iter_base = address + index * 1
          mbt_ffi_store8(iter_base + 0, if iter_elem { 1 } else { 0 })
        }
        mbt_ffi_store32(iter_base + 12, payload47.length())
        mbt_ffi_store32(iter_base + 8, address)
        cleanup_list.push(address)

        ()
      }
      Json(payload48) => {
        mbt_ffi_store8(iter_base + 0, 34)

        let ptr49 = mbt_ffi_str2ptr(payload48)
        mbt_ffi_store32(iter_base + 12, payload48.length())
        mbt_ffi_store32(iter_base + 8, ptr49)
        cleanup_list.push(ptr49)

        ()
      }
      Null => {
        mbt_ffi_store8(iter_base + 0, 35)

        ()
      }
    }
  }
  let return_area = mbt_ffi_malloc(20)
  wasmImportMethodDbTransactionQuery(
    handle,
    ptr,
    statement.length(),
    address51,
    params.length(),
    return_area,
  )

  let lifted84 = match mbt_ffi_load8_u(return_area + 0) {
    0 => {
      let array : Array[DbColumn] = []
      for index54 = 0
          index54 < mbt_ffi_load32(return_area + 8)
          index54 = index54 + 1 {
        let iter_base = mbt_ffi_load32(return_area + 4) + index54 * 32

        let result = mbt_ffi_ptr2str(
          mbt_ffi_load32(iter_base + 8),
          mbt_ffi_load32(iter_base + 12),
        )

        let lifted = match mbt_ffi_load8_u(iter_base + 16) {
          0 => DbColumnType::Boolean
          1 => DbColumnType::Tinyint
          2 => DbColumnType::Smallint
          3 => DbColumnType::Mediumint
          4 => DbColumnType::Int
          5 => DbColumnType::Bigint
          6 => DbColumnType::TinyintUnsigned
          7 => DbColumnType::SmallintUnsigned
          8 => DbColumnType::MediumintUnsigned
          9 => DbColumnType::IntUnsigned
          10 => DbColumnType::BigintUnsigned
          11 => DbColumnType::Float
          12 => DbColumnType::Double
          13 => DbColumnType::Decimal
          14 => DbColumnType::Date
          15 => DbColumnType::Datetime
          16 => DbColumnType::Timestamp
          17 => DbColumnType::Time
          18 => DbColumnType::Year
          19 => DbColumnType::Fixchar
          20 => DbColumnType::Varchar
          21 => DbColumnType::Tinytext
          22 => DbColumnType::Text
          23 => DbColumnType::Mediumtext
          24 => DbColumnType::Longtext
          25 => DbColumnType::Binary
          26 => DbColumnType::Varbinary
          27 => DbColumnType::Tinyblob
          28 => DbColumnType::Blob
          29 => DbColumnType::Mediumblob
          30 => DbColumnType::Longblob
          31 => DbColumnType::Enumeration
          32 => DbColumnType::Set
          33 => DbColumnType::Bit
          34 => DbColumnType::Json
          _ => panic()
        }

        let result53 = mbt_ffi_ptr2str(
          mbt_ffi_load32(iter_base + 20),
          mbt_ffi_load32(iter_base + 24),
        )

        array.push(DbColumn::{
          ordinal: mbt_ffi_load64(iter_base + 0).reinterpret_as_uint64(),
          name: result,
          db_type: lifted,
          db_type_name: result53,
        })
      }
      mbt_ffi_free(mbt_ffi_load32(return_area + 4))

      let array76 : Array[DbRow] = []
      for index77 = 0
          index77 < mbt_ffi_load32(return_area + 16)
          index77 = index77 + 1 {
        let iter_base = mbt_ffi_load32(return_area + 12) + index77 * 8

        let array74 : Array[DbValue] = []
        for index75 = 0
            index75 < mbt_ffi_load32(iter_base + 4)
            index75 = index75 + 1 {
          let iter_base = mbt_ffi_load32(iter_base + 0) + index75 * 24

          let lifted73 = match mbt_ffi_load8_u(iter_base + 0) {
            0 => DbValue::Boolean(mbt_ffi_load8_u(iter_base + 8) != 0)
            1 => DbValue::Tinyint(mbt_ffi_load8(iter_base + 8) - 0x100)
            2 => DbValue::Smallint(mbt_ffi_load16(iter_base + 8) - 0x10000)
            3 => DbValue::Mediumint(mbt_ffi_load32(iter_base + 8))
            4 => DbValue::Int(mbt_ffi_load32(iter_base + 8))
            5 => DbValue::Bigint(mbt_ffi_load64(iter_base + 8))
            6 =>
