        mbt_ffi_store32(iter_base + 12, payload8.length())
        mbt_ffi_store32(iter_base + 8, ptr9)
        cleanup_list.push(ptr9)

        ()
      }
      DbUuid(payload10) => {
        mbt_ffi_store8(iter_base + 0, 10)
        mbt_ffi_store64(iter_base + 8, payload10.0.reinterpret_as_int64())
        mbt_ffi_store64(iter_base + 16, payload10.1.reinterpret_as_int64())

        ()
