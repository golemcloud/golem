///|
pub fn DbConnection::execute(
  self : DbConnection,
  statement : String,
  params : Array[DbValue],
) -> Result[Int64, Error_] {
  let cleanup_list : Array[Int] = []

  let DbConnection(handle) = self

  let ptr = mbt_ffi_str2ptr(statement)

  let address = mbt_ffi_malloc(params.length() * 24)
  for index = 0; index < params.length(); index = index + 1 {
    let iter_elem : DbValue = params[index]
    let iter_base = address + index * 24

    match iter_elem {
      DbNull => {
        mbt_ffi_store8(iter_base + 0, 0)

        ()
      }
      DbBoolean(payload0) => {
        mbt_ffi_store8(iter_base + 0, 1)
        mbt_ffi_store8(iter_base + 8, if payload0 { 1 } else { 0 })

        ()
      }
      DbByte(payload1) => {
        mbt_ffi_store8(iter_base + 0, 2)
        mbt_ffi_store8(iter_base + 8, mbt_ffi_extend8(payload1))

        ()
      }
      DbShort(payload2) => {
        mbt_ffi_store8(iter_base + 0, 3)
        mbt_ffi_store16(iter_base + 8, mbt_ffi_extend16(payload2))

        ()
      }
      DbInt(payload3) => {
        mbt_ffi_store8(iter_base + 0, 4)
        mbt_ffi_store32(iter_base + 8, payload3)

        ()
      }
      DbLong(payload4) => {
        mbt_ffi_store8(iter_base + 0, 5)
        mbt_ffi_store64(iter_base + 8, payload4)

        ()
      }
      DbFloat(payload5) => {
        mbt_ffi_store8(iter_base + 0, 6)
        mbt_ffi_storef32(iter_base + 8, payload5)

        ()
      }
      DbDouble(payload6) => {
        mbt_ffi_store8(iter_base + 0, 7)
        mbt_ffi_storef64(iter_base + 8, payload6)

        ()
      }
      DbChar(payload7) => {
        mbt_ffi_store8(iter_base + 0, 8)
        mbt_ffi_store16(iter_base + 8, payload7.reinterpret_as_int())

        ()
      }
      DbString(payload8) => {
        mbt_ffi_store8(iter_base + 0, 9)

        let ptr9 = mbt_ffi_str2ptr(payload8)
        mbt_ffi_store32(iter_base + 12, payload8.length())
        mbt_ffi_store32(iter_base + 8, ptr9)
        cleanup_list.push(ptr9)

        ()
      }
      DbUuid(payload10) => {
        mbt_ffi_store8(iter_base + 0, 10)
        mbt_ffi_store64(iter_base + 8, payload10.0.reinterpret_as_int64())
        mbt_ffi_store64(iter_base + 16, payload10.1.reinterpret_as_int64())

        ()
      }
      DbDate(payload11) => {
        mbt_ffi_store8(iter_base + 0, 11)
        mbt_ffi_store64(iter_base + 8, payload11)

        ()
      }
      DbTimestamp(payload12) => {
        mbt_ffi_store8(iter_base + 0, 12)
        mbt_ffi_store64(iter_base + 8, payload12.0)
        mbt_ffi_store32(iter_base + 16, payload12.1)

        ()
      }
      DbTime(payload13) => {
        mbt_ffi_store8(iter_base + 0, 13)
        mbt_ffi_store64(iter_base + 8, payload13)

        ()
      }
      DbDecimal(payload14) => {
        mbt_ffi_store8(iter_base + 0, 14)

        let ptr15 = mbt_ffi_str2ptr(payload14)
        mbt_ffi_store32(iter_base + 12, payload14.length())
        mbt_ffi_store32(iter_base + 8, ptr15)
        cleanup_list.push(ptr15)

        ()
      }
      DbByteArray(payload16) => {
        mbt_ffi_store8(iter_base + 0, 15)

        let ptr17 = mbt_ffi_bytes2ptr(payload16)

        mbt_ffi_store32(iter_base + 12, payload16.length())
        mbt_ffi_store32(iter_base + 8, ptr17)
        cleanup_list.push(ptr17)

        ()
      }
    }
  }
  let return_area = mbt_ffi_malloc(24)
  wasmImportMethodDbConnectionExecute(
    handle,
    ptr,
    statement.length(),
    address,
    params.length(),
    return_area,
  )

  let lifted22 = match mbt_ffi_load8_u(return_area + 0) {
    0 => Result::Ok(mbt_ffi_load64(return_area + 8))
    1 => {
      let lifted = match mbt_ffi_load8_u(return_area + 8) {
        0 => {
          let result = mbt_ffi_ptr2str(
            mbt_ffi_load32(return_area + 12),
            mbt_ffi_load32(return_area + 16),
          )

          Error_::ConnectionFailure(result)
        }
        1 => {
          let result18 = mbt_ffi_ptr2str(
            mbt_ffi_load32(return_area + 12),
            mbt_ffi_load32(return_area + 16),
          )

          Error_::QueryParameterFailure(result18)
        }
        2 => {
          let result19 = mbt_ffi_ptr2str(
            mbt_ffi_load32(return_area + 12),
            mbt_ffi_load32(return_area + 16),
          )

          Error_::QueryExecutionFailure(result19)
        }
        3 => {
          let result20 = mbt_ffi_ptr2str(
            mbt_ffi_load32(return_area + 12),
            mbt_ffi_load32(return_area + 16),
          )

          Error_::QueryResponseFailure(result20)
        }
        4 => {
          let result21 = mbt_ffi_ptr2str(
            mbt_ffi_load32(return_area + 12),
            mbt_ffi_load32(return_area + 16),
          )

          Error_::Other(result21)
        }
        _ => panic()
      }

      Result::Err(lifted)
    }
    _ => panic()
  }
  let ret = lifted22
  mbt_ffi_free(ptr)
  mbt_ffi_free(address)
  mbt_ffi_free(return_area)
  cleanup_list.each(mbt_ffi_free)
  return ret
}

