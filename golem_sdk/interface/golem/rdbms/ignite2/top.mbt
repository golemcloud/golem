        mbt_ffi_store64(iter_base + 8, payload13)

        ()
      }
      DbDecimal(payload14) => {
        mbt_ffi_store8(iter_base + 0, 14)

        let ptr15 = mbt_ffi_str2ptr(payload14)
        mbt_ffi_store32(iter_base + 12, payload14.length())
        mbt_ffi_store32(iter_base + 8, ptr15)
        cleanup_list.push(ptr15)

