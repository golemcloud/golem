///|
/// Get schema manager for the graph
pub fn get_schema_manager(
  config : @connection.ConnectionConfig?,
) -> Result[SchemaManager, @errors.GraphError] {
  let cleanupList : Array[@ffi.Cleanup] = []
  let ignoreList : Array[&@ffi.Any] = []
  let return_area = @ffi.malloc(80)
  match config {
    None => {
      @ffi.store8(return_area + 0, 0)
      ()
    }
    Some(payload2) => {
      @ffi.store8(return_area + 0, 1)
      match payload2.hosts {
        None => {
          @ffi.store8(return_area + 4, 0)
          ()
        }
        Some(payload8) => {
          @ffi.store8(return_area + 4, 1)
          let address = @ffi.malloc(payload8.length() * 8)
          for index = 0; index < payload8.length(); index = index + 1 {
            let element9 : String = payload8[index]
            let base10 = address + index * 8
            @ffi.store32(base10 + 4, element9.length())
            @ffi.store32(base10 + 0, @ffi.str2ptr(element9))
            ignoreList.push(element9)
          }
          @ffi.store32(return_area + 12, payload8.length())
          @ffi.store32(return_area + 8, address)
          cleanupList.push({ address, size: payload8.length() * 8, align: 4 })
          ()
        }
      }
      match payload2.port {
        None => {
          @ffi.store8(return_area + 16, 0)
          ()
        }
        Some(payload16) => {
          @ffi.store8(return_area + 16, 1)
          @ffi.store16(return_area + 18, payload16.reinterpret_as_int())
          ()
        }
      }
      match payload2.database_name {
        None => {
          @ffi.store8(return_area + 20, 0)
          ()
        }
        Some(payload22) => {
          @ffi.store8(return_area + 20, 1)
          @ffi.store32(return_area + 28, payload22.length())
          @ffi.store32(return_area + 24, @ffi.str2ptr(payload22))
          ignoreList.push(payload22)
          ()
        }
      }
      match payload2.username {
        None => {
          @ffi.store8(return_area + 32, 0)
          ()
        }
        Some(payload28) => {
          @ffi.store8(return_area + 32, 1)
          @ffi.store32(return_area + 40, payload28.length())
          @ffi.store32(return_area + 36, @ffi.str2ptr(payload28))
          ignoreList.push(payload28)
          ()
        }
      }
      match payload2.password {
        None => {
          @ffi.store8(return_area + 44, 0)
          ()
        }
        Some(payload34) => {
          @ffi.store8(return_area + 44, 1)
          @ffi.store32(return_area + 52, payload34.length())
          @ffi.store32(return_area + 48, @ffi.str2ptr(payload34))
          ignoreList.push(payload34)
          ()
        }
      }
      match payload2.timeout_seconds {
        None => {
          @ffi.store8(return_area + 56, 0)
          ()
        }
        Some(payload40) => {
          @ffi.store8(return_area + 56, 1)
          @ffi.store32(return_area + 60, payload40.reinterpret_as_int())
          ()
        }
      }
      match payload2.max_connections {
        None => {
          @ffi.store8(return_area + 64, 0)
          ()
        }
        Some(payload46) => {
          @ffi.store8(return_area + 64, 1)
          @ffi.store32(return_area + 68, payload46.reinterpret_as_int())
          ()
        }
      }
      let address49 = @ffi.malloc(payload2.provider_config.length() * 16)
      for index50 = 0
          index50 < payload2.provider_config.length()
          index50 = index50 + 1 {
        let element47 : (String, String) = payload2.provider_config[index50]
        let base48 = address49 + index50 * 16
        @ffi.store32(base48 + 4, element47.0.length())
        @ffi.store32(base48 + 0, @ffi.str2ptr(element47.0))
        @ffi.store32(base48 + 12, element47.1.length())
        @ffi.store32(base48 + 8, @ffi.str2ptr(element47.1))
        ignoreList.push(element47.0)
        ignoreList.push(element47.1)
      }
      @ffi.store32(return_area + 76, payload2.provider_config.length())
      @ffi.store32(return_area + 72, address49)
      cleanupList.push({
        address: address49,
        size: payload2.provider_config.length() * 16,
        align: 4,
      })
      ()
    }
  }
  let return_area51 = @ffi.malloc(32)
  wasmImportGetSchemaManager(return_area, return_area51)
  let lifted121 = match @ffi.load8_u(return_area51 + 0) {
    0 =>
      Result::Ok(SchemaManager::SchemaManager(@ffi.load32(return_area51 + 8)))
    1 => {
      let lifted120 = match @ffi.load8_u(return_area51 + 8) {
        0 => {
          let result = @ffi.ptr2str(
            @ffi.load32(return_area51 + 16),
            @ffi.load32(return_area51 + 20),
          )
          @errors.GraphError::UnsupportedOperation(result)
        }
        1 => {
          let result60 = @ffi.ptr2str(
            @ffi.load32(return_area51 + 16),
            @ffi.load32(return_area51 + 20),
          )
          @errors.GraphError::ConnectionFailed(result60)
        }
        2 => {
          let result63 = @ffi.ptr2str(
            @ffi.load32(return_area51 + 16),
            @ffi.load32(return_area51 + 20),
          )
          @errors.GraphError::AuthenticationFailed(result63)
        }
        3 => {
          let result66 = @ffi.ptr2str(
            @ffi.load32(return_area51 + 16),
            @ffi.load32(return_area51 + 20),
          )
          @errors.GraphError::AuthorizationFailed(result66)
        }
        4 => {
          let lifted = match @ffi.load8_u(return_area51 + 16) {
            0 => {
              let result71 = @ffi.ptr2str(
                @ffi.load32(return_area51 + 24),
                @ffi.load32(return_area51 + 28),
              )
              @types.ElementId::StringValue(result71)
            }
            1 => @types.ElementId::Int64(@ffi.load64(return_area51 + 24))
            2 => {
              let result76 = @ffi.ptr2str(
                @ffi.load32(return_area51 + 24),
                @ffi.load32(return_area51 + 28),
              )
              @types.ElementId::Uuid(result76)
            }
            _ => panic()
          }
          @errors.GraphError::ElementNotFound(lifted)
        }
        5 => {
          let lifted87 = match @ffi.load8_u(return_area51 + 16) {
            0 => {
              let result81 = @ffi.ptr2str(
                @ffi.load32(return_area51 + 24),
                @ffi.load32(return_area51 + 28),
              )
              @types.ElementId::StringValue(result81)
            }
            1 => @types.ElementId::Int64(@ffi.load64(return_area51 + 24))
            2 => {
              let result86 = @ffi.ptr2str(
                @ffi.load32(return_area51 + 24),
                @ffi.load32(return_area51 + 28),
              )
              @types.ElementId::Uuid(result86)
            }
            _ => panic()
          }
          @errors.GraphError::DuplicateElement(lifted87)
        }
        6 => {
          let result90 = @ffi.ptr2str(
            @ffi.load32(return_area51 + 16),
            @ffi.load32(return_area51 + 20),
          )
          @errors.GraphError::SchemaViolation(result90)
        }
        7 => {
          let result93 = @ffi.ptr2str(
            @ffi.load32(return_area51 + 16),
            @ffi.load32(return_area51 + 20),
          )
          @errors.GraphError::ConstraintViolation(result93)
        }
        8 => {
          let result96 = @ffi.ptr2str(
            @ffi.load32(return_area51 + 16),
            @ffi.load32(return_area51 + 20),
          )
          @errors.GraphError::InvalidPropertyType(result96)
        }
        9 => {
          let result99 = @ffi.ptr2str(
            @ffi.load32(return_area51 + 16),
            @ffi.load32(return_area51 + 20),
          )
          @errors.GraphError::InvalidQuery(result99)
        }
        10 => {
          let result102 = @ffi.ptr2str(
            @ffi.load32(return_area51 + 16),
            @ffi.load32(return_area51 + 20),
          )
          @errors.GraphError::TransactionFailed(result102)
        }
        11 => @errors.GraphError::TransactionConflict
        12 => @errors.GraphError::TransactionTimeout
        13 => @errors.GraphError::DeadlockDetected
        14 => @errors.GraphError::Timeout
        15 => {
          let result113 = @ffi.ptr2str(
            @ffi.load32(return_area51 + 16),
            @ffi.load32(return_area51 + 20),
          )
          @errors.GraphError::ResourceExhausted(result113)
        }
        16 => {
          let result116 = @ffi.ptr2str(
            @ffi.load32(return_area51 + 16),
            @ffi.load32(return_area51 + 20),
          )
          @errors.GraphError::InternalError(result116)
        }
        17 => {
          let result119 = @ffi.ptr2str(
            @ffi.load32(return_area51 + 16),
            @ffi.load32(return_area51 + 20),
          )
          @errors.GraphError::ServiceUnavailable(result119)
        }
        _ => panic()
      }
      Result::Err(lifted120)
    }
    _ => panic()
  }
  @ffi.free(return_area)
  @ffi.free(return_area51)
  cleanupList.each(fn(cleanup) { @ffi.free(cleanup.address) })
  ignore(ignoreList)
  return lifted121
}
