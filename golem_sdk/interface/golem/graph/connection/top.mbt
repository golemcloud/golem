                @ffi.load32(return_area45 + 24),
                @ffi.load32(return_area45 + 28),
              )
              @types.ElementId::Uuid(result70)
            }
            _ => panic()
          }
          @errors.GraphError::ElementNotFound(lifted)
        }
        5 => {
          let lifted81 = match @ffi.load8_u(return_area45 + 16) {
            0 => {
              let result75 = @ffi.ptr2str(
                @ffi.load32(return_area45 + 24),
                @ffi.load32(return_area45 + 28),
              )
              @types.ElementId::StringValue(result75)
            }
            1 => @types.ElementId::Int64(@ffi.load64(return_area45 + 24))
            2 => {
              let result80 = @ffi.ptr2str(
                @ffi.load32(return_area45 + 24),
                @ffi.load32(return_area45 + 28),
              )
              @types.ElementId::Uuid(result80)
            }
            _ => panic()
          }
          @errors.GraphError::DuplicateElement(lifted81)
        }
        6 => {
          let result84 = @ffi.ptr2str(
            @ffi.load32(return_area45 + 16),
            @ffi.load32(return_area45 + 20),
          )
          @errors.GraphError::SchemaViolation(result84)
        }
        7 => {
          let result87 = @ffi.ptr2str(
            @ffi.load32(return_area45 + 16),
            @ffi.load32(return_area45 + 20),
          )
          @errors.GraphError::ConstraintViolation(result87)
        }
        8 => {
          let result90 = @ffi.ptr2str(
            @ffi.load32(return_area45 + 16),
            @ffi.load32(return_area45 + 20),
          )
          @errors.GraphError::InvalidPropertyType(result90)
        }
        9 => {
          let result93 = @ffi.ptr2str(
            @ffi.load32(return_area45 + 16),
            @ffi.load32(return_area45 + 20),
          )
          @errors.GraphError::InvalidQuery(result93)
        }
        10 => {
          let result96 = @ffi.ptr2str(
            @ffi.load32(return_area45 + 16),
            @ffi.load32(return_area45 + 20),
          )
          @errors.GraphError::TransactionFailed(result96)
        }
        11 => @errors.GraphError::TransactionConflict
        12 => @errors.GraphError::TransactionTimeout
        13 => @errors.GraphError::DeadlockDetected
        14 => @errors.GraphError::Timeout
        15 => {
          let result107 = @ffi.ptr2str(
            @ffi.load32(return_area45 + 16),
            @ffi.load32(return_area45 + 20),
          )
          @errors.GraphError::ResourceExhausted(result107)
        }
        16 => {
          let result110 = @ffi.ptr2str(
            @ffi.load32(return_area45 + 16),
            @ffi.load32(return_area45 + 20),
          )
          @errors.GraphError::InternalError(result110)
        }
        17 => {
          let result113 = @ffi.ptr2str(
            @ffi.load32(return_area45 + 16),
            @ffi.load32(return_area45 + 20),
          )
          @errors.GraphError::ServiceUnavailable(result113)
        }
        _ => panic()
      }
      Result::Err(lifted114)
    }
    _ => panic()
  }
  @ffi.free(return_area)
  @ffi.free(address43)
  @ffi.free(return_area45)
  cleanupList.each(fn(cleanup) { @ffi.free(cleanup.address) })
  ignore(ignoreList)
  return lifted115
}
