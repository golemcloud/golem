///|
/// Connect to a graph database with the specified configuration
pub fn connect(config : ConnectionConfig) -> Result[Graph, @errors.GraphError] {
  let cleanupList : Array[@ffi.Cleanup] = []
  let ignoreList : Array[&@ffi.Any] = []
  let return_area = @ffi.malloc(76)
  match config.hosts {
    None => {
      @ffi.store8(return_area + 0, 0)
      ()
    }
    Some(payload2) => {
      @ffi.store8(return_area + 0, 1)
      let address = @ffi.malloc(payload2.length() * 8)
      for index = 0; index < payload2.length(); index = index + 1 {
        let element3 : String = payload2[index]
        let base4 = address + index * 8
        @ffi.store32(base4 + 4, element3.length())
        @ffi.store32(base4 + 0, @ffi.str2ptr(element3))
        ignoreList.push(element3)
      }
      @ffi.store32(return_area + 8, payload2.length())
      @ffi.store32(return_area + 4, address)
      cleanupList.push({ address, size: payload2.length() * 8, align: 4 })
      ()
    }
  }
  match config.port {
    None => {
      @ffi.store8(return_area + 12, 0)
      ()
    }
    Some(payload10) => {
      @ffi.store8(return_area + 12, 1)
      @ffi.store16(return_area + 14, payload10.reinterpret_as_int())
      ()
    }
  }
  match config.database_name {
    None => {
      @ffi.store8(return_area + 16, 0)
      ()
    }
    Some(payload16) => {
      @ffi.store8(return_area + 16, 1)
      @ffi.store32(return_area + 24, payload16.length())
      @ffi.store32(return_area + 20, @ffi.str2ptr(payload16))
      ignoreList.push(payload16)
      ()
    }
  }
  match config.username {
    None => {
      @ffi.store8(return_area + 28, 0)
      ()
    }
    Some(payload22) => {
      @ffi.store8(return_area + 28, 1)
      @ffi.store32(return_area + 36, payload22.length())
      @ffi.store32(return_area + 32, @ffi.str2ptr(payload22))
      ignoreList.push(payload22)
      ()
    }
  }
  match config.password {
    None => {
      @ffi.store8(return_area + 40, 0)
      ()
    }
    Some(payload28) => {
      @ffi.store8(return_area + 40, 1)
      @ffi.store32(return_area + 48, payload28.length())
      @ffi.store32(return_area + 44, @ffi.str2ptr(payload28))
      ignoreList.push(payload28)
      ()
    }
  }
  match config.timeout_seconds {
    None => {
      @ffi.store8(return_area + 52, 0)
      ()
    }
    Some(payload34) => {
      @ffi.store8(return_area + 52, 1)
      @ffi.store32(return_area + 56, payload34.reinterpret_as_int())
      ()
    }
  }
  match config.max_connections {
    None => {
      @ffi.store8(return_area + 60, 0)
      ()
    }
    Some(payload40) => {
      @ffi.store8(return_area + 60, 1)
      @ffi.store32(return_area + 64, payload40.reinterpret_as_int())
      ()
    }
  }
  let address43 = @ffi.malloc(config.provider_config.length() * 16)
  for index44 = 0
      index44 < config.provider_config.length()
      index44 = index44 + 1 {
    let element41 : (String, String) = config.provider_config[index44]
    let base42 = address43 + index44 * 16
    @ffi.store32(base42 + 4, element41.0.length())
    @ffi.store32(base42 + 0, @ffi.str2ptr(element41.0))
    @ffi.store32(base42 + 12, element41.1.length())
    @ffi.store32(base42 + 8, @ffi.str2ptr(element41.1))
    ignoreList.push(element41.0)
    ignoreList.push(element41.1)
  }
  @ffi.store32(return_area + 72, config.provider_config.length())
  @ffi.store32(return_area + 68, address43)
  let return_area45 = @ffi.malloc(32)
  wasmImportConnect(return_area, return_area45)
  let lifted115 = match @ffi.load8_u(return_area45 + 0) {
    0 => Result::Ok(Graph::Graph(@ffi.load32(return_area45 + 8)))
    1 => {
      let lifted114 = match @ffi.load8_u(return_area45 + 8) {
        0 => {
          let result = @ffi.ptr2str(
            @ffi.load32(return_area45 + 16),
            @ffi.load32(return_area45 + 20),
          )
          @errors.GraphError::UnsupportedOperation(result)
        }
        1 => {
          let result54 = @ffi.ptr2str(
            @ffi.load32(return_area45 + 16),
