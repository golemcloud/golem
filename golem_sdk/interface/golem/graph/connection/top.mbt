          )
          @errors.GraphError::AuthenticationFailed(result57)
        }
        3 => {
          let result60 = @ffi.ptr2str(
            @ffi.load32(return_area45 + 16),
            @ffi.load32(return_area45 + 20),
          )
          @errors.GraphError::AuthorizationFailed(result60)
        }
        4 => {
          let lifted = match @ffi.load8_u(return_area45 + 16) {
            0 => {
              let result65 = @ffi.ptr2str(
                @ffi.load32(return_area45 + 24),
                @ffi.load32(return_area45 + 28),
              )
              @types.ElementId::StringValue(result65)
            }
            1 => @types.ElementId::Int64(@ffi.load64(return_area45 + 24))
            2 => {
