    handle,
    @ffi.str2ptr(statement),
    statement.length(),
    address284,
    params.length(),
    return_area,
  )
  let lifted304 = match @ffi.load8_u(return_area + 0) {
    0 =>
      Result::Ok(DbResultStream::DbResultStream(@ffi.load32(return_area + 4)))
    1 => {
      let lifted = match @ffi.load8_u(return_area + 4) {
        0 => {
          let result = @ffi.ptr2str(
            @ffi.load32(return_area + 8),
            @ffi.load32(return_area + 12),
          )
          Error_::ConnectionFailure(result)
        }
        1 => {
          let result294 = @ffi.ptr2str(
            @ffi.load32(return_area + 8),
            @ffi.load32(return_area + 12),
          )
          Error_::QueryParameterFailure(result294)
        }
        2 => {
          let result297 = @ffi.ptr2str(
            @ffi.load32(return_area + 8),
            @ffi.load32(return_area + 12),
          )
          Error_::QueryExecutionFailure(result297)
        }
        3 => {
          let result300 = @ffi.ptr2str(
            @ffi.load32(return_area + 8),
            @ffi.load32(return_area + 12),
          )
          Error_::QueryResponseFailure(result300)
        }
        4 => {
          let result303 = @ffi.ptr2str(
            @ffi.load32(return_area + 8),
            @ffi.load32(return_area + 12),
          )
          Error_::Other(result303)
        }
        _ => panic()
      }
      Result::Err(lifted)
    }
    _ => panic()
  }
  ignore(statement)
  @ffi.free(address284)
  @ffi.free(return_area)
  cleanupList.each(fn(cleanup) { @ffi.free(cleanup.address) })
  ignore(ignoreList)
  return lifted304
}

