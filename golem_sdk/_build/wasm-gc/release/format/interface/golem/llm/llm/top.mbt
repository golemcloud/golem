///|
/// Makes a single call to the LLM and gets back a streaming API to receive the response in chunks.
pub fn stream(events : Array[Event], config : Config) -> ChatStream {
  let cleanupList : Array[@ffi.Cleanup] = []
  let ignoreList : Array[&@ffi.Any] = []
  let return_area = @ffi.malloc(80)
  let address142 = @ffi.malloc(events.length() * 96)
  for index143 = 0; index143 < events.length(); index143 = index143 + 1 {
    let element : Event = events[index143]
    let base = address142 + index143 * 96
    match element {
      Message(payload) => {
        @ffi.store8(base + 0, 0)
        @ffi.store8(base + 4, payload.role.ordinal())
        match payload.name {
          None => {
            @ffi.store8(base + 8, 0)
            ()
          }
          Some(payload7) => {
            @ffi.store8(base + 8, 1)
            @ffi.store32(base + 16, payload7.length())
            @ffi.store32(base + 12, @ffi.str2ptr(payload7))
            ignoreList.push(payload7)
            ()
          }
        }
        let address = @ffi.malloc(payload.content.length() * 28)
        for index = 0; index < payload.content.length(); index = index + 1 {
          let element8 : ContentPart = payload.content[index]
          let base9 = address + index * 28
          match element8 {
            Text(payload12) => {
              @ffi.store8(base9 + 0, 0)
              @ffi.store32(base9 + 8, payload12.length())
              @ffi.store32(base9 + 4, @ffi.str2ptr(payload12))
              ignoreList.push(payload12)
              ()
            }
            Image(payload15) => {
              @ffi.store8(base9 + 0, 1)
              match payload15 {
                Url(payload18) => {
                  @ffi.store8(base9 + 4, 0)
                  @ffi.store32(base9 + 12, payload18.url.length())
                  @ffi.store32(base9 + 8, @ffi.str2ptr(payload18.url))
                  match payload18.detail {
                    None => {
                      @ffi.store8(base9 + 16, 0)
                      ()
                    }
                    Some(payload24) => {
                      @ffi.store8(base9 + 16, 1)
                      @ffi.store8(base9 + 17, payload24.ordinal())
                      ()
                    }
                  }
                  ignoreList.push(payload18.url)
                  ()
                }
                Inline(payload27) => {
                  @ffi.store8(base9 + 4, 1)
                  @ffi.store32(base9 + 12, payload27.data.length())
