        3 => {
          let result20 = @ffi.ptr2str(
            @ffi.load32(return_area + 8),
            @ffi.load32(return_area + 12),
          )
          @types.SearchError::Internal(result20)
        }
        4 => @types.SearchError::Timeout
        5 => @types.SearchError::RateLimited
        _ => panic()
      }
      Result::Err(lifted)
    }
    _ => panic()
  }
  ignore(index)
