  let (lowered, lowered6, lowered7) = match schema.primary_key {
    None => (0, 0, 0)
    Some(payload5) => {
      ignoreList.push(payload5)
      (1, @ffi.str2ptr(payload5), payload5.length())
    }
  }
  let return_area = @ffi.malloc(16)
  wasmImportUpdateSchema(
    @ffi.str2ptr(index),
    index.length(),
    address,
    schema.fields.length(),
    lowered,
    lowered6,
    lowered7,
    return_area,
  )
  let lifted25 = match @ffi.load8_u(return_area + 0) {
    0 => Result::Ok(())
    1 => {
      let lifted = match @ffi.load8_u(return_area + 4) {
        0 => @types.SearchError::IndexNotFound
        1 => {
          let result = @ffi.ptr2str(
            @ffi.load32(return_area + 8),
            @ffi.load32(return_area + 12),
          )
          @types.SearchError::InvalidQuery(result)
