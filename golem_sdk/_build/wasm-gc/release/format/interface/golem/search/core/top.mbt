///|
pub fn update_schema(
  index : String,
  schema : @types.Schema,
) -> Result[Unit, @types.SearchError] {
  let cleanupList : Array[@ffi.Cleanup] = []
  let ignoreList : Array[&@ffi.Any] = []
  let address = @ffi.malloc(schema.fields.length() * 16)
  for index0 = 0; index0 < schema.fields.length(); index0 = index0 + 1 {
    let element : @types.SchemaField = schema.fields[index0]
    let base = address + index0 * 16
    @ffi.store32(base + 4, element.name.length())
    @ffi.store32(base + 0, @ffi.str2ptr(element.name))
    @ffi.store8(base + 8, element.field_type.ordinal())
    @ffi.store8(base + 9, if element.required { 1 } else { 0 })
    @ffi.store8(base + 10, if element.facet { 1 } else { 0 })
    @ffi.store8(base + 11, if element.sort { 1 } else { 0 })
    @ffi.store8(base + 12, if element.index { 1 } else { 0 })
    ignoreList.push(element.name)
