        let result = @ffi.ptr2str(
          @ffi.load32(base1 + 0),
          @ffi.load32(base1 + 4),
        )
        array.push(@types.SchemaField::{
          name: result,
          field_type: @types.FieldType::from(@ffi.load8_u(base1 + 8)),
          required: @ffi.load8_u(base1 + 9) != 0,
          facet: @ffi.load8_u(base1 + 10) != 0,
          sort: @ffi.load8_u(base1 + 11) != 0,
          index: @ffi.load8_u(base1 + 12) != 0,
        })
      }
      @ffi.free(@ffi.load32(return_area + 4))
      let lifted : String? = match @ffi.load8_u(return_area + 12) {
        0 => Option::None
        1 => {
          let result7 = @ffi.ptr2str(
            @ffi.load32(return_area + 16),
            @ffi.load32(return_area + 20),
          )
          Option::Some(result7)
        }
        _ => panic()
      }
      Result::Ok(@types.Schema::{ fields: array, primary_key: lifted })
    }
    1 => {
      let lifted24 = match @ffi.load8_u(return_area + 4) {
        0 => @types.SearchError::IndexNotFound
        1 => {
          let result14 = @ffi.ptr2str(
            @ffi.load32(return_area + 8),
            @ffi.load32(return_area + 12),
          )
          @types.SearchError::InvalidQuery(result14)
