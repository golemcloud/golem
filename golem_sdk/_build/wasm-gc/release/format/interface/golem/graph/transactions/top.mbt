///|
/// Update vertex properties (replaces all properties)
pub fn Transaction::update_vertex(
  self : Transaction,
  options : @types.UpdateVertexOptions,
) -> Result[@types.Vertex, @errors.GraphError] {
  let cleanupList : Array[@ffi.Cleanup] = []
  let ignoreList : Array[&@ffi.Any] = []
  let Transaction(handle) = self
  let (lowered, lowered6, lowered7) = match options.id {
    StringValue(payload) => {
      ignoreList.push(payload)
      (0, Int::to_int64(@ffi.str2ptr(payload)), payload.length())
    }
    Int64(payload2) => (1, payload2, 0)
    Uuid(payload5) => {
      ignoreList.push(payload5)
      (2, Int::to_int64(@ffi.str2ptr(payload5)), payload5.length())
    }
  }
  let address123 = @ffi.malloc(options.properties.length() * 48)
  for index124 = 0
      index124 < options.properties.length()
      index124 = index124 + 1 {
    let element8 : (String, @types.PropertyValue) = options.properties[index124]
    let base9 = address123 + index124 * 48
    @ffi.store32(base9 + 4, element8.0.length())
    @ffi.store32(base9 + 0, @ffi.str2ptr(element8.0))
    match element8.1 {
      NullValue => {
        @ffi.store8(base9 + 8, 0)
        ()
      }
      Boolean(payload15) => {
        @ffi.store8(base9 + 8, 1)
        @ffi.store8(base9 + 16, if payload15 { 1 } else { 0 })
        ()
      }
      Int8(payload18) => {
        @ffi.store8(base9 + 8, 2)
        @ffi.store8(base9 + 16, @ffi.extend8(payload18))
        ()
      }
      Int16(payload21) => {
        @ffi.store8(base9 + 8, 3)
        @ffi.store16(base9 + 16, @ffi.extend16(payload21))
        ()
      }
      Int32(payload24) => {
        @ffi.store8(base9 + 8, 4)
        @ffi.store32(base9 + 16, payload24)
        ()
      }
      Int64(payload27) => {
        @ffi.store8(base9 + 8, 5)
        @ffi.store64(base9 + 16, payload27)
        ()
      }
      Uint8(payload30) => {
        @ffi.store8(base9 + 8, 6)
        @ffi.store8(base9 + 16, payload30.to_int())
        ()
      }
      Uint16(payload33) => {
        @ffi.store8(base9 + 8, 7)
        @ffi.store16(base9 + 16, payload33.reinterpret_as_int())
        ()
      }
      Uint32(payload36) => {
        @ffi.store8(base9 + 8, 8)
        @ffi.store32(base9 + 16, payload36.reinterpret_as_int())
        ()
      }
      Uint64(payload39) => {
        @ffi.store8(base9 + 8, 9)
        @ffi.store64(base9 + 16, payload39.reinterpret_as_int64())
        ()
      }
      Float32Value(payload42) => {
        @ffi.store8(base9 + 8, 10)
        @ffi.storef32(base9 + 16, payload42)
        ()
      }
      Float64Value(payload45) => {
        @ffi.store8(base9 + 8, 11)
        @ffi.storef64(base9 + 16, payload45)
