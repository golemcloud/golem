///|
/// == TRAVESAL OPERATIONS ==
/// Find shortest path between two vertices
pub fn Transaction::find_shortest_path(
  self : Transaction,
  options : @types.FindShortestPathOptions,
) -> Result[@types.Path?, @errors.GraphError] {
  let cleanupList : Array[@ffi.Cleanup] = []
  let ignoreList : Array[&@ffi.Any] = []
  let return_area = @ffi.malloc(104)
  let Transaction(handle) = self
  @ffi.store32(return_area + 0, handle)
  match options.from_vertex {
    StringValue(payload) => {
      @ffi.store8(return_area + 8, 0)
      @ffi.store32(return_area + 20, payload.length())
      @ffi.store32(return_area + 16, @ffi.str2ptr(payload))
      ignoreList.push(payload)
      ()
    }
    Int64(payload2) => {
      @ffi.store8(return_area + 8, 1)
      @ffi.store64(return_area + 16, payload2)
      ()
    }
