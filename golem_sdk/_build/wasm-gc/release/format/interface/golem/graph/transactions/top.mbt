///|
/// Find all paths between two vertices (up to limit)
pub fn Transaction::find_all_paths(
  self : Transaction,
  options : @types.FindAllPathsOptions,
) -> Result[Array[@types.Path], @errors.GraphError] {
  let cleanupList : Array[@ffi.Cleanup] = []
  let ignoreList : Array[&@ffi.Any] = []
  let return_area = @ffi.malloc(112)
  let Transaction(handle) = self
  @ffi.store32(return_area + 0, handle)
  match options.from_vertex {
    StringValue(payload) => {
      @ffi.store8(return_area + 8, 0)
