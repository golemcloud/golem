              match iter_elem.owner {
                None => {
                  mbt_ffi_store8(iter_base + 12, 0)

                  ()
                }
                Some(payload14) => {
                  mbt_ffi_store8(iter_base + 12, 1)

                  let ptr15 = mbt_ffi_str2ptr(payload14)
                  mbt_ffi_store32(iter_base + 20, payload14.length())
