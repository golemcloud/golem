///|
pub fn wasmExportDiscoverAgentTypes() -> Int {
  let result : Result[Array[@common.AgentType], @common.AgentError] = @guest.discover_agent_types()

  match result {
    Ok(payload) => {
      mbt_ffi_store8(return_area + 0, 0)

      let address837 = mbt_ffi_malloc(payload.length() * 80)
      for index838 = 0; index838 < payload.length(); index838 = index838 + 1 {
        let iter_elem : @common.AgentType = payload[index838]
        let iter_base = address837 + index838 * 80

        let ptr = mbt_ffi_str2ptr(iter_elem.type_name)
        mbt_ffi_store32(iter_base + 4, iter_elem.type_name.length())
        mbt_ffi_store32(iter_base + 0, ptr)

        let ptr0 = mbt_ffi_str2ptr(iter_elem.description)
        mbt_ffi_store32(iter_base + 12, iter_elem.description.length())
        mbt_ffi_store32(iter_base + 8, ptr0)

        match iter_elem.constructor_.name {
          None => {
            mbt_ffi_store8(iter_base + 16, 0)

            ()
          }
          Some(payload2) => {
            mbt_ffi_store8(iter_base + 16, 1)

            let ptr3 = mbt_ffi_str2ptr(payload2)
            mbt_ffi_store32(iter_base + 24, payload2.length())
            mbt_ffi_store32(iter_base + 20, ptr3)

            ()
          }
        }

        let ptr4 = mbt_ffi_str2ptr(iter_elem.constructor_.description)
        mbt_ffi_store32(
          iter_base + 32,
          iter_elem.constructor_.description.length(),
        )
        mbt_ffi_store32(iter_base + 28, ptr4)

        match iter_elem.constructor_.prompt_hint {
          None => {
            mbt_ffi_store8(iter_base + 36, 0)

            ()
          }
          Some(payload6) => {
            mbt_ffi_store8(iter_base + 36, 1)

            let ptr7 = mbt_ffi_str2ptr(payload6)
            mbt_ffi_store32(iter_base + 44, payload6.length())
            mbt_ffi_store32(iter_base + 40, ptr7)

            ()
          }
        }

        match iter_elem.constructor_.input_schema {
          Tuple(payload8) => {
            mbt_ffi_store8(iter_base + 48, 0)

            let address71 = mbt_ffi_malloc(payload8.length() * 24)
            for index72 = 0; index72 < payload8.length(); index72 = index72 + 1 {
              let iter_elem : (String, @common.ElementSchema) = payload8[index72]
              let iter_base = address71 + index72 * 24

