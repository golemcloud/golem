///|
pub fn wasmExportGetDefinition() -> Int {
  let result : @common.AgentType = @guest.get_definition()

  let ptr = mbt_ffi_str2ptr(result.type_name)
  mbt_ffi_store32(return_area + 4, result.type_name.length())
  mbt_ffi_store32(return_area + 0, ptr)

  let ptr0 = mbt_ffi_str2ptr(result.description)
  mbt_ffi_store32(return_area + 12, result.description.length())
  mbt_ffi_store32(return_area + 8, ptr0)

  match result.constructor_.name {
    None => {
      mbt_ffi_store8(return_area + 16, 0)

      ()
    }
    Some(payload1) => {
      mbt_ffi_store8(return_area + 16, 1)

      let ptr2 = mbt_ffi_str2ptr(payload1)
      mbt_ffi_store32(return_area + 24, payload1.length())
      mbt_ffi_store32(return_area + 20, ptr2)

      ()
    }
  }

  let ptr3 = mbt_ffi_str2ptr(result.constructor_.description)
  mbt_ffi_store32(return_area + 32, result.constructor_.description.length())
  mbt_ffi_store32(return_area + 28, ptr3)

  match result.constructor_.prompt_hint {
    None => {
      mbt_ffi_store8(return_area + 36, 0)

      ()
    }
    Some(payload5) => {
      mbt_ffi_store8(return_area + 36, 1)

      let ptr6 = mbt_ffi_str2ptr(payload5)
      mbt_ffi_store32(return_area + 44, payload5.length())
      mbt_ffi_store32(return_area + 40, ptr6)

      ()
    }
  }

  match result.constructor_.input_schema {
    Tuple(payload7) => {
      mbt_ffi_store8(return_area + 48, 0)

      let address70 = mbt_ffi_malloc(payload7.length() * 24)
