        let iter_elem : (String, @common.ElementSchema) = payload7[index71]
        let iter_base = address70 + index71 * 24

        let ptr8 = mbt_ffi_str2ptr(iter_elem.0)
        mbt_ffi_store32(iter_base + 4, iter_elem.0.length())
        mbt_ffi_store32(iter_base + 0, ptr8)

        match iter_elem.1 {
          ComponentModel(payload9) => {
            mbt_ffi_store8(iter_base + 8, 0)

            let address56 = mbt_ffi_malloc(payload9.nodes.length() * 48)
            for index57 = 0
                index57 < payload9.nodes.length()
                index57 = index57 + 1 {
              let iter_elem : @types.NamedWitTypeNode = payload9.nodes[index57]
              let iter_base = address56 + index57 * 48

              match iter_elem.name {
                None => {
                  mbt_ffi_store8(iter_base + 0, 0)

                  ()
                }
                Some(payload11) => {
                  mbt_ffi_store8(iter_base + 0, 1)

                  let ptr12 = mbt_ffi_str2ptr(payload11)
                  mbt_ffi_store32(iter_base + 8, payload11.length())
                  mbt_ffi_store32(iter_base + 4, ptr12)

