              match iter_elem.type_ {
                RecordType(payload16) => {
                  mbt_ffi_store8(iter_base + 24, 0)

                  let address = mbt_ffi_malloc(payload16.length() * 12)
                  for index = 0; index < payload16.length(); index = index + 1 {
                    let iter_elem : (String, Int) = payload16[index]
                    let iter_base = address + index * 12

                    let ptr17 = mbt_ffi_str2ptr(iter_elem.0)
                    mbt_ffi_store32(iter_base + 4, iter_elem.0.length())
