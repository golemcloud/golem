{
  "name": "golem-skill-harness",
  "version": "0.1.0",
  "description": "Skill testing harness for Golem coding agents",
  "type": "module",
  "main": "dist/src/run.js",
  "scripts": {
    "start": "tsx src/run.ts",
    "migrate:effect": "tsx src/migrate-effect-skills.ts",
    "build": "npm run lint && tsc",
    "test": "node --test dist/tests/*.test.js",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lint:fix": "eslint --fix \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "dependencies": {
    "@ampcode/sdk": "^0.1.0-20260717152646-g22b5e58",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.3.0",
    "ctrf": "^0.2.0",
    "jsonpath-plus": "^10.4.0",
    "tsx": "^4.7.0",
    "yaml": "^2.3.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.10.6",
    "eslint": "^9.0.0",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.0.0"
  }
}
