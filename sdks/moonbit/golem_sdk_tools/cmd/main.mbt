///|
fn main {
  let args = @env.args()
  if args.length() < 2 {
    println(
      "Usage: golem_sdk_tools <command> <args>\nCommands:\n  reexports <sdk-path> <target-dir>\n  agents <project-root>",
    )
    return
  }
  if args[1] == "reexports" {
    if args.length() < 4 {
      println("Usage: golem_sdk_tools reexports <sdk-path> <target-dir>")
      return
    }
    run_reexports(args[2], args[3]) catch {
      e => println("Error: \{e}")
    }
  } else if args[1] == "agents" {
    if args.length() < 3 {
      println("Usage: golem_sdk_tools agents <project-root>")
      return
    }
    run_agents(args[2]) catch {
      e => println("Error: \{e}")
    }
  } else {
    println("Unknown command: \{args[1]}")
  }
}

///|
/// Runs the `agents` subcommand: scans all packages in a project and generates
/// `golem_agents.mbt`, `golem_derive.mbt`, and `golem_clients.mbt` where needed.
fn run_agents(project_root : String) -> Unit raise {
  let scans = @lib.discover_and_scan(project_root)
  // Collect all config types across all packages for cross-package validation
  let all_config_types : Array[@lib.ConfigTypeInfo] = []
  for scan in scans {
    let config_types = @lib.parse_config_types(
      scan.files,
      package=scan.pkg.rel_path,
    )
    for ct in config_types {
      all_config_types.push(ct)
    }
  }
  for scan in scans {
    let pkg_dir = scan.pkg.dir
    let files = scan.files
    // Parse annotations from this package
    let value_types = @lib.parse_value_types(files)
    let multimodal_enums = @lib.parse_multimodal_enums(files)
    let config_types = @lib.parse_config_types(files, package=scan.pkg.rel_path)
    let agents = @lib.parse_agents(files)
    let has_derive = value_types.length() > 0 ||
      multimodal_enums.length() > 0 ||
      config_types.length() > 0
    let has_agents = agents.length() > 0
    if has_agents {
      // --- Agent package: generate golem_agents.mbt, golem_derive.mbt, golem_clients.mbt ---
      if agents[0].has_init {
        println(
          "Warning: existing fn init found in \{pkg_dir}. Remove it to avoid conflicts with generated code.",
        )
      }
      // Cross-package config validation
      @lib.validate_config_types(
        agents,
        all_config_types,
        agent_package=scan.pkg.rel_path,
      )
      // golem_agents.mbt
      let impls = @lib.generate_agent_registration(agents)
      let formatted = @formatter.impls_to_string(impls)
      let output = "// Generated by golem_sdk_tools — DO NOT EDIT!\n\n" +
        formatted
      let output_path = "\{pkg_dir}/golem_agents.mbt"
      @fs.write_string_to_file(output_path, output)
      println("Generated \{output_path} with \{agents.length()} agent(s)")
      // golem_derive.mbt
      if has_derive || all_config_types.length() > 0 {
        generate_derive_file(
          pkg_dir,
          value_types,
          multimodal_enums,
          config_types,
          all_config_types~,
        )
      } else {
        cleanup_stale_file("\{pkg_dir}/golem_derive.mbt")
      }
      // golem_clients.mbt
      let client_impls = @lib.generate_client_code(
        agents,
        config_types=all_config_types,
        agent_package=scan.pkg.rel_path,
      )
      let client_formatted = @formatter.impls_to_string(client_impls)
      let client_output = "// Generated by golem_sdk_tools — DO NOT EDIT!\n\n" +
        client_formatted
      let client_path = "\{pkg_dir}/golem_clients.mbt"
      @fs.write_string_to_file(client_path, client_output)
      println("Generated golem_clients.mbt with \{agents.length()} client(s)")
      // Auto-add RPC-related imports to moon.pkg
      let pkg_path = "\{pkg_dir}/moon.pkg"
      let mut pkg_content = @fs.read_file_to_string(pkg_path)
      pkg_content = @lib.ensure_pkg_import(
        pkg_content, "golemcloud/golem_sdk/rpc", "@rpc",
      )
      pkg_content = @lib.ensure_pkg_import(
        pkg_content, "golemcloud/golem_sdk/interface/golem/core/types", "@rpcTypes",
      )
      pkg_content = @lib.ensure_pkg_import(
        pkg_content, "golemcloud/golem_sdk/interface/wasi/clocks/wallClock", "@wallClock",
      )
      let uses_multimodal = has_multimodal_agent(agents)
      if uses_multimodal || multimodal_enums.length() > 0 {
        pkg_content = @lib.ensure_pkg_import(
          pkg_content, "golemcloud/golem_sdk/agents/types", "@types",
        )
        println("Ensured agents/types import in moon.pkg")
      }
      let uses_config = agents.iter().any(fn(a) { a.config_type is Some(_) })
      if uses_config || config_types.length() > 0 {
        pkg_content = @lib.ensure_pkg_import(
          pkg_content, "golemcloud/golem_sdk/config", "@config",
        )
        pkg_content = @lib.ensure_pkg_import(
          pkg_content, "golemcloud/golem_sdk/schema", "@schema",
        )
        println("Ensured config and schema imports in moon.pkg")
      }
      @fs.write_string_to_file(pkg_path, pkg_content)
    } else if has_derive {
      // --- Non-agent package with derive types: generate golem_derive.mbt only ---
      generate_derive_file(pkg_dir, value_types, multimodal_enums, config_types)
      // Ensure needed imports in moon.pkg
      let pkg_path = "\{pkg_dir}/moon.pkg"
      let mut pkg_content = @fs.read_file_to_string(pkg_path)
      pkg_content = @lib.ensure_pkg_import(
        pkg_content, "golemcloud/golem_sdk/schema", "@schema",
      )
      pkg_content = @lib.ensure_pkg_import(
        pkg_content, "golemcloud/golem_sdk/extractor", "@extractor",
      )
      pkg_content = @lib.ensure_pkg_import(
        pkg_content, "golemcloud/golem_sdk/interface/golem/agent/common", "@common",
      )
      if multimodal_enums.length() > 0 {
        pkg_content = @lib.ensure_pkg_import(
          pkg_content, "golemcloud/golem_sdk/agents/types", "@types",
        )
      }
      if config_types.length() > 0 {
        pkg_content = @lib.ensure_pkg_import(
          pkg_content, "golemcloud/golem_sdk/config", "@config",
        )
      }
      @fs.write_string_to_file(pkg_path, pkg_content)
    }
    // Clean up stale files for categories not present in this package
    if not(has_agents) {
      cleanup_stale_file("\{pkg_dir}/golem_agents.mbt")
      cleanup_stale_file("\{pkg_dir}/golem_clients.mbt")
    }
    if not(has_derive) && not(has_agents) {
      cleanup_stale_file("\{pkg_dir}/golem_derive.mbt")
    }
  }
}

///|
/// Generates `golem_derive.mbt` from value types, multimodal enums, and config types.
/// When `all_config_types` is provided, also generates override types and walker
/// functions for config types reachable from agents in this package.
fn generate_derive_file(
  pkg_dir : String,
  value_types : Array[@lib.ValueTypeInfo],
  multimodal_enums : Array[@lib.MultimodalEnumInfo],
  config_types : Array[@lib.ConfigTypeInfo],
  all_config_types? : Array[@lib.ConfigTypeInfo] = [],
) -> Unit raise {
  let all_impls : Array[@syntax.Impl] = []
  if value_types.length() > 0 {
    @lib.generate_value_type_impls(value_types).each(fn(i) { all_impls.push(i) })
  }
  if multimodal_enums.length() > 0 {
    @lib.generate_multimodal_impls(multimodal_enums).each(fn(i) {
      all_impls.push(i)
    })
  }
  if config_types.length() > 0 {
    @lib.generate_config_field_impls(config_types).each(fn(i) {
      all_impls.push(i)
    })
  }
  if all_config_types.length() > 0 {
    @lib.generate_config_override_types(all_config_types).each(fn(i) {
      all_impls.push(i)
    })
    @lib.generate_config_override_walkers(all_config_types).each(fn(i) {
      all_impls.push(i)
    })
  }
  let derive_formatted = @formatter.impls_to_string(
    @list.List::from_array(all_impls),
  )
  let derive_output = "// Generated by golem_sdk_tools — DO NOT EDIT!\n\n" +
    derive_formatted
  let derive_path = "\{pkg_dir}/golem_derive.mbt"
  @fs.write_string_to_file(derive_path, derive_output)
  println(
    "Generated \{derive_path} with \{value_types.length()} type(s), \{multimodal_enums.length()} multimodal enum(s), and \{config_types.length()} config type(s)",
  )
}

///|
/// Removes a generated file if it exists.
fn cleanup_stale_file(path : String) -> Unit {
  if @fs.path_exists(path) {
    @fs.remove_file(path) catch {
      e => {
        println("Warning: could not remove stale file \{path}: \{e}")
        return
      }
    }
    println("Removed stale \{path}")
  }
}

///|
/// Checks if any agent uses multimodal types in its constructor or methods.
fn has_multimodal_agent(agents : Array[@lib.AgentInfo]) -> Bool {
  for a in agents {
    for p in a.constructor_params {
      if @lib.is_multimodal_type(p.1) {
        return true
      }
    }
    for m in a.methods {
      for p in m.params {
        if @lib.is_multimodal_type(p.1) {
          return true
        }
      }
      match m.return_type {
        Some(pt) => if @lib.is_multimodal_type(pt) { return true }
        None => ()
      }
    }
  }
  false
}

///|
/// Runs the `reexports` subcommand: parses SDK gen sources and generates `golem_reexports.mbt` plus updates `moon.pkg`.
fn run_reexports(sdk_path : String, target_dir : String) -> Unit raise {
  let gen_dir = "\{sdk_path}/gen"
  let entries = @fs.read_dir(gen_dir)
  let fns : Array[@lib.FnSignature] = []
  for entry in entries {
    if entry.has_suffix(".mbt") {
      let content = @fs.read_file_to_string("\{gen_dir}/\{entry}")
      let file_fns = @lib.parse_mbt_source(content)
      for fn_ in file_fns {
        fns.push(fn_)
      }
    }
  }
  let impls = @lib.generate_reexports(fns, "gen")
  let formatted = @formatter.impls_to_string(impls)
  let output = "// Generated by golem_sdk_tools — DO NOT EDIT!\n\n" +
    formatted
  let output_path = "\{target_dir}/golem_reexports.mbt"
  @fs.write_string_to_file(output_path, output)
  println("Generated \{output_path} with \{fns.length()} functions")
  // Update target moon.pkg with link section from SDK's gen/moon.pkg
  let gen_pkg_content = @fs.read_file_to_string("\{gen_dir}/moon.pkg")
  let exports = @lib.transform_exports(@lib.parse_pkg_exports(gen_pkg_content))
  let target_pkg_path = "\{target_dir}/moon.pkg"
  let target_pkg_content = @fs.read_file_to_string(target_pkg_path)
  let updated = @lib.update_pkg_link(target_pkg_content, exports)
  @fs.write_string_to_file(target_pkg_path, updated)
  println("Updated \{target_pkg_path} with \{exports.length()} exports")
}
