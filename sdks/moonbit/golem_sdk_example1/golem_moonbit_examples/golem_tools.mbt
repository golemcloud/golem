      __golem_command_path[1:].to_array(),
      __golem_decoded,
      __golem_stdin,
      __golem_principal,
    )
  }
  match __golem_index {
    1 => {
      let verbose :UInt = try {
        @tool.decode_canonical_field(
          __golem_decoded,
          "verbose",
          "tool canonical-git command commit",
        )
      } catch{
        __golem_error => return Err(__golem_error)
