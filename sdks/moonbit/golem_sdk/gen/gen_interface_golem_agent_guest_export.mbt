                      index59 < payload11.nodes.length()
                      index59 = index59 + 1 {
                    let iter_elem : @types.NamedWitTypeNode = payload11.nodes[index59]
                    let iter_base = address58 + index59 * 48

                    match iter_elem.name {
                      None => {
                        mbt_ffi_store8(iter_base + 0, 0)

                        ()
                      }
                      Some(payload13) => {
                        mbt_ffi_store8(iter_base + 0, 1)

