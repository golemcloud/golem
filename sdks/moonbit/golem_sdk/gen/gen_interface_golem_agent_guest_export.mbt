///|
pub fn wasmExportGetDefinition() -> Int {
  let result : @common.AgentType = @guest.get_definition()

  let ptr = mbt_ffi_str2ptr(result.type_name)
  mbt_ffi_store32(return_area + 4, result.type_name.length())
  mbt_ffi_store32(return_area + 0, ptr)

  let ptr0 = mbt_ffi_str2ptr(result.description)
  mbt_ffi_store32(return_area + 12, result.description.length())
  mbt_ffi_store32(return_area + 8, ptr0)

  let ptr1 = mbt_ffi_str2ptr(result.source_language)
  mbt_ffi_store32(return_area + 20, result.source_language.length())
  mbt_ffi_store32(return_area + 16, ptr1)

  match result.constructor_.name {
    None => {
      mbt_ffi_store8(return_area + 24, 0)

      ()
    }
    Some(payload2) => {
      mbt_ffi_store8(return_area + 24, 1)

      let ptr3 = mbt_ffi_str2ptr(payload2)
      mbt_ffi_store32(return_area + 32, payload2.length())
      mbt_ffi_store32(return_area + 28, ptr3)

      ()
    }
  }

  let ptr4 = mbt_ffi_str2ptr(result.constructor_.description)
  mbt_ffi_store32(return_area + 40, result.constructor_.description.length())
  mbt_ffi_store32(return_area + 36, ptr4)

  match result.constructor_.prompt_hint {
    None => {
      mbt_ffi_store8(return_area + 44, 0)

      ()
    }
    Some(payload6) => {
      mbt_ffi_store8(return_area + 44, 1)

      let ptr7 = mbt_ffi_str2ptr(payload6)
      mbt_ffi_store32(return_area + 52, payload6.length())
      mbt_ffi_store32(return_area + 48, ptr7)

      ()
    }
  }

  match result.constructor_.input_schema {
    Tuple(payload8) => {
      mbt_ffi_store8(return_area + 56, 0)

      let address71 = mbt_ffi_malloc(payload8.length() * 24)
      for index72 = 0; index72 < payload8.length(); index72 = index72 + 1 {
        let iter_elem : (String, @types.ElementSchema) = payload8[index72]
