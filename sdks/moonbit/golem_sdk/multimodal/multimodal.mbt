// Schema-native multimodal support, replacing the deleted `agents/types`
// unstructured/multimodal carriers. A `Multimodal[T]` serializes to a
// `List(Variant(...))` whose list node carries `metadata.role = Multimodal`,
// and whose value is `List([Variant(case_idx, Some(payload))...])`. This
// mirrors the Rust SDK's `MultimodalAdvanced<T>` / `MultimodalSchema` and the
// TS SDK's `multimodalSchemaType`; there is no `DataValue`/`ElementValue` and
// no legacy `@types.Multimodal` carrier.
//
// `Multimodal[T]` is an ordinary `@schema.IntoSchema` / `@schema.FromSchema`
// type (exactly like `Array[T]`), so the agent codegen needs no multimodal
// special-casing — `decode_param` / `encode_output` / `into_schema_graph`
// handle it generically. `T` is a `#derive.multimodal` enum whose variants are
// the modalities; `golem_sdk_tools` generates the `MultimodalModality` impl.

///|
/// Multimodal input/output for agent methods: a list of modality items where
/// `T` is a `#derive.multimodal` enum whose variants are the modalities.
pub(all) struct Multimodal[T] {
  items : Array[T]
}

///|
/// Create a `Multimodal[T]` from a list of modality items.
pub fn[T] Multimodal::new(items : Array[T]) -> Multimodal[T] {
  { items, }
}

///|
/// The modality set of a `#derive.multimodal` enum, expressed against the
/// recursive schema model. Generated by `golem_sdk_tools` for each
/// `#derive.multimodal` enum. Mirrors the Rust `MultimodalSchema` trait, but
/// case-index based to match MoonBit's variant encoding.
pub(open) trait MultimodalModality {
  /// Stable schema type-id of the modality enum (used to derive the generic
  /// `Multimodal[T]` type-id).
  fn multimodal_type_id() -> @model.TypeId
  /// Register each modality's payload type into `builder` and return the
  /// variant cases, in declaration order.
  fn multimodal_cases(@model.SchemaBuilder) -> Array[@model.VariantCaseType]
  /// Encode an instance to its `(case index, payload value)`.
  fn to_modality_value(Self) -> (UInt, @model.SchemaValue)
  /// Decode a `(case index, payload value)` back to an instance.
  fn from_modality_value(UInt, @model.SchemaValue) -> Self raise @schema.FromSchemaError
}

///|
/// A metadata envelope tagging a node with `role = Multimodal`.
fn multimodal_role_metadata() -> @types.MetadataEnvelope {
  {
    doc: None,
    aliases: [],
    examples: [],
    deprecated: None,
    role: Some(@types.Role::Multimodal),
  }
}

///|
pub impl[T : MultimodalModality] @schema.IntoSchema for Multimodal[T] with fn type_id() {
  @schema.type_id_with_args("golem.multimodal.Multimodal", [
    T::multimodal_type_id(),
  ])
}

///|
pub impl[T : MultimodalModality] @schema.IntoSchema for Multimodal[T] with fn register_in(
  b,
) {
  let cases = T::multimodal_cases(b)
  let element = @model.schema_type(Variant(cases))
  @model.schema_type(List(element), metadata=multimodal_role_metadata())
}

///|
pub impl[T : MultimodalModality] @schema.IntoSchema for Multimodal[T] with fn to_value(
  self,
) {
  let elements : Array[@model.SchemaValue] = self.items.map(fn(item) {
    let (case, payload) = T::to_modality_value(item)
    @model.SchemaValue::Variant(case, Some(payload))
  })
  List(elements)
}

///|
pub impl[T : MultimodalModality] @schema.FromSchema for Multimodal[T] with fn from_value(
  v,
) {
  match v {
    List(items) => {
      let result : Array[T] = []
      for item in items {
        match item {
          Variant(case, Some(payload)) =>
            result.push(T::from_modality_value(case, payload))
          Variant(_, None) =>
            raise @schema.FromSchemaError::custom(
              "multimodal item is missing its payload",
            )
          other =>
            raise @schema.FromSchemaError::shape_mismatch(
              "multimodal variant",
              @schema.value_kind(other),
              "Multimodal",
            )
        }
      }
      { items: result }
    }
    other =>
      raise @schema.FromSchemaError::shape_mismatch(
        "list",
        @schema.value_kind(other),
        "Multimodal",
      )
  }
}
