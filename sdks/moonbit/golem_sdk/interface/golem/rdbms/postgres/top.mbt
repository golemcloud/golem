      Daterange(payload81) => {
        mbt_ffi_store8(iter_base + 0, 33)

        match payload81.start {
          Included(payload82) => {
            mbt_ffi_store8(iter_base + 8, 0)
            mbt_ffi_store32(iter_base + 12, payload82.year)
            mbt_ffi_store8(iter_base + 16, payload82.month.to_int())
