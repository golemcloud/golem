///|
pub fn LazyDbColumnType::lazy_db_column_type(
  value : DbColumnType,
) -> LazyDbColumnType {
  let cleanup_list : Array[Int] = []

  let (lowered, lowered50, lowered51, lowered52, lowered53) = match value {
    Character => (0, 0, 0, 0, 0)
    Int2 => (1, 0, 0, 0, 0)
    Int4 => (2, 0, 0, 0, 0)
    Int8 => (3, 0, 0, 0, 0)
    Float4 => (4, 0, 0, 0, 0)
    Float8 => (5, 0, 0, 0, 0)
    Numeric => (6, 0, 0, 0, 0)
    Boolean => (7, 0, 0, 0, 0)
    Text => (8, 0, 0, 0, 0)
    Varchar => (9, 0, 0, 0, 0)
    Bpchar => (10, 0, 0, 0, 0)
    Timestamp => (11, 0, 0, 0, 0)
    Timestamptz => (12, 0, 0, 0, 0)
    Date => (13, 0, 0, 0, 0)
    Time => (14, 0, 0, 0, 0)
    Timetz => (15, 0, 0, 0, 0)
    Interval => (16, 0, 0, 0, 0)
    Bytea => (17, 0, 0, 0, 0)
    Uuid => (18, 0, 0, 0, 0)
    Xml => (19, 0, 0, 0, 0)
    Json => (20, 0, 0, 0, 0)
    Jsonb => (21, 0, 0, 0, 0)
    Jsonpath => (22, 0, 0, 0, 0)
    Inet => (23, 0, 0, 0, 0)
    Cidr => (24, 0, 0, 0, 0)
    Macaddr => (25, 0, 0, 0, 0)
    Bit => (26, 0, 0, 0, 0)
    Varbit => (27, 0, 0, 0, 0)
    Int4range => (28, 0, 0, 0, 0)
    Int8range => (29, 0, 0, 0, 0)
    Numrange => (30, 0, 0, 0, 0)
    Tsrange => (31, 0, 0, 0, 0)
    Tstzrange => (32, 0, 0, 0, 0)
    Daterange => (33, 0, 0, 0, 0)
    Money => (34, 0, 0, 0, 0)
    Oid => (35, 0, 0, 0, 0)
    Enumeration(payload35) => {
      let ptr = mbt_ffi_str2ptr(payload35.name)
      cleanup_list.push(ptr)

      (36, ptr, payload35.name.length(), 0, 0)
    }
    Composite(payload36) => {
      let ptr37 = mbt_ffi_str2ptr(payload36.name)

      let address = mbt_ffi_malloc(payload36.attributes.length() * 12)
      for index = 0; index < payload36.attributes.length(); index = index + 1 {
        let iter_elem : (String, LazyDbColumnType) = payload36.attributes[index]
        let iter_base = address + index * 12

        let ptr38 = mbt_ffi_str2ptr(iter_elem.0)
        mbt_ffi_store32(iter_base + 4, iter_elem.0.length())
        mbt_ffi_store32(iter_base + 0, ptr38)

        let LazyDbColumnType(handle) = iter_elem.1
        mbt_ffi_store32(iter_base + 8, handle)
        cleanup_list.push(ptr38)
      }
      cleanup_list.push(ptr37)
      cleanup_list.push(address)

      (
        37,
        ptr37,
        payload36.name.length(),
        address,
        payload36.attributes.length(),
      )
    }
    Domain(payload39) => {
      let ptr40 = mbt_ffi_str2ptr(payload39.name)

      let LazyDbColumnType(handle41) = payload39.base_type
      cleanup_list.push(ptr40)

      (38, ptr40, payload39.name.length(), handle41, 0)
    }
    Array(payload42) => {
      let LazyDbColumnType(handle43) = payload42

      (39, handle43, 0, 0, 0)
    }
    Range(payload44) => {
      let ptr45 = mbt_ffi_str2ptr(payload44.name)

      let LazyDbColumnType(handle46) = payload44.base_type
      cleanup_list.push(ptr45)

      (40, ptr45, payload44.name.length(), handle46, 0)
    }
    Vector => (41, 0, 0, 0, 0)
    Halfvec => (42, 0, 0, 0, 0)
    Sparsevec => (43, 0, 0, 0, 0)
  }
  let result : Int = wasmImportConstructorLazyDbColumnType(
    lowered, lowered50, lowered51, lowered52, lowered53,
  )
  let ret = LazyDbColumnType::LazyDbColumnType(result)
  cleanup_list.each(mbt_ffi_free)
  return ret
}

