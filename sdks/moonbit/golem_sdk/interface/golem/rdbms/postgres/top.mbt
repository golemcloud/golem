        match payload74.start {
          Included(payload75) => {
            mbt_ffi_store8(iter_base + 8, 0)
            mbt_ffi_store32(iter_base + 12, payload75.timestamp.date.year)
            mbt_ffi_store8(
              iter_base + 16,
              payload75.timestamp.date.month.to_int(),
            )
            mbt_ffi_store8(
              iter_base + 17,
              payload75.timestamp.date.day.to_int(),
            )
            mbt_ffi_store8(
              iter_base + 20,
              payload75.timestamp.time.hour.to_int(),
            )
            mbt_ffi_store8(
              iter_base + 21,
              payload75.timestamp.time.minute.to_int(),
            )
            mbt_ffi_store8(
              iter_base + 22,
              payload75.timestamp.time.second.to_int(),
            )
            mbt_ffi_store32(
              iter_base + 24,
              payload75.timestamp.time.nanosecond.reinterpret_as_int(),
            )
            mbt_ffi_store32(iter_base + 28, payload75.offset)

            ()
          }
          Excluded(payload76) => {
            mbt_ffi_store8(iter_base + 8, 1)
            mbt_ffi_store32(iter_base + 12, payload76.timestamp.date.year)
            mbt_ffi_store8(
              iter_base + 16,
              payload76.timestamp.date.month.to_int(),
            )
            mbt_ffi_store8(
              iter_base + 17,
              payload76.timestamp.date.day.to_int(),
            )
            mbt_ffi_store8(
              iter_base + 20,
              payload76.timestamp.time.hour.to_int(),
            )
            mbt_ffi_store8(
              iter_base + 21,
              payload76.timestamp.time.minute.to_int(),
            )
            mbt_ffi_store8(
              iter_base + 22,
              payload76.timestamp.time.second.to_int(),
            )
            mbt_ffi_store32(
              iter_base + 24,
              payload76.timestamp.time.nanosecond.reinterpret_as_int(),
            )
            mbt_ffi_store32(iter_base + 28, payload76.offset)

            ()
          }
          Unbounded => {
            mbt_ffi_store8(iter_base + 8, 2)

            ()
          }
        }

        match payload74.end {
          Included(payload78) => {
            mbt_ffi_store8(iter_base + 32, 0)
            mbt_ffi_store32(iter_base + 36, payload78.timestamp.date.year)
            mbt_ffi_store8(
              iter_base + 40,
              payload78.timestamp.date.month.to_int(),
            )
            mbt_ffi_store8(
              iter_base + 41,
              payload78.timestamp.date.day.to_int(),
            )
            mbt_ffi_store8(
              iter_base + 44,
              payload78.timestamp.time.hour.to_int(),
            )
            mbt_ffi_store8(
              iter_base + 45,
              payload78.timestamp.time.minute.to_int(),
