          Excluded(payload72) => {
            mbt_ffi_store8(iter_base + 28, 1)
            mbt_ffi_store32(iter_base + 32, payload72.date.year)
            mbt_ffi_store8(iter_base + 36, payload72.date.month.to_int())
            mbt_ffi_store8(iter_base + 37, payload72.date.day.to_int())
            mbt_ffi_store8(iter_base + 40, payload72.time.hour.to_int())
            mbt_ffi_store8(iter_base + 41, payload72.time.minute.to_int())
