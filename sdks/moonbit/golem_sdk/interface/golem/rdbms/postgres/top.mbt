            mbt_ffi_store8(iter_base + 28, payload85.month.to_int())
            mbt_ffi_store8(iter_base + 29, payload85.day.to_int())

            ()
          }
          Excluded(payload86) => {
            mbt_ffi_store8(iter_base + 20, 1)
            mbt_ffi_store32(iter_base + 24, payload86.year)
            mbt_ffi_store8(iter_base + 28, payload86.month.to_int())
            mbt_ffi_store8(iter_base + 29, payload86.day.to_int())

            ()
          }
          Unbounded => {
            mbt_ffi_store8(iter_base + 20, 2)

            ()
          }
        }

        ()
      }
      Money(payload88) => {
        mbt_ffi_store8(iter_base + 0, 34)
        mbt_ffi_store64(iter_base + 8, payload88)

        ()
      }
      Oid(payload89) => {
        mbt_ffi_store8(iter_base + 0, 35)
        mbt_ffi_store32(iter_base + 8, payload89.reinterpret_as_int())

        ()
      }
      Enumeration(payload90) => {
        mbt_ffi_store8(iter_base + 0, 36)

        let ptr91 = mbt_ffi_str2ptr(payload90.name)
        mbt_ffi_store32(iter_base + 12, payload90.name.length())
        mbt_ffi_store32(iter_base + 8, ptr91)

        let ptr92 = mbt_ffi_str2ptr(payload90.value)
        mbt_ffi_store32(iter_base + 20, payload90.value.length())
        mbt_ffi_store32(iter_base + 16, ptr92)
        cleanup_list.push(ptr91)
        cleanup_list.push(ptr92)

        ()
      }
      Composite(payload93) => {
        mbt_ffi_store8(iter_base + 0, 37)

        let ptr94 = mbt_ffi_str2ptr(payload93.name)
        mbt_ffi_store32(iter_base + 12, payload93.name.length())
        mbt_ffi_store32(iter_base + 8, ptr94)

        let address96 = mbt_ffi_malloc(payload93.values.length() * 4)
        for index97 = 0
            index97 < payload93.values.length()
            index97 = index97 + 1 {
          let iter_elem : LazyDbValue = payload93.values[index97]
          let iter_base = address96 + index97 * 4

          let LazyDbValue(handle95) = iter_elem
          mbt_ffi_store32(iter_base + 0, handle95)
        }
        mbt_ffi_store32(iter_base + 20, payload93.values.length())
        mbt_ffi_store32(iter_base + 16, address96)
        cleanup_list.push(ptr94)
        cleanup_list.push(address96)

        ()
      }
      Domain(payload98) => {
        mbt_ffi_store8(iter_base + 0, 38)

        let ptr99 = mbt_ffi_str2ptr(payload98.name)
        mbt_ffi_store32(iter_base + 12, payload98.name.length())
        mbt_ffi_store32(iter_base + 8, ptr99)

        let LazyDbValue(handle100) = payload98.value
        mbt_ffi_store32(iter_base + 16, handle100)
        cleanup_list.push(ptr99)

        ()
      }
      Array(payload101) => {
        mbt_ffi_store8(iter_base + 0, 39)

        let address103 = mbt_ffi_malloc(payload101.length() * 4)
        for index104 = 0
            index104 < payload101.length()
            index104 = index104 + 1 {
          let iter_elem : LazyDbValue = payload101[index104]
          let iter_base = address103 + index104 * 4

          let LazyDbValue(handle102) = iter_elem
          mbt_ffi_store32(iter_base + 0, handle102)
        }
        mbt_ffi_store32(iter_base + 12, payload101.length())
        mbt_ffi_store32(iter_base + 8, address103)
        cleanup_list.push(address103)

        ()
      }
      Range(payload105) => {
        mbt_ffi_store8(iter_base + 0, 40)

        let ptr106 = mbt_ffi_str2ptr(payload105.name)
        mbt_ffi_store32(iter_base + 12, payload105.name.length())
        mbt_ffi_store32(iter_base + 8, ptr106)

        match payload105.value.start {
          Included(payload107) => {
            mbt_ffi_store8(iter_base + 16, 0)

            let LazyDbValue(handle108) = payload107
            mbt_ffi_store32(iter_base + 20, handle108)

            ()
          }
          Excluded(payload109) => {
            mbt_ffi_store8(iter_base + 16, 1)

            let LazyDbValue(handle110) = payload109
            mbt_ffi_store32(iter_base + 20, handle110)

            ()
          }
          Unbounded => {
            mbt_ffi_store8(iter_base + 16, 2)

            ()
          }
        }

        match payload105.value.end {
          Included(payload112) => {
            mbt_ffi_store8(iter_base + 24, 0)

            let LazyDbValue(handle113) = payload112
            mbt_ffi_store32(iter_base + 28, handle113)

            ()
          }
          Excluded(payload114) => {
            mbt_ffi_store8(iter_base + 24, 1)

            let LazyDbValue(handle115) = payload114
            mbt_ffi_store32(iter_base + 28, handle115)

            ()
          }
          Unbounded => {
            mbt_ffi_store8(iter_base + 24, 2)

            ()
          }
        }
        cleanup_list.push(ptr106)

        ()
      }
      Null => {
        mbt_ffi_store8(iter_base + 0, 41)

        ()
      }
      Vector(payload118) => {
        mbt_ffi_store8(iter_base + 0, 42)

        let ptr119 = mbt_ffi_float_array2ptr(payload118)

        mbt_ffi_store32(iter_base + 12, payload118.length())
        mbt_ffi_store32(iter_base + 8, ptr119)
        cleanup_list.push(ptr119)

        ()
      }
      Halfvec(payload120) => {
        mbt_ffi_store8(iter_base + 0, 43)

        let ptr121 = mbt_ffi_float_array2ptr(payload120)

        mbt_ffi_store32(iter_base + 12, payload120.length())
        mbt_ffi_store32(iter_base + 8, ptr121)
        cleanup_list.push(ptr121)

        ()
      }
      Sparsevec(payload122) => {
        mbt_ffi_store8(iter_base + 0, 44)
        mbt_ffi_store32(iter_base + 8, payload122.dim)

        let ptr123 = mbt_ffi_int_array2ptr(payload122.indices)

        mbt_ffi_store32(iter_base + 16, payload122.indices.length())
        mbt_ffi_store32(iter_base + 12, ptr123)

        let ptr124 = mbt_ffi_float_array2ptr(payload122.values)

        mbt_ffi_store32(iter_base + 24, payload122.values.length())
        mbt_ffi_store32(iter_base + 20, ptr124)
        cleanup_list.push(ptr123)
        cleanup_list.push(ptr124)

        ()
      }
    }
  }
  let return_area = mbt_ffi_malloc(16)
  wasmImportMethodDbTransactionQueryStream(
    handle,
    ptr,
    statement.length(),
    address125,
    params.length(),
    return_area,
  )

  let lifted131 = match mbt_ffi_load8_u(return_area + 0) {
    0 =>
      Result::Ok(
        DbResultStream::DbResultStream(mbt_ffi_load32(return_area + 4)),
      )
    1 => {
      let lifted = match mbt_ffi_load8_u(return_area + 4) {
        0 => {
          let result = mbt_ffi_ptr2str(
            mbt_ffi_load32(return_area + 8),
            mbt_ffi_load32(return_area + 12),
          )

          Error_::ConnectionFailure(result)
        }
        1 => {
          let result127 = mbt_ffi_ptr2str(
            mbt_ffi_load32(return_area + 8),
            mbt_ffi_load32(return_area + 12),
          )

          Error_::QueryParameterFailure(result127)
        }
        2 => {
          let result128 = mbt_ffi_ptr2str(
            mbt_ffi_load32(return_area + 8),
            mbt_ffi_load32(return_area + 12),
          )

          Error_::QueryExecutionFailure(result128)
        }
        3 => {
          let result129 = mbt_ffi_ptr2str(
            mbt_ffi_load32(return_area + 8),
            mbt_ffi_load32(return_area + 12),
          )

          Error_::QueryResponseFailure(result129)
        }
        4 => {
          let result130 = mbt_ffi_ptr2str(
            mbt_ffi_load32(return_area + 8),
            mbt_ffi_load32(return_area + 12),
          )

          Error_::Other(result130)
        }
        _ => panic()
      }

      Result::Err(lifted)
    }
    _ => panic()
  }
  let ret = lifted131
  mbt_ffi_free(ptr)
  mbt_ffi_free(address125)
  mbt_ffi_free(return_area)
  cleanup_list.each(mbt_ffi_free)
  return ret
}

///|
pub fn DbTransaction::execute(
  self : DbTransaction,
  statement : String,
  params : Array[DbValue],
) -> Result[UInt64, Error_] {
  let cleanup_list : Array[Int] = []

  let DbTransaction(handle) = self

  let ptr = mbt_ffi_str2ptr(statement)

  let address125 = mbt_ffi_malloc(params.length() * 56)
  for index126 = 0; index126 < params.length(); index126 = index126 + 1 {
    let iter_elem : DbValue = params[index126]
    let iter_base = address125 + index126 * 56

    match iter_elem {
      Character(payload) => {
        mbt_ffi_store8(iter_base + 0, 0)
        mbt_ffi_store8(iter_base + 8, mbt_ffi_extend8(payload))

        ()
      }
      Int2(payload0) => {
        mbt_ffi_store8(iter_base + 0, 1)
        mbt_ffi_store16(iter_base + 8, mbt_ffi_extend16(payload0))

        ()
      }
      Int4(payload1) => {
        mbt_ffi_store8(iter_base + 0, 2)
        mbt_ffi_store32(iter_base + 8, payload1)

        ()
      }
      Int8(payload2) => {
        mbt_ffi_store8(iter_base + 0, 3)
        mbt_ffi_store64(iter_base + 8, payload2)

        ()
      }
      Float4(payload3) => {
        mbt_ffi_store8(iter_base + 0, 4)
        mbt_ffi_storef32(iter_base + 8, payload3)

        ()
      }
      Float8(payload4) => {
        mbt_ffi_store8(iter_base + 0, 5)
        mbt_ffi_storef64(iter_base + 8, payload4)

        ()
      }
      Numeric(payload5) => {
        mbt_ffi_store8(iter_base + 0, 6)

        let ptr6 = mbt_ffi_str2ptr(payload5)
        mbt_ffi_store32(iter_base + 12, payload5.length())
        mbt_ffi_store32(iter_base + 8, ptr6)
        cleanup_list.push(ptr6)

        ()
      }
      Boolean(payload7) => {
        mbt_ffi_store8(iter_base + 0, 7)
        mbt_ffi_store8(iter_base + 8, if payload7 { 1 } else { 0 })

        ()
      }
      Text(payload8) => {
        mbt_ffi_store8(iter_base + 0, 8)

        let ptr9 = mbt_ffi_str2ptr(payload8)
        mbt_ffi_store32(iter_base + 12, payload8.length())
        mbt_ffi_store32(iter_base + 8, ptr9)
        cleanup_list.push(ptr9)

        ()
      }
      Varchar(payload10) => {
        mbt_ffi_store8(iter_base + 0, 9)

        let ptr11 = mbt_ffi_str2ptr(payload10)
        mbt_ffi_store32(iter_base + 12, payload10.length())
        mbt_ffi_store32(iter_base + 8, ptr11)
        cleanup_list.push(ptr11)

        ()
      }
      Bpchar(payload12) => {
        mbt_ffi_store8(iter_base + 0, 10)

        let ptr13 = mbt_ffi_str2ptr(payload12)
        mbt_ffi_store32(iter_base + 12, payload12.length())
        mbt_ffi_store32(iter_base + 8, ptr13)
        cleanup_list.push(ptr13)

        ()
      }
      Timestamp(payload14) => {
        mbt_ffi_store8(iter_base + 0, 11)
        mbt_ffi_store32(iter_base + 8, payload14.date.year)
        mbt_ffi_store8(iter_base + 12, payload14.date.month.to_int())
        mbt_ffi_store8(iter_base + 13, payload14.date.day.to_int())
        mbt_ffi_store8(iter_base + 16, payload14.time.hour.to_int())
        mbt_ffi_store8(iter_base + 17, payload14.time.minute.to_int())
        mbt_ffi_store8(iter_base + 18, payload14.time.second.to_int())
        mbt_ffi_store32(
          iter_base + 20,
          payload14.time.nanosecond.reinterpret_as_int(),
        )

        ()
      }
      Timestamptz(payload15) => {
        mbt_ffi_store8(iter_base + 0, 12)
        mbt_ffi_store32(iter_base + 8, payload15.timestamp.date.year)
        mbt_ffi_store8(iter_base + 12, payload15.timestamp.date.month.to_int())
        mbt_ffi_store8(iter_base + 13, payload15.timestamp.date.day.to_int())
        mbt_ffi_store8(iter_base + 16, payload15.timestamp.time.hour.to_int())
        mbt_ffi_store8(iter_base + 17, payload15.timestamp.time.minute.to_int())
        mbt_ffi_store8(iter_base + 18, payload15.timestamp.time.second.to_int())
        mbt_ffi_store32(
          iter_base + 20,
          payload15.timestamp.time.nanosecond.reinterpret_as_int(),
        )
        mbt_ffi_store32(iter_base + 24, payload15.offset)

        ()
      }
      Date(payload16) => {
        mbt_ffi_store8(iter_base + 0, 13)
        mbt_ffi_store32(iter_base + 8, payload16.year)
        mbt_ffi_store8(iter_base + 12, payload16.month.to_int())
        mbt_ffi_store8(iter_base + 13, payload16.day.to_int())

        ()
      }
      Time(payload17) => {
        mbt_ffi_store8(iter_base + 0, 14)
        mbt_ffi_store8(iter_base + 8, payload17.hour.to_int())
        mbt_ffi_store8(iter_base + 9, payload17.minute.to_int())
        mbt_ffi_store8(iter_base + 10, payload17.second.to_int())
        mbt_ffi_store32(
          iter_base + 12,
          payload17.nanosecond.reinterpret_as_int(),
        )

        ()
      }
      Timetz(payload18) => {
        mbt_ffi_store8(iter_base + 0, 15)
        mbt_ffi_store8(iter_base + 8, payload18.time.hour.to_int())
        mbt_ffi_store8(iter_base + 9, payload18.time.minute.to_int())
        mbt_ffi_store8(iter_base + 10, payload18.time.second.to_int())
        mbt_ffi_store32(
          iter_base + 12,
          payload18.time.nanosecond.reinterpret_as_int(),
        )
        mbt_ffi_store32(iter_base + 16, payload18.offset)

        ()
      }
      Interval(payload19) => {
        mbt_ffi_store8(iter_base + 0, 16)
        mbt_ffi_store32(iter_base + 8, payload19.months)
        mbt_ffi_store32(iter_base + 12, payload19.days)
        mbt_ffi_store64(iter_base + 16, payload19.microseconds)

        ()
      }
      Bytea(payload20) => {
        mbt_ffi_store8(iter_base + 0, 17)

        let ptr21 = mbt_ffi_bytes2ptr(payload20)

        mbt_ffi_store32(iter_base + 12, payload20.length())
        mbt_ffi_store32(iter_base + 8, ptr21)
        cleanup_list.push(ptr21)

        ()
      }
      Json(payload22) => {
        mbt_ffi_store8(iter_base + 0, 18)

        let ptr23 = mbt_ffi_str2ptr(payload22)
        mbt_ffi_store32(iter_base + 12, payload22.length())
        mbt_ffi_store32(iter_base + 8, ptr23)
        cleanup_list.push(ptr23)

        ()
      }
      Jsonb(payload24) => {
        mbt_ffi_store8(iter_base + 0, 19)

        let ptr25 = mbt_ffi_str2ptr(payload24)
        mbt_ffi_store32(iter_base + 12, payload24.length())
        mbt_ffi_store32(iter_base + 8, ptr25)
        cleanup_list.push(ptr25)

        ()
      }
      Jsonpath(payload26) => {
        mbt_ffi_store8(iter_base + 0, 20)

        let ptr27 = mbt_ffi_str2ptr(payload26)
        mbt_ffi_store32(iter_base + 12, payload26.length())
        mbt_ffi_store32(iter_base + 8, ptr27)
        cleanup_list.push(ptr27)

        ()
      }
      Xml(payload28) => {
        mbt_ffi_store8(iter_base + 0, 21)

        let ptr29 = mbt_ffi_str2ptr(payload28)
        mbt_ffi_store32(iter_base + 12, payload28.length())
        mbt_ffi_store32(iter_base + 8, ptr29)
        cleanup_list.push(ptr29)

        ()
      }
      Uuid(payload30) => {
        mbt_ffi_store8(iter_base + 0, 22)
        mbt_ffi_store64(
          iter_base + 8,
          payload30.high_bits.reinterpret_as_int64(),
        )
        mbt_ffi_store64(
          iter_base + 16,
          payload30.low_bits.reinterpret_as_int64(),
        )

        ()
      }
      Inet(payload31) => {
        mbt_ffi_store8(iter_base + 0, 23)

        match payload31 {
          Ipv4(payload32) => {
            mbt_ffi_store8(iter_base + 8, 0)
            mbt_ffi_store8(iter_base + 10, payload32.0.to_int())
            mbt_ffi_store8(iter_base + 11, payload32.1.to_int())
            mbt_ffi_store8(iter_base + 12, payload32.2.to_int())
            mbt_ffi_store8(iter_base + 13, payload32.3.to_int())

            ()
          }
          Ipv6(payload33) => {
            mbt_ffi_store8(iter_base + 8, 1)
            mbt_ffi_store16(iter_base + 10, payload33.0.reinterpret_as_int())
            mbt_ffi_store16(iter_base + 12, payload33.1.reinterpret_as_int())
            mbt_ffi_store16(iter_base + 14, payload33.2.reinterpret_as_int())
            mbt_ffi_store16(iter_base + 16, payload33.3.reinterpret_as_int())
            mbt_ffi_store16(iter_base + 18, payload33.4.reinterpret_as_int())
            mbt_ffi_store16(iter_base + 20, payload33.5.reinterpret_as_int())
            mbt_ffi_store16(iter_base + 22, payload33.6.reinterpret_as_int())
            mbt_ffi_store16(iter_base + 24, payload33.7.reinterpret_as_int())

            ()
          }
        }

        ()
      }
      Cidr(payload34) => {
        mbt_ffi_store8(iter_base + 0, 24)

        match payload34 {
          Ipv4(payload35) => {
            mbt_ffi_store8(iter_base + 8, 0)
            mbt_ffi_store8(iter_base + 10, payload35.0.to_int())
            mbt_ffi_store8(iter_base + 11, payload35.1.to_int())
            mbt_ffi_store8(iter_base + 12, payload35.2.to_int())
            mbt_ffi_store8(iter_base + 13, payload35.3.to_int())

            ()
          }
          Ipv6(payload36) => {
            mbt_ffi_store8(iter_base + 8, 1)
            mbt_ffi_store16(iter_base + 10, payload36.0.reinterpret_as_int())
            mbt_ffi_store16(iter_base + 12, payload36.1.reinterpret_as_int())
            mbt_ffi_store16(iter_base + 14, payload36.2.reinterpret_as_int())
            mbt_ffi_store16(iter_base + 16, payload36.3.reinterpret_as_int())
            mbt_ffi_store16(iter_base + 18, payload36.4.reinterpret_as_int())
            mbt_ffi_store16(iter_base + 20, payload36.5.reinterpret_as_int())
            mbt_ffi_store16(iter_base + 22, payload36.6.reinterpret_as_int())
            mbt_ffi_store16(iter_base + 24, payload36.7.reinterpret_as_int())

            ()
          }
        }

        ()
      }
      Macaddr(payload37) => {
        mbt_ffi_store8(iter_base + 0, 25)
        mbt_ffi_store8(iter_base + 8, payload37.octets.0.to_int())
        mbt_ffi_store8(iter_base + 9, payload37.octets.1.to_int())
        mbt_ffi_store8(iter_base + 10, payload37.octets.2.to_int())
        mbt_ffi_store8(iter_base + 11, payload37.octets.3.to_int())
        mbt_ffi_store8(iter_base + 12, payload37.octets.4.to_int())
        mbt_ffi_store8(iter_base + 13, payload37.octets.5.to_int())

        ()
      }
      Bit(payload38) => {
        mbt_ffi_store8(iter_base + 0, 26)

        let address = mbt_ffi_malloc(payload38.length() * 1)
        for index = 0; index < payload38.length(); index = index + 1 {
          let iter_elem : Bool = payload38[index]
          let iter_base = address + index * 1
          mbt_ffi_store8(iter_base + 0, if iter_elem { 1 } else { 0 })
        }
        mbt_ffi_store32(iter_base + 12, payload38.length())
        mbt_ffi_store32(iter_base + 8, address)
        cleanup_list.push(address)

        ()
      }
      Varbit(payload39) => {
        mbt_ffi_store8(iter_base + 0, 27)

        let address40 = mbt_ffi_malloc(payload39.length() * 1)
        for index41 = 0; index41 < payload39.length(); index41 = index41 + 1 {
          let iter_elem : Bool = payload39[index41]
          let iter_base = address40 + index41 * 1
          mbt_ffi_store8(iter_base + 0, if iter_elem { 1 } else { 0 })
        }
        mbt_ffi_store32(iter_base + 12, payload39.length())
        mbt_ffi_store32(iter_base + 8, address40)
        cleanup_list.push(address40)

        ()
      }
      Int4range(payload42) => {
        mbt_ffi_store8(iter_base + 0, 28)

        match payload42.start {
          Included(payload43) => {
            mbt_ffi_store8(iter_base + 8, 0)
            mbt_ffi_store32(iter_base + 12, payload43)

            ()
          }
          Excluded(payload44) => {
            mbt_ffi_store8(iter_base + 8, 1)
            mbt_ffi_store32(iter_base + 12, payload44)

            ()
          }
          Unbounded => {
            mbt_ffi_store8(iter_base + 8, 2)

            ()
          }
        }

        match payload42.end {
          Included(payload46) => {
            mbt_ffi_store8(iter_base + 16, 0)
            mbt_ffi_store32(iter_base + 20, payload46)

            ()
          }
          Excluded(payload47) => {
            mbt_ffi_store8(iter_base + 16, 1)
            mbt_ffi_store32(iter_base + 20, payload47)

            ()
          }
          Unbounded => {
            mbt_ffi_store8(iter_base + 16, 2)

            ()
          }
        }

        ()
      }
      Int8range(payload49) => {
        mbt_ffi_store8(iter_base + 0, 29)

        match payload49.start {
          Included(payload50) => {
            mbt_ffi_store8(iter_base + 8, 0)
            mbt_ffi_store64(iter_base + 16, payload50)

            ()
          }
          Excluded(payload51) => {
            mbt_ffi_store8(iter_base + 8, 1)
            mbt_ffi_store64(iter_base + 16, payload51)

            ()
          }
          Unbounded => {
            mbt_ffi_store8(iter_base + 8, 2)

            ()
          }
        }

        match payload49.end {
          Included(payload53) => {
            mbt_ffi_store8(iter_base + 24, 0)
            mbt_ffi_store64(iter_base + 32, payload53)

            ()
          }
          Excluded(payload54) => {
            mbt_ffi_store8(iter_base + 24, 1)
            mbt_ffi_store64(iter_base + 32, payload54)

            ()
          }
