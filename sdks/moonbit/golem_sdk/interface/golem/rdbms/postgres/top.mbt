///|
pub fn DbConnection::open(address : String) -> Result[DbConnection, Error_] {
  let ptr = mbt_ffi_str2ptr(address)
  let return_area = mbt_ffi_malloc(16)
  wasmImportStaticDbConnectionOpen(ptr, address.length(), return_area)

  let lifted4 = match mbt_ffi_load8_u(return_area + 0) {
    0 => Result::Ok(DbConnection::DbConnection(mbt_ffi_load32(return_area + 4)))
    1 => {
      let lifted = match mbt_ffi_load8_u(return_area + 4) {
        0 => {
          let result = mbt_ffi_ptr2str(
            mbt_ffi_load32(return_area + 8),
            mbt_ffi_load32(return_area + 12),
          )

          Error_::ConnectionFailure(result)
        }
        1 => {
          let result0 = mbt_ffi_ptr2str(
            mbt_ffi_load32(return_area + 8),
            mbt_ffi_load32(return_area + 12),
          )

          Error_::QueryParameterFailure(result0)
        }
        2 => {
          let result1 = mbt_ffi_ptr2str(
            mbt_ffi_load32(return_area + 8),
            mbt_ffi_load32(return_area + 12),
          )

          Error_::QueryExecutionFailure(result1)
        }
        3 => {
          let result2 = mbt_ffi_ptr2str(
            mbt_ffi_load32(return_area + 8),
            mbt_ffi_load32(return_area + 12),
          )

          Error_::QueryResponseFailure(result2)
        }
