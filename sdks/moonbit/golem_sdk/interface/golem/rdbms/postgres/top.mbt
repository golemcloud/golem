          }
          Excluded(payload79) => {
            mbt_ffi_store8(iter_base + 32, 1)
            mbt_ffi_store32(iter_base + 36, payload79.timestamp.date.year)
            mbt_ffi_store8(
              iter_base + 40,
              payload79.timestamp.date.month.to_int(),
            )
            mbt_ffi_store8(
              iter_base + 41,
              payload79.timestamp.date.day.to_int(),
            )
            mbt_ffi_store8(
              iter_base + 44,
              payload79.timestamp.time.hour.to_int(),
            )
            mbt_ffi_store8(
              iter_base + 45,
              payload79.timestamp.time.minute.to_int(),
