///|
/// Parses a UUID from a string
pub fn parse_uuid(uuid : String) -> Result[Uuid, String] {

      let ptr = mbt_ffi_str2ptr(uuid)
      let return_area = mbt_ffi_malloc(24)
      wasmImportParseUuid(ptr, uuid.length(), return_area);

      let lifted = match (mbt_ffi_load8_u((return_area) + 0)) {
            0 => {

                  Result::Ok(Uuid::{high_bits : (mbt_ffi_load64((return_area) + 8)).reinterpret_as_uint64(), low_bits : (mbt_ffi_load64((return_area) + 16)).reinterpret_as_uint64()})
            }
            1 => {

                  let result = mbt_ffi_ptr2str(mbt_ffi_load32((return_area) + 8), mbt_ffi_load32((return_area) + 12))

                  Result::Err(result)
            }
            _ => panic()
      }
      let ret = lifted
      mbt_ffi_free(ptr)
      mbt_ffi_free(return_area)
      return ret

}
///|
/// Converts a UUID to a string
pub fn uuid_to_string(uuid : Uuid) -> String {

      let return_area = mbt_ffi_malloc(8)
      wasmImportUuidToString(((uuid).high_bits).reinterpret_as_int64(), ((uuid).low_bits).reinterpret_as_int64(), return_area);

      let result = mbt_ffi_ptr2str(mbt_ffi_load32((return_area) + 0), mbt_ffi_load32((return_area) + 4))
      let ret = result
      mbt_ffi_free(return_area)
      return ret

}

