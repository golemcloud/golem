///|
pub fn FutureInvokeResult::subscribe(
  self : FutureInvokeResult,
) -> @poll.Pollable {
  let FutureInvokeResult(handle) = self
  let result : Int = wasmImportMethodFutureInvokeResultSubscribe(handle)
  let ret = @poll.Pollable::Pollable(result)
  return ret
}

