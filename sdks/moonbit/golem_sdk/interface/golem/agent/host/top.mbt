          ()
        }
        PrimS32Type => {
          mbt_ffi_store8(iter_base + 24, 14)

          ()
        }
        PrimS64Type => {
          mbt_ffi_store8(iter_base + 24, 15)

          ()
        }
        PrimF32Type => {
          mbt_ffi_store8(iter_base + 24, 16)

          ()
        }
        PrimF64Type => {
          mbt_ffi_store8(iter_base + 24, 17)

          ()
        }
