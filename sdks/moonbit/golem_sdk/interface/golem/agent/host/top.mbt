///|
/// Schedule invocation for later
pub fn WasmRpc::schedule_invocation(self : WasmRpc, scheduled_time : @wallClock.Datetime, method_name : String, input : @types.SchemaValueTree) -> Unit {
      let cleanup_list : Array[Int] = []

