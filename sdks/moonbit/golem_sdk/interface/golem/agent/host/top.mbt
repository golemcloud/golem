              for index146 = 0
                  index146 < mbt_ffi_load32(return_area + 16)
                  index146 = index146 + 1 {
                let iter_base = mbt_ffi_load32(return_area + 12) + index146 * 24

                let lifted144 = match mbt_ffi_load8_u(iter_base + 0) {
                  0 => {
                    let array : Array[Int] = []
                    for index131 = 0
                        index131 < mbt_ffi_load32(iter_base + 12)
                        index131 = index131 + 1 {
                      let iter_base = mbt_ffi_load32(iter_base + 8) +
                        index131 * 4

                      array.push(mbt_ffi_load32(iter_base + 0))
                    }
                    mbt_ffi_free(mbt_ffi_load32(iter_base + 8))

                    @types.WitNode::RecordValue(array)
                  }
                  1 => {
                    let lifted : Int? = match mbt_ffi_load8_u(iter_base + 12) {
                      0 => Option::None
                      1 => Option::Some(mbt_ffi_load32(iter_base + 16))
                      _ => panic()
                    }

                    @types.WitNode::VariantValue(
                      (
                        mbt_ffi_load32(iter_base + 8).reinterpret_as_uint(),
                        lifted,
                      ),
                    )
                  }
                  2 =>
                    @types.WitNode::EnumValue(
                      mbt_ffi_load32(iter_base + 8).reinterpret_as_uint(),
                    )
                  3 => {
                    let array132 : Array[Bool] = []
                    for index133 = 0
                        index133 < mbt_ffi_load32(iter_base + 12)
                        index133 = index133 + 1 {
                      let iter_base = mbt_ffi_load32(iter_base + 8) +
                        index133 * 1

                      array132.push(mbt_ffi_load8_u(iter_base + 0) != 0)
                    }
                    mbt_ffi_free(mbt_ffi_load32(iter_base + 8))

                    @types.WitNode::FlagsValue(array132)
                  }
                  4 => {
                    let array134 : Array[Int] = []
                    for index135 = 0
                        index135 < mbt_ffi_load32(iter_base + 12)
                        index135 = index135 + 1 {
                      let iter_base = mbt_ffi_load32(iter_base + 8) +
                        index135 * 4

                      array134.push(mbt_ffi_load32(iter_base + 0))
                    }
                    mbt_ffi_free(mbt_ffi_load32(iter_base + 8))

                    @types.WitNode::TupleValue(array134)
                  }
                  5 => {
                    let array136 : Array[Int] = []
                    for index137 = 0
                        index137 < mbt_ffi_load32(iter_base + 12)
                        index137 = index137 + 1 {
                      let iter_base = mbt_ffi_load32(iter_base + 8) +
                        index137 * 4

                      array136.push(mbt_ffi_load32(iter_base + 0))
                    }
                    mbt_ffi_free(mbt_ffi_load32(iter_base + 8))

                    @types.WitNode::ListValue(array136)
                  }
                  6 => {
                    let lifted138 : Int? = match
                      mbt_ffi_load8_u(iter_base + 8) {
                      0 => Option::None
                      1 => Option::Some(mbt_ffi_load32(iter_base + 12))
                      _ => panic()
                    }

                    @types.WitNode::OptionValue(lifted138)
                  }
                  7 => {
                    let lifted141 = match mbt_ffi_load8_u(iter_base + 8) {
                      0 => {
                        let lifted139 : Int? = match
                          mbt_ffi_load8_u(iter_base + 12) {
                          0 => Option::None
                          1 => Option::Some(mbt_ffi_load32(iter_base + 16))
                          _ => panic()
                        }

                        Result::Ok(lifted139)
                      }
                      1 => {
                        let lifted140 : Int? = match
                          mbt_ffi_load8_u(iter_base + 12) {
                          0 => Option::None
                          1 => Option::Some(mbt_ffi_load32(iter_base + 16))
                          _ => panic()
                        }

                        Result::Err(lifted140)
                      }
                      _ => panic()
                    }

                    @types.WitNode::ResultValue(lifted141)
                  }
                  8 =>
                    @types.WitNode::PrimU8(
                      mbt_ffi_load8_u(iter_base + 8).to_byte(),
                    )
                  9 =>
                    @types.WitNode::PrimU16(
                      mbt_ffi_load16_u(iter_base + 8)
                      .land(0xFFFF)
                      .reinterpret_as_uint(),
                    )
                  10 =>
                    @types.WitNode::PrimU32(
                      mbt_ffi_load32(iter_base + 8).reinterpret_as_uint(),
                    )
                  11 =>
                    @types.WitNode::PrimU64(
                      mbt_ffi_load64(iter_base + 8).reinterpret_as_uint64(),
                    )
                  12 =>
                    @types.WitNode::PrimS8(mbt_ffi_load8(iter_base + 8) - 0x100)
                  13 =>
                    @types.WitNode::PrimS16(
                      mbt_ffi_load16(iter_base + 8) - 0x10000,
                    )
                  14 => @types.WitNode::PrimS32(mbt_ffi_load32(iter_base + 8))
                  15 => @types.WitNode::PrimS64(mbt_ffi_load64(iter_base + 8))
                  16 =>
                    @types.WitNode::PrimFloat32(mbt_ffi_loadf32(iter_base + 8))
                  17 =>
                    @types.WitNode::PrimFloat64(mbt_ffi_loadf64(iter_base + 8))
                  18 =>
                    @types.WitNode::PrimChar(
                      Int::unsafe_to_char(mbt_ffi_load32(iter_base + 8)),
                    )
                  19 =>
                    @types.WitNode::PrimBool(
                      mbt_ffi_load8_u(iter_base + 8) != 0,
                    )
                  20 => {
                    let result142 = mbt_ffi_ptr2str(
                      mbt_ffi_load32(iter_base + 8),
                      mbt_ffi_load32(iter_base + 12),
                    )

                    @types.WitNode::PrimString(result142)
                  }
                  21 => {
                    let result143 = mbt_ffi_ptr2str(
                      mbt_ffi_load32(iter_base + 8),
                      mbt_ffi_load32(iter_base + 12),
                    )

                    @types.WitNode::Handle(
                      (
                        @types.Uri::{ value: result143 },
                        mbt_ffi_load64(iter_base + 16).reinterpret_as_uint64(),
                      ),
                    )
                  }
                  _ => panic()
                }

                array145.push(lifted144)
              }
              mbt_ffi_free(mbt_ffi_load32(return_area + 12))

              let array169 : Array[@types.NamedWitTypeNode] = []
              for index170 = 0
                  index170 < mbt_ffi_load32(return_area + 24)
                  index170 = index170 + 1 {
                let iter_base = mbt_ffi_load32(return_area + 20) + index170 * 48

                let lifted148 : String? = match mbt_ffi_load8_u(iter_base + 0) {
                  0 => Option::None
                  1 => {
                    let result147 = mbt_ffi_ptr2str(
                      mbt_ffi_load32(iter_base + 4),
                      mbt_ffi_load32(iter_base + 8),
                    )

                    Option::Some(result147)
                  }
                  _ => panic()
                }

                let lifted150 : String? = match
                  mbt_ffi_load8_u(iter_base + 12) {
                  0 => Option::None
                  1 => {
                    let result149 = mbt_ffi_ptr2str(
                      mbt_ffi_load32(iter_base + 16),
                      mbt_ffi_load32(iter_base + 20),
                    )

                    Option::Some(result149)
                  }
                  _ => panic()
                }

                let lifted168 = match mbt_ffi_load8_u(iter_base + 24) {
                  0 => {
                    let array152 : Array[(String, Int)] = []
                    for index153 = 0
                        index153 < mbt_ffi_load32(iter_base + 36)
                        index153 = index153 + 1 {
                      let iter_base = mbt_ffi_load32(iter_base + 32) +
                        index153 * 12

                      let result151 = mbt_ffi_ptr2str(
                        mbt_ffi_load32(iter_base + 0),
                        mbt_ffi_load32(iter_base + 4),
                      )

                      array152.push((result151, mbt_ffi_load32(iter_base + 8)))
                    }
                    mbt_ffi_free(mbt_ffi_load32(iter_base + 32))

                    @types.WitTypeNode::RecordType(array152)
                  }
                  1 => {
                    let array156 : Array[(String, Int?)] = []
                    for index157 = 0
                        index157 < mbt_ffi_load32(iter_base + 36)
                        index157 = index157 + 1 {
                      let iter_base = mbt_ffi_load32(iter_base + 32) +
                        index157 * 16

                      let result154 = mbt_ffi_ptr2str(
                        mbt_ffi_load32(iter_base + 0),
                        mbt_ffi_load32(iter_base + 4),
                      )

                      let lifted155 : Int? = match
                        mbt_ffi_load8_u(iter_base + 8) {
                        0 => Option::None
                        1 => Option::Some(mbt_ffi_load32(iter_base + 12))
                        _ => panic()
                      }

                      array156.push((result154, lifted155))
                    }
                    mbt_ffi_free(mbt_ffi_load32(iter_base + 32))

                    @types.WitTypeNode::VariantType(array156)
                  }
                  2 => {
                    let array159 : Array[String] = []
                    for index160 = 0
                        index160 < mbt_ffi_load32(iter_base + 36)
                        index160 = index160 + 1 {
                      let iter_base = mbt_ffi_load32(iter_base + 32) +
                        index160 * 8

                      let result158 = mbt_ffi_ptr2str(
                        mbt_ffi_load32(iter_base + 0),
                        mbt_ffi_load32(iter_base + 4),
                      )

                      array159.push(result158)
                    }
                    mbt_ffi_free(mbt_ffi_load32(iter_base + 32))

                    @types.WitTypeNode::EnumType(array159)
                  }
                  3 => {
                    let array162 : Array[String] = []
                    for index163 = 0
                        index163 < mbt_ffi_load32(iter_base + 36)
                        index163 = index163 + 1 {
                      let iter_base = mbt_ffi_load32(iter_base + 32) +
                        index163 * 8

                      let result161 = mbt_ffi_ptr2str(
                        mbt_ffi_load32(iter_base + 0),
                        mbt_ffi_load32(iter_base + 4),
                      )

                      array162.push(result161)
                    }
                    mbt_ffi_free(mbt_ffi_load32(iter_base + 32))

                    @types.WitTypeNode::FlagsType(array162)
                  }
                  4 => {
                    let array164 : Array[Int] = []
                    for index165 = 0
                        index165 < mbt_ffi_load32(iter_base + 36)
                        index165 = index165 + 1 {
                      let iter_base = mbt_ffi_load32(iter_base + 32) +
                        index165 * 4

                      array164.push(mbt_ffi_load32(iter_base + 0))
                    }
                    mbt_ffi_free(mbt_ffi_load32(iter_base + 32))

                    @types.WitTypeNode::TupleType(array164)
                  }
                  5 =>
                    @types.WitTypeNode::ListType(mbt_ffi_load32(iter_base + 32))
                  6 =>
                    @types.WitTypeNode::OptionType(
                      mbt_ffi_load32(iter_base + 32),
                    )
                  7 => {
                    let lifted166 : Int? = match
                      mbt_ffi_load8_u(iter_base + 32) {
                      0 => Option::None
                      1 => Option::Some(mbt_ffi_load32(iter_base + 36))
                      _ => panic()
                    }

                    let lifted167 : Int? = match
                      mbt_ffi_load8_u(iter_base + 40) {
                      0 => Option::None
                      1 => Option::Some(mbt_ffi_load32(iter_base + 44))
                      _ => panic()
                    }

                    @types.WitTypeNode::ResultType((lifted166, lifted167))
                  }
                  8 => @types.WitTypeNode::PrimU8Type
                  9 => @types.WitTypeNode::PrimU16Type
                  10 => @types.WitTypeNode::PrimU32Type
                  11 => @types.WitTypeNode::PrimU64Type
                  12 => @types.WitTypeNode::PrimS8Type
                  13 => @types.WitTypeNode::PrimS16Type
                  14 => @types.WitTypeNode::PrimS32Type
                  15 => @types.WitTypeNode::PrimS64Type
                  16 => @types.WitTypeNode::PrimF32Type
                  17 => @types.WitTypeNode::PrimF64Type
                  18 => @types.WitTypeNode::PrimCharType
                  19 => @types.WitTypeNode::PrimBoolType
                  20 => @types.WitTypeNode::PrimStringType
                  21 =>
                    @types.WitTypeNode::HandleType(
                      (
                        mbt_ffi_load64(iter_base + 32).reinterpret_as_uint64(),
                        @types.ResourceMode::from(
                          mbt_ffi_load8_u(iter_base + 40),
                        ),
                      ),
                    )
                  _ => panic()
                }

                array169.push(@types.NamedWitTypeNode::{
                  name: lifted148,
                  owner: lifted150,
                  type_: lifted168,
                })
              }
              mbt_ffi_free(mbt_ffi_load32(return_area + 20))

              @common.AgentError::CustomError(@types.ValueAndType::{
                value: @types.WitValue::{ nodes: array145 },
                typ: @types.WitType::{ nodes: array169 },
              })
            }
            _ => panic()
          }

          RpcError::RemoteAgentError(lifted171)
        }
        _ => panic()
      }

      Result::Err(lifted172)
    }
    _ => panic()
  }
  let ret = lifted173
  mbt_ffi_free(ptr)
  mbt_ffi_free(return_area)

  cleanup_list.each(mbt_ffi_free)
  return ret
}

///|
/// Invokes a remote method with the given parameters, and returns a `future-invoke-result` value which can
/// be polled for the result.
///
/// With this function it is possible to call multiple (different) agents simultaneously.
pub fn WasmRpc::async_invoke_and_await(
  self : WasmRpc,
  method_name : String,
  input : @types.DataValue,
) -> FutureInvokeResult {
  let cleanup_list : Array[Int] = []

  let WasmRpc(handle) = self

  let ptr = mbt_ffi_str2ptr(method_name)

  let (lowered, lowered122, lowered123) = match input {
    Tuple(payload) => {
      let address57 = mbt_ffi_malloc(payload.length() * 28)
      for index58 = 0; index58 < payload.length(); index58 = index58 + 1 {
        let iter_elem : @types.ElementValue = payload[index58]
        let iter_base = address57 + index58 * 28

        match iter_elem {
          ComponentModel(payload0) => {
            mbt_ffi_store8(iter_base + 0, 0)

            let address41 = mbt_ffi_malloc(payload0.nodes.length() * 24)
            for index42 = 0
                index42 < payload0.nodes.length()
                index42 = index42 + 1 {
              let iter_elem : @types.WitNode = payload0.nodes[index42]
              let iter_base = address41 + index42 * 24

              match iter_elem {
                RecordValue(payload1) => {
                  mbt_ffi_store8(iter_base + 0, 0)

                  let address = mbt_ffi_malloc(payload1.length() * 4)
                  for index = 0; index < payload1.length(); index = index + 1 {
                    let iter_elem : Int = payload1[index]
                    let iter_base = address + index * 4
                    mbt_ffi_store32(iter_base + 0, iter_elem)
                  }
                  mbt_ffi_store32(iter_base + 12, payload1.length())
                  mbt_ffi_store32(iter_base + 8, address)
                  cleanup_list.push(address)

                  ()
                }
                VariantValue(payload2) => {
                  mbt_ffi_store8(iter_base + 0, 1)
                  mbt_ffi_store32(
                    iter_base + 8,
                    payload2.0.reinterpret_as_int(),
                  )

                  match payload2.1 {
                    None => {
                      mbt_ffi_store8(iter_base + 12, 0)

                      ()
                    }
                    Some(payload4) => {
                      mbt_ffi_store8(iter_base + 12, 1)
                      mbt_ffi_store32(iter_base + 16, payload4)

                      ()
                    }
                  }

                  ()
                }
                EnumValue(payload5) => {
                  mbt_ffi_store8(iter_base + 0, 2)
                  mbt_ffi_store32(iter_base + 8, payload5.reinterpret_as_int())

                  ()
                }
                FlagsValue(payload6) => {
                  mbt_ffi_store8(iter_base + 0, 3)

                  let address7 = mbt_ffi_malloc(payload6.length() * 1)
                  for index8 = 0
                      index8 < payload6.length()
                      index8 = index8 + 1 {
                    let iter_elem : Bool = payload6[index8]
                    let iter_base = address7 + index8 * 1
                    mbt_ffi_store8(iter_base + 0, if iter_elem { 1 } else { 0 })
                  }
                  mbt_ffi_store32(iter_base + 12, payload6.length())
                  mbt_ffi_store32(iter_base + 8, address7)
                  cleanup_list.push(address7)

                  ()
                }
                TupleValue(payload9) => {
                  mbt_ffi_store8(iter_base + 0, 4)

                  let address10 = mbt_ffi_malloc(payload9.length() * 4)
                  for index11 = 0
                      index11 < payload9.length()
                      index11 = index11 + 1 {
                    let iter_elem : Int = payload9[index11]
                    let iter_base = address10 + index11 * 4
                    mbt_ffi_store32(iter_base + 0, iter_elem)
                  }
                  mbt_ffi_store32(iter_base + 12, payload9.length())
                  mbt_ffi_store32(iter_base + 8, address10)
                  cleanup_list.push(address10)

                  ()
                }
                ListValue(payload12) => {
                  mbt_ffi_store8(iter_base + 0, 5)

                  let address13 = mbt_ffi_malloc(payload12.length() * 4)
                  for index14 = 0
                      index14 < payload12.length()
                      index14 = index14 + 1 {
                    let iter_elem : Int = payload12[index14]
                    let iter_base = address13 + index14 * 4
                    mbt_ffi_store32(iter_base + 0, iter_elem)
                  }
                  mbt_ffi_store32(iter_base + 12, payload12.length())
                  mbt_ffi_store32(iter_base + 8, address13)
                  cleanup_list.push(address13)

                  ()
                }
                OptionValue(payload15) => {
                  mbt_ffi_store8(iter_base + 0, 6)

                  match payload15 {
                    None => {
                      mbt_ffi_store8(iter_base + 8, 0)

                      ()
                    }
                    Some(payload17) => {
                      mbt_ffi_store8(iter_base + 8, 1)
                      mbt_ffi_store32(iter_base + 12, payload17)

                      ()
                    }
                  }

                  ()
                }
                ResultValue(payload18) => {
                  mbt_ffi_store8(iter_base + 0, 7)

                  match payload18 {
                    Ok(payload19) => {
                      mbt_ffi_store8(iter_base + 8, 0)

                      match payload19 {
                        None => {
                          mbt_ffi_store8(iter_base + 12, 0)

                          ()
                        }
                        Some(payload21) => {
                          mbt_ffi_store8(iter_base + 12, 1)
                          mbt_ffi_store32(iter_base + 16, payload21)

                          ()
                        }
                      }

                      ()
                    }
                    Err(payload22) => {
                      mbt_ffi_store8(iter_base + 8, 1)

                      match payload22 {
                        None => {
                          mbt_ffi_store8(iter_base + 12, 0)

                          ()
                        }
                        Some(payload24) => {
                          mbt_ffi_store8(iter_base + 12, 1)
                          mbt_ffi_store32(iter_base + 16, payload24)

                          ()
                        }
                      }

                      ()
                    }
                  }

                  ()
                }
                PrimU8(payload25) => {
                  mbt_ffi_store8(iter_base + 0, 8)
                  mbt_ffi_store8(iter_base + 8, payload25.to_int())

                  ()
                }
                PrimU16(payload26) => {
                  mbt_ffi_store8(iter_base + 0, 9)
                  mbt_ffi_store16(iter_base + 8, payload26.reinterpret_as_int())

                  ()
                }
                PrimU32(payload27) => {
                  mbt_ffi_store8(iter_base + 0, 10)
                  mbt_ffi_store32(iter_base + 8, payload27.reinterpret_as_int())

                  ()
                }
                PrimU64(payload28) => {
                  mbt_ffi_store8(iter_base + 0, 11)
                  mbt_ffi_store64(
                    iter_base + 8,
                    payload28.reinterpret_as_int64(),
                  )

                  ()
                }
                PrimS8(payload29) => {
                  mbt_ffi_store8(iter_base + 0, 12)
                  mbt_ffi_store8(iter_base + 8, mbt_ffi_extend8(payload29))

                  ()
                }
                PrimS16(payload30) => {
                  mbt_ffi_store8(iter_base + 0, 13)
                  mbt_ffi_store16(iter_base + 8, mbt_ffi_extend16(payload30))

                  ()
                }
                PrimS32(payload31) => {
                  mbt_ffi_store8(iter_base + 0, 14)
                  mbt_ffi_store32(iter_base + 8, payload31)

                  ()
                }
                PrimS64(payload32) => {
                  mbt_ffi_store8(iter_base + 0, 15)
                  mbt_ffi_store64(iter_base + 8, payload32)

                  ()
                }
                PrimFloat32(payload33) => {
                  mbt_ffi_store8(iter_base + 0, 16)
                  mbt_ffi_storef32(iter_base + 8, payload33)

                  ()
                }
                PrimFloat64(payload34) => {
                  mbt_ffi_store8(iter_base + 0, 17)
                  mbt_ffi_storef64(iter_base + 8, payload34)

                  ()
                }
                PrimChar(payload35) => {
                  mbt_ffi_store8(iter_base + 0, 18)
                  mbt_ffi_store32(iter_base + 8, payload35.to_int())

                  ()
                }
                PrimBool(payload36) => {
                  mbt_ffi_store8(iter_base + 0, 19)
                  mbt_ffi_store8(iter_base + 8, if payload36 { 1 } else { 0 })

                  ()
                }
                PrimString(payload37) => {
                  mbt_ffi_store8(iter_base + 0, 20)

                  let ptr38 = mbt_ffi_str2ptr(payload37)
                  mbt_ffi_store32(iter_base + 12, payload37.length())
                  mbt_ffi_store32(iter_base + 8, ptr38)
                  cleanup_list.push(ptr38)

                  ()
                }
                Handle(payload39) => {
                  mbt_ffi_store8(iter_base + 0, 21)

                  let ptr40 = mbt_ffi_str2ptr(payload39.0.value)
                  mbt_ffi_store32(iter_base + 12, payload39.0.value.length())
                  mbt_ffi_store32(iter_base + 8, ptr40)
                  mbt_ffi_store64(
                    iter_base + 16,
                    payload39.1.reinterpret_as_int64(),
                  )
                  cleanup_list.push(ptr40)

                  ()
                }
              }
            }
            mbt_ffi_store32(iter_base + 8, payload0.nodes.length())
            mbt_ffi_store32(iter_base + 4, address41)
            cleanup_list.push(address41)

            ()
          }
          UnstructuredText(payload43) => {
            mbt_ffi_store8(iter_base + 0, 1)

            match payload43 {
              Url(payload44) => {
                mbt_ffi_store8(iter_base + 4, 0)

                let ptr45 = mbt_ffi_str2ptr(payload44)
                mbt_ffi_store32(iter_base + 12, payload44.length())
                mbt_ffi_store32(iter_base + 8, ptr45)
                cleanup_list.push(ptr45)

                ()
              }
              Inline(payload46) => {
                mbt_ffi_store8(iter_base + 4, 1)

                let ptr47 = mbt_ffi_str2ptr(payload46.data)
                mbt_ffi_store32(iter_base + 12, payload46.data.length())
                mbt_ffi_store32(iter_base + 8, ptr47)

                match payload46.text_type {
                  None => {
                    mbt_ffi_store8(iter_base + 16, 0)

                    ()
                  }
                  Some(payload49) => {
                    mbt_ffi_store8(iter_base + 16, 1)

                    let ptr50 = mbt_ffi_str2ptr(payload49.language_code)
                    mbt_ffi_store32(
                      iter_base + 24,
                      payload49.language_code.length(),
                    )
                    mbt_ffi_store32(iter_base + 20, ptr50)
                    cleanup_list.push(ptr50)

                    ()
                  }
                }
                cleanup_list.push(ptr47)

                ()
              }
            }

            ()
          }
          UnstructuredBinary(payload51) => {
            mbt_ffi_store8(iter_base + 0, 2)

            match payload51 {
              Url(payload52) => {
                mbt_ffi_store8(iter_base + 4, 0)

                let ptr53 = mbt_ffi_str2ptr(payload52)
                mbt_ffi_store32(iter_base + 12, payload52.length())
                mbt_ffi_store32(iter_base + 8, ptr53)
                cleanup_list.push(ptr53)

                ()
              }
              Inline(payload54) => {
                mbt_ffi_store8(iter_base + 4, 1)

