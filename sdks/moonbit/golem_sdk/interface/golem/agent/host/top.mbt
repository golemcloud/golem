            }
            Some(payload37) => {
              mbt_ffi_store8(iter_base + 8, 1)
              mbt_ffi_store32(iter_base + 12, payload37)

              ()
            }
          }

          match iter_elem.metadata.doc {
            None => {
              mbt_ffi_store8(iter_base + 16, 0)

