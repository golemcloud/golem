/// Best-effort attempt to cancel the remote invocation by idempotency key.
/// If the invocation has already started or completed, this is a no-op.
pub fn FutureInvokeResult::cancel(self : FutureInvokeResult) -> Unit {
  let FutureInvokeResult(handle) = self
  wasmImportMethodFutureInvokeResultCancel(handle)
}

///|
/// Cancel the scheduled invocation
pub fn CancellationToken::cancel(self : CancellationToken) -> Unit {
  let CancellationToken(handle) = self
  wasmImportMethodCancellationTokenCancel(handle)
}

///|
/// Get the current value of the config key.
///
/// The expected type is a hint to the host what type of value is expected by the guest and can be used
/// by the host to automatically migrate config values to fit the expected schema.
///
/// Only keys that are declared by the agent-type are allowed to be accessed. Trying
/// to access an undeclared key will trap, unless the expected type is an option. In that case
/// none is returned.
///
/// Getting a local key will get values defined as part of the current
/// component revision + overrides declared during agent creation.
///
/// Getting a shared key will get the current value of the key in the environment.
pub fn get_config_value(
  key : Array[String],
  expected_type : @types.WitType,
) -> @types.WitValue {
  let cleanup_list : Array[Int] = []

  let address = mbt_ffi_malloc(key.length() * 8)
  for index = 0; index < key.length(); index = index + 1 {
    let iter_elem : String = key[index]
    let iter_base = address + index * 8

    let ptr = mbt_ffi_str2ptr(iter_elem)
    mbt_ffi_store32(iter_base + 4, iter_elem.length())
    mbt_ffi_store32(iter_base + 0, ptr)
    cleanup_list.push(ptr)
  }

  let address47 = mbt_ffi_malloc(expected_type.nodes.length() * 48)
  for index48 = 0; index48 < expected_type.nodes.length(); index48 = index48 + 1 {
    let iter_elem : @types.NamedWitTypeNode = expected_type.nodes[index48]
    let iter_base = address47 + index48 * 48

    match iter_elem.name {
      None => {
        mbt_ffi_store8(iter_base + 0, 0)

        ()
      }
      Some(payload0) => {
        mbt_ffi_store8(iter_base + 0, 1)

        let ptr1 = mbt_ffi_str2ptr(payload0)
        mbt_ffi_store32(iter_base + 8, payload0.length())
        mbt_ffi_store32(iter_base + 4, ptr1)
        cleanup_list.push(ptr1)

        ()
      }
    }

    match iter_elem.owner {
      None => {
        mbt_ffi_store8(iter_base + 12, 0)

        ()
      }
      Some(payload3) => {
        mbt_ffi_store8(iter_base + 12, 1)

        let ptr4 = mbt_ffi_str2ptr(payload3)
        mbt_ffi_store32(iter_base + 20, payload3.length())
        mbt_ffi_store32(iter_base + 16, ptr4)
        cleanup_list.push(ptr4)

        ()
      }
    }

    match iter_elem.type_ {
      RecordType(payload5) => {
        mbt_ffi_store8(iter_base + 24, 0)

        let address7 = mbt_ffi_malloc(payload5.length() * 12)
        for index8 = 0; index8 < payload5.length(); index8 = index8 + 1 {
          let iter_elem : (String, Int) = payload5[index8]
          let iter_base = address7 + index8 * 12

          let ptr6 = mbt_ffi_str2ptr(iter_elem.0)
          mbt_ffi_store32(iter_base + 4, iter_elem.0.length())
          mbt_ffi_store32(iter_base + 0, ptr6)
          mbt_ffi_store32(iter_base + 8, iter_elem.1)
          cleanup_list.push(ptr6)
        }
        mbt_ffi_store32(iter_base + 36, payload5.length())
        mbt_ffi_store32(iter_base + 32, address7)
        cleanup_list.push(address7)

        ()
      }
      VariantType(payload9) => {
        mbt_ffi_store8(iter_base + 24, 1)

        let address13 = mbt_ffi_malloc(payload9.length() * 16)
        for index14 = 0; index14 < payload9.length(); index14 = index14 + 1 {
          let iter_elem : (String, Int?) = payload9[index14]
          let iter_base = address13 + index14 * 16

          let ptr10 = mbt_ffi_str2ptr(iter_elem.0)
          mbt_ffi_store32(iter_base + 4, iter_elem.0.length())
          mbt_ffi_store32(iter_base + 0, ptr10)

          match iter_elem.1 {
            None => {
              mbt_ffi_store8(iter_base + 8, 0)

              ()
            }
            Some(payload12) => {
              mbt_ffi_store8(iter_base + 8, 1)
              mbt_ffi_store32(iter_base + 12, payload12)

              ()
            }
          }
          cleanup_list.push(ptr10)
        }
        mbt_ffi_store32(iter_base + 36, payload9.length())
        mbt_ffi_store32(iter_base + 32, address13)
        cleanup_list.push(address13)

        ()
      }
      EnumType(payload15) => {
        mbt_ffi_store8(iter_base + 24, 2)

        let address17 = mbt_ffi_malloc(payload15.length() * 8)
        for index18 = 0; index18 < payload15.length(); index18 = index18 + 1 {
          let iter_elem : String = payload15[index18]
          let iter_base = address17 + index18 * 8

          let ptr16 = mbt_ffi_str2ptr(iter_elem)
          mbt_ffi_store32(iter_base + 4, iter_elem.length())
          mbt_ffi_store32(iter_base + 0, ptr16)
          cleanup_list.push(ptr16)
        }
        mbt_ffi_store32(iter_base + 36, payload15.length())
        mbt_ffi_store32(iter_base + 32, address17)
        cleanup_list.push(address17)

        ()
      }
      FlagsType(payload19) => {
        mbt_ffi_store8(iter_base + 24, 3)

        let address21 = mbt_ffi_malloc(payload19.length() * 8)
        for index22 = 0; index22 < payload19.length(); index22 = index22 + 1 {
          let iter_elem : String = payload19[index22]
          let iter_base = address21 + index22 * 8

          let ptr20 = mbt_ffi_str2ptr(iter_elem)
          mbt_ffi_store32(iter_base + 4, iter_elem.length())
          mbt_ffi_store32(iter_base + 0, ptr20)
          cleanup_list.push(ptr20)
        }
        mbt_ffi_store32(iter_base + 36, payload19.length())
        mbt_ffi_store32(iter_base + 32, address21)
        cleanup_list.push(address21)

        ()
      }
      TupleType(payload23) => {
        mbt_ffi_store8(iter_base + 24, 4)

        let address24 = mbt_ffi_malloc(payload23.length() * 4)
        for index25 = 0; index25 < payload23.length(); index25 = index25 + 1 {
          let iter_elem : Int = payload23[index25]
          let iter_base = address24 + index25 * 4
          mbt_ffi_store32(iter_base + 0, iter_elem)
        }
        mbt_ffi_store32(iter_base + 36, payload23.length())
        mbt_ffi_store32(iter_base + 32, address24)
        cleanup_list.push(address24)

        ()
      }
      ListType(payload26) => {
        mbt_ffi_store8(iter_base + 24, 5)
        mbt_ffi_store32(iter_base + 32, payload26)

        ()
      }
      OptionType(payload27) => {
        mbt_ffi_store8(iter_base + 24, 6)
        mbt_ffi_store32(iter_base + 32, payload27)

        ()
      }
      ResultType(payload28) => {
        mbt_ffi_store8(iter_base + 24, 7)

        match payload28.0 {
          None => {
            mbt_ffi_store8(iter_base + 32, 0)

            ()
          }
          Some(payload30) => {
            mbt_ffi_store8(iter_base + 32, 1)
            mbt_ffi_store32(iter_base + 36, payload30)

            ()
          }
        }

        match payload28.1 {
          None => {
            mbt_ffi_store8(iter_base + 40, 0)

            ()
          }
          Some(payload32) => {
            mbt_ffi_store8(iter_base + 40, 1)
            mbt_ffi_store32(iter_base + 44, payload32)

            ()
          }
        }

        ()
      }
      PrimU8Type => {
        mbt_ffi_store8(iter_base + 24, 8)

        ()
      }
      PrimU16Type => {
        mbt_ffi_store8(iter_base + 24, 9)

        ()
      }
      PrimU32Type => {
        mbt_ffi_store8(iter_base + 24, 10)

        ()
      }
      PrimU64Type => {
        mbt_ffi_store8(iter_base + 24, 11)

        ()
      }
      PrimS8Type => {
        mbt_ffi_store8(iter_base + 24, 12)

        ()
      }
      PrimS16Type => {
        mbt_ffi_store8(iter_base + 24, 13)

        ()
      }
      PrimS32Type => {
        mbt_ffi_store8(iter_base + 24, 14)

        ()
      }
      PrimS64Type => {
        mbt_ffi_store8(iter_base + 24, 15)

        ()
      }
      PrimF32Type => {
        mbt_ffi_store8(iter_base + 24, 16)

        ()
      }
      PrimF64Type => {
        mbt_ffi_store8(iter_base + 24, 17)

        ()
      }
      PrimCharType => {
        mbt_ffi_store8(iter_base + 24, 18)

        ()
      }
      PrimBoolType => {
        mbt_ffi_store8(iter_base + 24, 19)

        ()
      }
      PrimStringType => {
        mbt_ffi_store8(iter_base + 24, 20)

        ()
      }
      HandleType(payload46) => {
        mbt_ffi_store8(iter_base + 24, 21)
        mbt_ffi_store64(iter_base + 32, payload46.0.reinterpret_as_int64())
        mbt_ffi_store8(iter_base + 40, payload46.1.ordinal())

        ()
      }
    }
  }
  let return_area = mbt_ffi_malloc(8)
  wasmImportGetConfigValue(
    address,
    key.length(),
    address47,
    expected_type.nodes.length(),
    return_area,
  )

  let array62 : Array[@types.WitNode] = []
  for index63 = 0
      index63 < mbt_ffi_load32(return_area + 4)
      index63 = index63 + 1 {
    let iter_base = mbt_ffi_load32(return_area + 0) + index63 * 24

    let lifted61 = match mbt_ffi_load8_u(iter_base + 0) {
      0 => {
        let array : Array[Int] = []
        for index49 = 0
            index49 < mbt_ffi_load32(iter_base + 12)
            index49 = index49 + 1 {
          let iter_base = mbt_ffi_load32(iter_base + 8) + index49 * 4

          array.push(mbt_ffi_load32(iter_base + 0))
        }
        mbt_ffi_free(mbt_ffi_load32(iter_base + 8))

        @types.WitNode::RecordValue(array)
      }
      1 => {
        let lifted : Int? = match mbt_ffi_load8_u(iter_base + 12) {
          0 => Option::None
          1 => Option::Some(mbt_ffi_load32(iter_base + 16))
          _ => panic()
        }

        @types.WitNode::VariantValue(
          (mbt_ffi_load32(iter_base + 8).reinterpret_as_uint(), lifted),
        )
      }
      2 =>
        @types.WitNode::EnumValue(
          mbt_ffi_load32(iter_base + 8).reinterpret_as_uint(),
        )
      3 => {
        let array50 : Array[Bool] = []
        for index51 = 0
            index51 < mbt_ffi_load32(iter_base + 12)
            index51 = index51 + 1 {
          let iter_base = mbt_ffi_load32(iter_base + 8) + index51 * 1

          array50.push(mbt_ffi_load8_u(iter_base + 0) != 0)
        }
        mbt_ffi_free(mbt_ffi_load32(iter_base + 8))

        @types.WitNode::FlagsValue(array50)
      }
      4 => {
        let array52 : Array[Int] = []
        for index53 = 0
            index53 < mbt_ffi_load32(iter_base + 12)
            index53 = index53 + 1 {
          let iter_base = mbt_ffi_load32(iter_base + 8) + index53 * 4

          array52.push(mbt_ffi_load32(iter_base + 0))
        }
        mbt_ffi_free(mbt_ffi_load32(iter_base + 8))

        @types.WitNode::TupleValue(array52)
      }
      5 => {
        let array54 : Array[Int] = []
        for index55 = 0
            index55 < mbt_ffi_load32(iter_base + 12)
            index55 = index55 + 1 {
          let iter_base = mbt_ffi_load32(iter_base + 8) + index55 * 4

          array54.push(mbt_ffi_load32(iter_base + 0))
        }
        mbt_ffi_free(mbt_ffi_load32(iter_base + 8))

        @types.WitNode::ListValue(array54)
      }
      6 => {
        let lifted56 : Int? = match mbt_ffi_load8_u(iter_base + 8) {
          0 => Option::None
          1 => Option::Some(mbt_ffi_load32(iter_base + 12))
          _ => panic()
        }

        @types.WitNode::OptionValue(lifted56)
      }
      7 => {
        let lifted59 = match mbt_ffi_load8_u(iter_base + 8) {
          0 => {
            let lifted57 : Int? = match mbt_ffi_load8_u(iter_base + 12) {
              0 => Option::None
              1 => Option::Some(mbt_ffi_load32(iter_base + 16))
              _ => panic()
            }

            Result::Ok(lifted57)
          }
          1 => {
            let lifted58 : Int? = match mbt_ffi_load8_u(iter_base + 12) {
              0 => Option::None
              1 => Option::Some(mbt_ffi_load32(iter_base + 16))
              _ => panic()
            }

            Result::Err(lifted58)
          }
          _ => panic()
        }

        @types.WitNode::ResultValue(lifted59)
      }
      8 => @types.WitNode::PrimU8(mbt_ffi_load8_u(iter_base + 8).to_byte())
      9 =>
        @types.WitNode::PrimU16(
          mbt_ffi_load16_u(iter_base + 8).land(0xFFFF).reinterpret_as_uint(),
        )
      10 =>
        @types.WitNode::PrimU32(
          mbt_ffi_load32(iter_base + 8).reinterpret_as_uint(),
        )
      11 =>
        @types.WitNode::PrimU64(
          mbt_ffi_load64(iter_base + 8).reinterpret_as_uint64(),
        )
      12 => @types.WitNode::PrimS8(mbt_ffi_load8(iter_base + 8) - 0x100)
      13 => @types.WitNode::PrimS16(mbt_ffi_load16(iter_base + 8) - 0x10000)
      14 => @types.WitNode::PrimS32(mbt_ffi_load32(iter_base + 8))
      15 => @types.WitNode::PrimS64(mbt_ffi_load64(iter_base + 8))
      16 => @types.WitNode::PrimFloat32(mbt_ffi_loadf32(iter_base + 8))
      17 => @types.WitNode::PrimFloat64(mbt_ffi_loadf64(iter_base + 8))
      18 =>
        @types.WitNode::PrimChar(
          Int::unsafe_to_char(mbt_ffi_load32(iter_base + 8)),
        )
      19 => @types.WitNode::PrimBool(mbt_ffi_load8_u(iter_base + 8) != 0)
      20 => {
        let result = mbt_ffi_ptr2str(
          mbt_ffi_load32(iter_base + 8),
          mbt_ffi_load32(iter_base + 12),
        )

        @types.WitNode::PrimString(result)
      }
      21 => {
        let result60 = mbt_ffi_ptr2str(
          mbt_ffi_load32(iter_base + 8),
          mbt_ffi_load32(iter_base + 12),
        )

        @types.WitNode::Handle(
          (
            @types.Uri::{ value: result60 },
            mbt_ffi_load64(iter_base + 16).reinterpret_as_uint64(),
          ),
        )
      }
      _ => panic()
    }

    array62.push(lifted61)
  }
  mbt_ffi_free(mbt_ffi_load32(return_area + 0))
  let ret = @types.WitValue::{ nodes: array62 }
  mbt_ffi_free(address)
  mbt_ffi_free(address47)
  mbt_ffi_free(return_area)

  cleanup_list.each(mbt_ffi_free)
  return ret
}
