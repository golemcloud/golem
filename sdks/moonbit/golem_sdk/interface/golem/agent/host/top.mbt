                        let result392 = mbt_ffi_ptr2str(mbt_ffi_load32((iter_base) + 8), mbt_ffi_load32((iter_base) + 12))

                        @types.SchemaValueNode::UnionValue(@types.UnionValuePayload::{tag : result392, body : mbt_ffi_load32((iter_base) + 16)})
                  }
                  31 => {

                        let result393 = mbt_ffi_ptr2str(mbt_ffi_load32((iter_base) + 8), mbt_ffi_load32((iter_base) + 12))

                        @types.SchemaValueNode::SecretValue(@types.SecretValuePayload::{secret_ref : result393})
                  }
                  32 => {

                        @types.SchemaValueNode::QuotaTokenHandle(@types.QuotaToken::QuotaToken(mbt_ffi_load32((iter_base) + 8)))
                  }
                  _ => panic()
            }

            array395.push(lifted394)
      }
      mbt_ffi_free(mbt_ffi_load32((return_area) + 0))
      let ret = @types.SchemaValueTree::{value_nodes : array395, root : mbt_ffi_load32((return_area) + 8)}
      mbt_ffi_free(address)
      mbt_ffi_free(address360)
      mbt_ffi_free(address366)
      mbt_ffi_free(return_area)

      cleanup_list.each(mbt_ffi_free)
      return ret

}

