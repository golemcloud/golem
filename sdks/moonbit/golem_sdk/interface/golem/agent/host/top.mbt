            }
            Some(payload39) => {
              mbt_ffi_store8(iter_base + 16, 1)

              let ptr40 = mbt_ffi_str2ptr(payload39)
              mbt_ffi_store32(iter_base + 24, payload39.length())
              mbt_ffi_store32(iter_base + 20, ptr40)
              cleanup_list.push(ptr40)

