                Other(payload53) => {
                  mbt_ffi_store8(iter_base + 60, 1)

                  let ptr54 = mbt_ffi_str2ptr(payload53)
                  mbt_ffi_store32(iter_base + 68, payload53.length())
                  mbt_ffi_store32(iter_base + 64, ptr54)
                  cleanup_list.push(ptr54)

