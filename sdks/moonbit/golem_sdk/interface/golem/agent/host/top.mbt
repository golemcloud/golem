                  mbt_ffi_free(mbt_ffi_load32(return_area + 36))

                  @common.AgentError::CustomError(@types.TypedSchemaValue::{
                    graph: @types.SchemaGraph::{
                      type_nodes: array164,
                      defs: array169,
                      root: mbt_ffi_load32(return_area + 32),
