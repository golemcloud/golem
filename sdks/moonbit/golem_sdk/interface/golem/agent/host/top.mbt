                          1 => Option::Some(mbt_ffi_load32(iter_base + 12))
                          _ => panic()
                        }

                        @types.SchemaValueNode::OptionValue(lifted185)
                      }
                      22 => {
                        let lifted188 = match mbt_ffi_load8_u(iter_base + 8) {
                          0 => {
                            let lifted186 : Int? = match
                              mbt_ffi_load8_u(iter_base + 12) {
