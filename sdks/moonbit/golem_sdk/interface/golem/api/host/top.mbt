///|
/// Fork an agent to another agent at a given oplog index
pub fn fork_agent(
  source_agent_id : @types.AgentId,
  target_agent_id : @types.AgentId,
  oplog_idx_cut_off : UInt64,
) -> Unit {
  let ptr = mbt_ffi_str2ptr(source_agent_id.agent_id)

  let ptr0 = mbt_ffi_str2ptr(target_agent_id.agent_id)
  wasmImportForkAgent(
    source_agent_id.component_id.uuid.high_bits.reinterpret_as_int64(),
    source_agent_id.component_id.uuid.low_bits.reinterpret_as_int64(),
    ptr,
    source_agent_id.agent_id.length(),
    target_agent_id.component_id.uuid.high_bits.reinterpret_as_int64(),
    target_agent_id.component_id.uuid.low_bits.reinterpret_as_int64(),
    ptr0,
    target_agent_id.agent_id.length(),
    oplog_idx_cut_off.reinterpret_as_int64(),
  )
  mbt_ffi_free(ptr)
  mbt_ffi_free(ptr0)
}

///|
/// Revert an agent to a previous state
pub fn revert_agent(
  agent_id : @types.AgentId,
  revert_target : RevertAgentTarget,
) -> Unit {
  let ptr = mbt_ffi_str2ptr(agent_id.agent_id)

  let (lowered, lowered1) = match revert_target {
    RevertToOplogIndex(payload) => (0, payload.reinterpret_as_int64())
    RevertLastInvocations(payload0) => (1, payload0.reinterpret_as_int64())
  }
  wasmImportRevertAgent(
    agent_id.component_id.uuid.high_bits.reinterpret_as_int64(),
    agent_id.component_id.uuid.low_bits.reinterpret_as_int64(),
    ptr,
    agent_id.agent_id.length(),
    lowered,
    lowered1,
  )
  mbt_ffi_free(ptr)
}

///|
/// Get the component-id for a given component reference.
/// Returns none when no component with the specified reference exists.
/// The syntax of the component reference is implementation dependent.
///
/// Golem OSS: "{component_name}"
/// Golem Cloud:
///     1: "{component_name}" -> will resolve in current account and project
///     2: "{project_name}/{component_name}" -> will resolve in current account
///     3: "{account_id}/{project_name}/{component_name}"
pub fn resolve_component_id(
  component_reference : String,
) -> @types.ComponentId? {
  let ptr = mbt_ffi_str2ptr(component_reference)
  let return_area = mbt_ffi_malloc(24)
  wasmImportResolveComponentId(ptr, component_reference.length(), return_area)

  let lifted : @types.ComponentId? = match mbt_ffi_load8_u(return_area + 0) {
    0 => Option::None
    1 =>
      Option::Some(@types.ComponentId::{
        uuid: @types.Uuid::{
          high_bits: mbt_ffi_load64(return_area + 8).reinterpret_as_uint64(),
          low_bits: mbt_ffi_load64(return_area + 16).reinterpret_as_uint64(),
        },
      })
    _ => panic()
  }
  let ret = lifted
  mbt_ffi_free(ptr)
  mbt_ffi_free(return_area)
  return ret
}

