      }
      PropGt(payload11) => {
        mbt_ffi_store8(iter_base + 0, 2)

        let ptr12 = mbt_ffi_str2ptr(payload11.property_name)
        mbt_ffi_store32(iter_base + 12, payload11.property_name.length())
