///|
/// Add or overwrite a named retry policy (persisted to oplog).
/// If a policy with the same name exists, it is replaced.
pub fn set_retry_policy(policy : NamedRetryPolicy) -> Unit {
  let cleanup_list : Array[Int] = []

  let ptr = mbt_ffi_str2ptr(policy.name)

  let address57 = mbt_ffi_malloc(policy.predicate.nodes.length() * 32)
  for index58 = 0
      index58 < policy.predicate.nodes.length()
      index58 = index58 + 1 {
    let iter_elem : PredicateNode = policy.predicate.nodes[index58]
    let iter_base = address57 + index58 * 32

    match iter_elem {
      PropEq(payload) => {
        mbt_ffi_store8(iter_base + 0, 0)

        let ptr0 = mbt_ffi_str2ptr(payload.property_name)
        mbt_ffi_store32(iter_base + 12, payload.property_name.length())
        mbt_ffi_store32(iter_base + 8, ptr0)

        match payload.value {
          Text(payload1) => {
            mbt_ffi_store8(iter_base + 16, 0)

            let ptr2 = mbt_ffi_str2ptr(payload1)
            mbt_ffi_store32(iter_base + 28, payload1.length())
            mbt_ffi_store32(iter_base + 24, ptr2)
            cleanup_list.push(ptr2)

            ()
          }
          Integer(payload3) => {
            mbt_ffi_store8(iter_base + 16, 1)
            mbt_ffi_store64(iter_base + 24, payload3)

            ()
          }
          Boolean(payload4) => {
            mbt_ffi_store8(iter_base + 16, 2)
            mbt_ffi_store8(iter_base + 24, if payload4 { 1 } else { 0 })

            ()
          }
        }
        cleanup_list.push(ptr0)

        ()
      }
      PropNeq(payload5) => {
        mbt_ffi_store8(iter_base + 0, 1)

        let ptr6 = mbt_ffi_str2ptr(payload5.property_name)
        mbt_ffi_store32(iter_base + 12, payload5.property_name.length())
        mbt_ffi_store32(iter_base + 8, ptr6)

        match payload5.value {
          Text(payload7) => {
            mbt_ffi_store8(iter_base + 16, 0)

            let ptr8 = mbt_ffi_str2ptr(payload7)
            mbt_ffi_store32(iter_base + 28, payload7.length())
            mbt_ffi_store32(iter_base + 24, ptr8)
            cleanup_list.push(ptr8)

