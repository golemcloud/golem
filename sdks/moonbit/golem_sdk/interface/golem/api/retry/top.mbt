        mbt_ffi_store32(iter_base + 12, payload37.property_name.length())
        mbt_ffi_store32(iter_base + 8, ptr38)

        let address = mbt_ffi_malloc(payload37.values.length() * 16)
        for index = 0; index < payload37.values.length(); index = index + 1 {
          let iter_elem : PredicateValue = payload37.values[index]
          let iter_base = address + index * 16

          match iter_elem {
