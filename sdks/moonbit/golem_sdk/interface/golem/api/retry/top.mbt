///|
/// Resolve the matching retry policy for a given operation context.
/// Evaluates named policies in descending priority order; returns the
/// policy from the first rule whose predicate matches, or none.
pub fn resolve_retry_policy(
  verb : String,
  noun_uri : String,
  properties : Array[(String, PredicateValue)],
) -> RetryPolicy? {
  let cleanup_list : Array[Int] = []

  let ptr = mbt_ffi_str2ptr(verb)

  let ptr0 = mbt_ffi_str2ptr(noun_uri)

  let address = mbt_ffi_malloc(properties.length() * 24)
  for index = 0; index < properties.length(); index = index + 1 {
    let iter_elem : (String, PredicateValue) = properties[index]
    let iter_base = address + index * 24

    let ptr1 = mbt_ffi_str2ptr(iter_elem.0)
    mbt_ffi_store32(iter_base + 4, iter_elem.0.length())
    mbt_ffi_store32(iter_base + 0, ptr1)

    match iter_elem.1 {
      Text(payload) => {
        mbt_ffi_store8(iter_base + 8, 0)

        let ptr2 = mbt_ffi_str2ptr(payload)
        mbt_ffi_store32(iter_base + 20, payload.length())
        mbt_ffi_store32(iter_base + 16, ptr2)
        cleanup_list.push(ptr2)

        ()
      }
      Integer(payload3) => {
        mbt_ffi_store8(iter_base + 8, 1)
        mbt_ffi_store64(iter_base + 16, payload3)

        ()
      }
      Boolean(payload4) => {
        mbt_ffi_store8(iter_base + 8, 2)
        mbt_ffi_store8(iter_base + 16, if payload4 { 1 } else { 0 })

        ()
      }
    }
    cleanup_list.push(ptr1)
  }
