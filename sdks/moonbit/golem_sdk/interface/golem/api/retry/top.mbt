            (mbt_ffi_load32(iter_base + 8), mbt_ffi_load32(iter_base + 12)),
          )
        13 =>
          PolicyNode::PolicyIntersect(
            (mbt_ffi_load32(iter_base + 8), mbt_ffi_load32(iter_base + 12)),
          )
        _ => panic()
      }

      array64.push(lifted63)
    }
    mbt_ffi_free(mbt_ffi_load32(iter_base + 20))

    array66.push(NamedRetryPolicy::{
      name: result,
      priority: mbt_ffi_load32(iter_base + 8).reinterpret_as_uint(),
      predicate: RetryPredicate::{ nodes: array28 },
      policy: RetryPolicy::{ nodes: array64 },
    })
  }
  mbt_ffi_free(mbt_ffi_load32(return_area + 0))
  let ret = array66
  mbt_ffi_free(return_area)
