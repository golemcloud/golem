      PredNot(payload54) => {
        mbt_ffi_store8(iter_base + 0, 13)
        mbt_ffi_store32(iter_base + 8, payload54)

        ()
      }
      PredTrue => {
        mbt_ffi_store8(iter_base + 0, 14)

        ()
      }
      PredFalse => {
        mbt_ffi_store8(iter_base + 0, 15)

        ()
      }
    }
  }

  let address135 = mbt_ffi_malloc(policy.policy.nodes.length() * 32)
  for index136 = 0
      index136 < policy.policy.nodes.length()
      index136 = index136 + 1 {
    let iter_elem : PolicyNode = policy.policy.nodes[index136]
    let iter_base = address135 + index136 * 32

    match iter_elem {
      Periodic(payload59) => {
        mbt_ffi_store8(iter_base + 0, 0)
        mbt_ffi_store64(iter_base + 8, payload59.reinterpret_as_int64())

        ()
      }
      Exponential(payload60) => {
        mbt_ffi_store8(iter_base + 0, 1)
        mbt_ffi_store64(
          iter_base + 8,
          payload60.base_delay.reinterpret_as_int64(),
        )
        mbt_ffi_storef64(iter_base + 16, payload60.factor)

        ()
      }
      Fibonacci(payload61) => {
        mbt_ffi_store8(iter_base + 0, 2)
        mbt_ffi_store64(iter_base + 8, payload61.first.reinterpret_as_int64())
        mbt_ffi_store64(iter_base + 16, payload61.second.reinterpret_as_int64())

        ()
      }
      Immediate => {
        mbt_ffi_store8(iter_base + 0, 3)

        ()
      }
      Never => {
        mbt_ffi_store8(iter_base + 0, 4)

        ()
      }
      CountBox(payload64) => {
        mbt_ffi_store8(iter_base + 0, 5)
        mbt_ffi_store32(
          iter_base + 8,
          payload64.max_retries.reinterpret_as_int(),
        )
        mbt_ffi_store32(iter_base + 12, payload64.inner)

        ()
      }
      TimeBox(payload65) => {
        mbt_ffi_store8(iter_base + 0, 6)
        mbt_ffi_store64(iter_base + 8, payload65.limit.reinterpret_as_int64())
        mbt_ffi_store32(iter_base + 16, payload65.inner)

        ()
      }
      ClampDelay(payload66) => {
        mbt_ffi_store8(iter_base + 0, 7)
        mbt_ffi_store64(
          iter_base + 8,
          payload66.min_delay.reinterpret_as_int64(),
        )
        mbt_ffi_store64(
          iter_base + 16,
          payload66.max_delay.reinterpret_as_int64(),
        )
        mbt_ffi_store32(iter_base + 24, payload66.inner)

        ()
      }
      AddDelay(payload67) => {
        mbt_ffi_store8(iter_base + 0, 8)
        mbt_ffi_store64(iter_base + 8, payload67.delay.reinterpret_as_int64())
        mbt_ffi_store32(iter_base + 16, payload67.inner)

        ()
      }
      Jitter(payload68) => {
        mbt_ffi_store8(iter_base + 0, 9)
        mbt_ffi_storef64(iter_base + 8, payload68.factor)
        mbt_ffi_store32(iter_base + 16, payload68.inner)

        ()
      }
      FilteredOn(payload69) => {
        mbt_ffi_store8(iter_base + 0, 10)

        let address130 = mbt_ffi_malloc(payload69.predicate.nodes.length() * 32)
        for index131 = 0
            index131 < payload69.predicate.nodes.length()
            index131 = index131 + 1 {
          let iter_elem : PredicateNode = payload69.predicate.nodes[index131]
          let iter_base = address130 + index131 * 32

          match iter_elem {
            PropEq(payload70) => {
              mbt_ffi_store8(iter_base + 0, 0)

              let ptr71 = mbt_ffi_str2ptr(payload70.property_name)
              mbt_ffi_store32(iter_base + 12, payload70.property_name.length())
              mbt_ffi_store32(iter_base + 8, ptr71)

              match payload70.value {
                Text(payload72) => {
                  mbt_ffi_store8(iter_base + 16, 0)

                  let ptr73 = mbt_ffi_str2ptr(payload72)
                  mbt_ffi_store32(iter_base + 28, payload72.length())
                  mbt_ffi_store32(iter_base + 24, ptr73)
                  cleanup_list.push(ptr73)

                  ()
                }
                Integer(payload74) => {
                  mbt_ffi_store8(iter_base + 16, 1)
                  mbt_ffi_store64(iter_base + 24, payload74)

                  ()
                }
                Boolean(payload75) => {
                  mbt_ffi_store8(iter_base + 16, 2)
                  mbt_ffi_store8(iter_base + 24, if payload75 { 1 } else { 0 })

                  ()
                }
              }
              cleanup_list.push(ptr71)

              ()
            }
            PropNeq(payload76) => {
              mbt_ffi_store8(iter_base + 0, 1)

              let ptr77 = mbt_ffi_str2ptr(payload76.property_name)
              mbt_ffi_store32(iter_base + 12, payload76.property_name.length())
              mbt_ffi_store32(iter_base + 8, ptr77)

              match payload76.value {
                Text(payload78) => {
                  mbt_ffi_store8(iter_base + 16, 0)

                  let ptr79 = mbt_ffi_str2ptr(payload78)
                  mbt_ffi_store32(iter_base + 28, payload78.length())
                  mbt_ffi_store32(iter_base + 24, ptr79)
                  cleanup_list.push(ptr79)

                  ()
                }
                Integer(payload80) => {
                  mbt_ffi_store8(iter_base + 16, 1)
                  mbt_ffi_store64(iter_base + 24, payload80)

                  ()
                }
                Boolean(payload81) => {
                  mbt_ffi_store8(iter_base + 16, 2)
                  mbt_ffi_store8(iter_base + 24, if payload81 { 1 } else { 0 })

                  ()
                }
              }
              cleanup_list.push(ptr77)

              ()
            }
            PropGt(payload82) => {
              mbt_ffi_store8(iter_base + 0, 2)

              let ptr83 = mbt_ffi_str2ptr(payload82.property_name)
              mbt_ffi_store32(iter_base + 12, payload82.property_name.length())
              mbt_ffi_store32(iter_base + 8, ptr83)

              match payload82.value {
                Text(payload84) => {
                  mbt_ffi_store8(iter_base + 16, 0)

                  let ptr85 = mbt_ffi_str2ptr(payload84)
                  mbt_ffi_store32(iter_base + 28, payload84.length())
                  mbt_ffi_store32(iter_base + 24, ptr85)
                  cleanup_list.push(ptr85)

                  ()
                }
                Integer(payload86) => {
                  mbt_ffi_store8(iter_base + 16, 1)
                  mbt_ffi_store64(iter_base + 24, payload86)

                  ()
                }
                Boolean(payload87) => {
                  mbt_ffi_store8(iter_base + 16, 2)
                  mbt_ffi_store8(iter_base + 24, if payload87 { 1 } else { 0 })

                  ()
                }
              }
              cleanup_list.push(ptr83)

              ()
            }
            PropGte(payload88) => {
              mbt_ffi_store8(iter_base + 0, 3)

              let ptr89 = mbt_ffi_str2ptr(payload88.property_name)
              mbt_ffi_store32(iter_base + 12, payload88.property_name.length())
              mbt_ffi_store32(iter_base + 8, ptr89)

              match payload88.value {
                Text(payload90) => {
                  mbt_ffi_store8(iter_base + 16, 0)

                  let ptr91 = mbt_ffi_str2ptr(payload90)
                  mbt_ffi_store32(iter_base + 28, payload90.length())
                  mbt_ffi_store32(iter_base + 24, ptr91)
                  cleanup_list.push(ptr91)

                  ()
                }
                Integer(payload92) => {
                  mbt_ffi_store8(iter_base + 16, 1)
                  mbt_ffi_store64(iter_base + 24, payload92)

                  ()
                }
                Boolean(payload93) => {
                  mbt_ffi_store8(iter_base + 16, 2)
                  mbt_ffi_store8(iter_base + 24, if payload93 { 1 } else { 0 })

                  ()
                }
              }
              cleanup_list.push(ptr89)

              ()
            }
            PropLt(payload94) => {
              mbt_ffi_store8(iter_base + 0, 4)

              let ptr95 = mbt_ffi_str2ptr(payload94.property_name)
              mbt_ffi_store32(iter_base + 12, payload94.property_name.length())
              mbt_ffi_store32(iter_base + 8, ptr95)

              match payload94.value {
                Text(payload96) => {
                  mbt_ffi_store8(iter_base + 16, 0)

                  let ptr97 = mbt_ffi_str2ptr(payload96)
                  mbt_ffi_store32(iter_base + 28, payload96.length())
                  mbt_ffi_store32(iter_base + 24, ptr97)
                  cleanup_list.push(ptr97)

                  ()
                }
                Integer(payload98) => {
                  mbt_ffi_store8(iter_base + 16, 1)
                  mbt_ffi_store64(iter_base + 24, payload98)

                  ()
                }
                Boolean(payload99) => {
                  mbt_ffi_store8(iter_base + 16, 2)
                  mbt_ffi_store8(iter_base + 24, if payload99 { 1 } else { 0 })

                  ()
                }
              }
              cleanup_list.push(ptr95)

              ()
            }
            PropLte(payload100) => {
              mbt_ffi_store8(iter_base + 0, 5)

              let ptr101 = mbt_ffi_str2ptr(payload100.property_name)
              mbt_ffi_store32(iter_base + 12, payload100.property_name.length())
              mbt_ffi_store32(iter_base + 8, ptr101)

              match payload100.value {
                Text(payload102) => {
                  mbt_ffi_store8(iter_base + 16, 0)

                  let ptr103 = mbt_ffi_str2ptr(payload102)
                  mbt_ffi_store32(iter_base + 28, payload102.length())
                  mbt_ffi_store32(iter_base + 24, ptr103)
                  cleanup_list.push(ptr103)

                  ()
                }
                Integer(payload104) => {
                  mbt_ffi_store8(iter_base + 16, 1)
                  mbt_ffi_store64(iter_base + 24, payload104)

                  ()
                }
                Boolean(payload105) => {
                  mbt_ffi_store8(iter_base + 16, 2)
                  mbt_ffi_store8(iter_base + 24, if payload105 { 1 } else { 0 })

                  ()
                }
              }
              cleanup_list.push(ptr101)

              ()
            }
            PropExists(payload106) => {
              mbt_ffi_store8(iter_base + 0, 6)

              let ptr107 = mbt_ffi_str2ptr(payload106)
              mbt_ffi_store32(iter_base + 12, payload106.length())
              mbt_ffi_store32(iter_base + 8, ptr107)
              cleanup_list.push(ptr107)

              ()
            }
            PropIn(payload108) => {
              mbt_ffi_store8(iter_base + 0, 7)

              let ptr109 = mbt_ffi_str2ptr(payload108.property_name)
              mbt_ffi_store32(iter_base + 12, payload108.property_name.length())
              mbt_ffi_store32(iter_base + 8, ptr109)

              let address114 = mbt_ffi_malloc(payload108.values.length() * 16)
              for index115 = 0
                  index115 < payload108.values.length()
                  index115 = index115 + 1 {
                let iter_elem : PredicateValue = payload108.values[index115]
                let iter_base = address114 + index115 * 16

                match iter_elem {
                  Text(payload110) => {
                    mbt_ffi_store8(iter_base + 0, 0)

                    let ptr111 = mbt_ffi_str2ptr(payload110)
                    mbt_ffi_store32(iter_base + 12, payload110.length())
                    mbt_ffi_store32(iter_base + 8, ptr111)
                    cleanup_list.push(ptr111)

                    ()
                  }
                  Integer(payload112) => {
                    mbt_ffi_store8(iter_base + 0, 1)
                    mbt_ffi_store64(iter_base + 8, payload112)

                    ()
                  }
                  Boolean(payload113) => {
                    mbt_ffi_store8(iter_base + 0, 2)
                    mbt_ffi_store8(
                      iter_base + 8,
                      if payload113 {
                        1
                      } else {
                        0
                      },
                    )

                    ()
                  }
                }
              }
              mbt_ffi_store32(iter_base + 20, payload108.values.length())
              mbt_ffi_store32(iter_base + 16, address114)
              cleanup_list.push(ptr109)
              cleanup_list.push(address114)

              ()
            }
            PropMatches(payload116) => {
              mbt_ffi_store8(iter_base + 0, 8)

              let ptr117 = mbt_ffi_str2ptr(payload116.property_name)
              mbt_ffi_store32(iter_base + 12, payload116.property_name.length())
              mbt_ffi_store32(iter_base + 8, ptr117)

              let ptr118 = mbt_ffi_str2ptr(payload116.pattern)
              mbt_ffi_store32(iter_base + 20, payload116.pattern.length())
              mbt_ffi_store32(iter_base + 16, ptr118)
              cleanup_list.push(ptr117)
              cleanup_list.push(ptr118)

              ()
            }
            PropStartsWith(payload119) => {
              mbt_ffi_store8(iter_base + 0, 9)

              let ptr120 = mbt_ffi_str2ptr(payload119.property_name)
              mbt_ffi_store32(iter_base + 12, payload119.property_name.length())
              mbt_ffi_store32(iter_base + 8, ptr120)

              let ptr121 = mbt_ffi_str2ptr(payload119.pattern)
              mbt_ffi_store32(iter_base + 20, payload119.pattern.length())
              mbt_ffi_store32(iter_base + 16, ptr121)
              cleanup_list.push(ptr120)
              cleanup_list.push(ptr121)

              ()
            }
            PropContains(payload122) => {
              mbt_ffi_store8(iter_base + 0, 10)

              let ptr123 = mbt_ffi_str2ptr(payload122.property_name)
              mbt_ffi_store32(iter_base + 12, payload122.property_name.length())
              mbt_ffi_store32(iter_base + 8, ptr123)

              let ptr124 = mbt_ffi_str2ptr(payload122.pattern)
              mbt_ffi_store32(iter_base + 20, payload122.pattern.length())
              mbt_ffi_store32(iter_base + 16, ptr124)
              cleanup_list.push(ptr123)
              cleanup_list.push(ptr124)

              ()
            }
            PredAnd(payload125) => {
              mbt_ffi_store8(iter_base + 0, 11)
              mbt_ffi_store32(iter_base + 8, payload125.0)
              mbt_ffi_store32(iter_base + 12, payload125.1)

              ()
            }
            PredOr(payload126) => {
              mbt_ffi_store8(iter_base + 0, 12)
              mbt_ffi_store32(iter_base + 8, payload126.0)
              mbt_ffi_store32(iter_base + 12, payload126.1)

              ()
            }
            PredNot(payload127) => {
              mbt_ffi_store8(iter_base + 0, 13)
              mbt_ffi_store32(iter_base + 8, payload127)

              ()
            }
            PredTrue => {
              mbt_ffi_store8(iter_base + 0, 14)

              ()
            }
            PredFalse => {
              mbt_ffi_store8(iter_base + 0, 15)

              ()
            }
          }
        }
        mbt_ffi_store32(iter_base + 12, payload69.predicate.nodes.length())
        mbt_ffi_store32(iter_base + 8, address130)
        mbt_ffi_store32(iter_base + 16, payload69.inner)
        cleanup_list.push(address130)

        ()
      }
      AndThen(payload132) => {
        mbt_ffi_store8(iter_base + 0, 11)
        mbt_ffi_store32(iter_base + 8, payload132.0)
        mbt_ffi_store32(iter_base + 12, payload132.1)

        ()
      }
      PolicyUnion(payload133) => {
        mbt_ffi_store8(iter_base + 0, 12)
        mbt_ffi_store32(iter_base + 8, payload133.0)
        mbt_ffi_store32(iter_base + 12, payload133.1)

        ()
      }
      PolicyIntersect(payload134) => {
        mbt_ffi_store8(iter_base + 0, 13)
        mbt_ffi_store32(iter_base + 8, payload134.0)
        mbt_ffi_store32(iter_base + 12, payload134.1)

        ()
      }
    }
  }
  wasmImportSetRetryPolicy(
    ptr,
    policy.name.length(),
    policy.priority.reinterpret_as_int(),
    address57,
    policy.predicate.nodes.length(),
    address135,
    policy.policy.nodes.length(),
  )
  mbt_ffi_free(ptr)
  mbt_ffi_free(address57)
  mbt_ffi_free(address135)

  cleanup_list.each(mbt_ffi_free)
}

///|
/// Remove a named retry policy by name (persisted to oplog).
pub fn remove_retry_policy(name : String) -> Unit {
  let ptr = mbt_ffi_str2ptr(name)
  wasmImportRemoveRetryPolicy(ptr, name.length())
  mbt_ffi_free(ptr)
}
