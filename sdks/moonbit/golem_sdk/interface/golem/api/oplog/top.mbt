              FixedListValue(payload41) => {
                mbt_ffi_store8(iter_base + 0, 19)

                let address42 = mbt_ffi_malloc(payload41.length() * 4)
                for index43 = 0
                    index43 < payload41.length()
                    index43 = index43 + 1 {
                  let iter_elem : Int = payload41[index43]
                  let iter_base = address42 + index43 * 4
