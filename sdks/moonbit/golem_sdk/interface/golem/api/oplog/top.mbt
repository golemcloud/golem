///|
/// Enriches raw oplog entries into public oplog entries by resolving oplog payloads
/// and augmenting entries with component metadata.
pub fn enrich_oplog_entries(
  environment_id : @host.EnvironmentId,
  agent_id : @types.AgentId,
  entries : Array[(UInt64, OplogEntry)],
  component_revision : UInt64,
