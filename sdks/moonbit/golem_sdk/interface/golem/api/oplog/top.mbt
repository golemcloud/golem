                mbt_ffi_store32(iter_base + 8, address45)
                cleanup_list.push(address45)

                ()
              }
              OptionValue(payload47) => {
                mbt_ffi_store8(iter_base + 0, 21)

                match payload47 {
                  None => {
                    mbt_ffi_store8(iter_base + 8, 0)

                    ()
                  }
                  Some(payload49) => {
                    mbt_ffi_store8(iter_base + 8, 1)
                    mbt_ffi_store32(iter_base + 12, payload49)

                    ()
                  }
                }

