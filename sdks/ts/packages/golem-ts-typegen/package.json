{
  "name": "@golemcloud/golem-ts-typegen",
  "type": "module",
  "version": "0.0.0",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "build": "rollup --failAfterWarnings -c",
    "prepare": "pnpm build",
    "clean-test-data": "node ../../scripts/clean-test-data.mjs",
    "generate-agent-metadata": "node ./dist/golem-typegen.cjs ./tsconfig.json --files 'tests/testData.ts' --golem-ts-sdk-import './tests/sdkPlaceholder.ts'",
    "test": "pnpm run clean-test-data && pnpm run generate-agent-metadata && vitest run",
    "dev": "rollup -c -w"
  },
  "bin": {
    "golem-typegen": "./dist/golem-typegen.cjs"
  },
  "keywords": [],
  "author": "",
  "license": "SEE LICENSE IN LICENSE",
  "description": "",
  "dependencies": {
    "@golemcloud/golem-ts-types-core": "workspace:*",
    "picocolors": "^1.1.1",
    "commander": "^14.0.0",
    "log-symbols": "^7.0.1",
    "ts-morph": "^26.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@types/node": "^24.3.0",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "eslint": "^9.33.0",
    "fast-check": "^4.2.0",
    "prettier": "^3.6.2",
    "reflect-metadata": "^0.1.14",
    "rollup": "^4.46.2",
    "rollup-plugin-dts": "^6.2.1",
    "rollup-plugin-typescript2": "^0.36.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.39.0",
    "vitest": "^3.2.4"
  },
  "private": false,
  "repository": "https://github.com/golemcloud/golem"
}
