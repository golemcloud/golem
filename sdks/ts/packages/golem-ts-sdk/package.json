{
  "name": "@golemcloud/golem-ts-sdk",
  "type": "module",
  "version": "0.0.0",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "types",
    "dist",
    "wasm"
  ],
  "main": "dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "typesVersions": {
    "*": {
      "agentic-guest": [
        "types/exports.d.ts"
      ],
      "golem:agent/common@1.5.0": [
        "types/golem_agent_1_5_0_common.d.ts"
      ],
      "golem:agent/host@1.5.0": [
        "types/golem_agent_1_5_0_host.d.ts"
      ],
      "golem:rdbms/ignite2@1.5.0": [
        "types/golem_rdbms_1_5_0_ignite2.d.ts"
      ]
    }
  },
  "scripts": {
    "bench": "vitest bench",
    "lint": "eslint . --ext .ts,.tsx,.mjs",
    "lint:fix": "eslint . --ext .ts,.tsx,.mjs --fix",
    "generate-dts": "wasm-rquickjs generate-dts --wit ../../wit --output types",
    "build": "pnpm run generate-dts && rollup --failAfterWarnings -c",
    "prepare": "pnpm build",
    "clean": "node ./scripts/clean.mjs",
    "clean-test-data": "node ../../scripts/clean-test-data.mjs",
    "generate-sample-agents-types": "golem-typegen ./tsconfig.json --files 'tests/**/*.ts' --include-class-decorators agent --golem-ts-sdk-import './src'",
    "test": "pnpm run clean-test-data && pnpm run generate-sample-agents-types && vitest run",
    "dev": "rollup -c -w",
    "generate-agent-template": "node ./scripts/generate-agent-template.mjs",
    "compile-agent-template": "cargo build --target wasm32-wasip2 --manifest-path=agent-template/Cargo.toml --release --features full,golem",
    "copy-agent-template": "node ./scripts/copy-agent-template.mjs",
    "build-agent-template": "pnpm run generate-agent-template && pnpm run compile-agent-template && pnpm run copy-agent-template"
  },
  "keywords": [],
  "sideEffects": [
    "src/index.ts"
  ],
  "author": "",
  "license": "SEE LICENSE IN LICENSE",
  "description": "",
  "dependencies": {
    "@golemcloud/golem-ts-types-core": "workspace:*",
    "ms": "^2.1.3"
  },
  "devDependencies": {
    "@golemcloud/golem-ts-typegen": "workspace:*",
    "@eslint/js": "^9.33.0",
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@types/ms": "^2.1.0",
    "@types/node": "^24.3.0",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "eslint": "^9.33.0",
    "fast-check": "^4.2.0",
    "prettier": "^3.6.2",
    "reflect-metadata": "^0.1.14",
    "rollup": "^4.46.2",
    "rollup-plugin-dts": "^6.2.1",
    "rollup-plugin-typescript2": "^0.36.0",
    "ts-morph": "^26.0.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.39.0",
    "vitest": "^3.2.4"
  },
  "private": false,
  "repository": "https://github.com/golemcloud/golem"
}
