---
import { metricBar } from "../data/homepage";
import wasmLogo from "../assets/logo/webassembly-white.svg";

const { metrics } = metricBar;
---

<section class="metric-bar-section">
  <div class="metric-bar">
    <div class="metric-strip">
      <div class="wasm-marker">
        <img src={wasmLogo.src} alt="WebAssembly" class="wasm-logo" width={wasmLogo.width} height={wasmLogo.height} />
      </div>
      <div class="metric-divider" aria-hidden="true"></div>
      {
        metrics.map((m) => (
          <div class="metric">
            <div class="metric-value">{m.value}</div>
            <div class="metric-label">{m.label}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .metric-bar-section {
    padding: 0;
  }
  .metric-bar {
    width: 100%;
    background: var(--bg-card);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    overflow-x: auto;
    overflow-y: hidden;
    scrollbar-width: none;
  }
  .metric-bar::-webkit-scrollbar {
    display: none;
  }
  .metric-strip {
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    justify-content: center;
    align-items: center;
    gap: 3rem;
    padding: 2.25rem 2rem;
    width: max-content;
    min-width: 100%;
    margin: 0 auto;
    box-sizing: border-box;
  }
  .metric {
    flex: 0 0 auto;
    min-width: 160px;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .wasm-marker {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
  }
  .wasm-logo {
    height: 52px;
    width: auto;
    display: block;
    opacity: 0.95;
  }
  .metric-divider {
    flex: 0 0 1px;
    align-self: stretch;
    background: var(--border);
    margin: 0.5rem 0;
  }
  .metric-value {
    font-family: var(--font-mono);
    font-size: clamp(1.5rem, 2.4vw, 2rem);
    font-weight: 600;
    color: var(--accent);
    letter-spacing: -0.01em;
    line-height: 1.1;
  }
  .metric-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    line-height: 1.3;
  }
  @media (max-width: 720px) {
    .metric-strip {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem 1rem;
      padding: 1.75rem 1.5rem;
      width: 100%;
      min-width: 0;
    }
    .metric,
    .wasm-marker {
      min-width: 0;
    }
    .wasm-marker {
      grid-column: 1 / -1;
      justify-content: center;
    }
    .metric-divider {
      display: none;
    }
  }
</style>
