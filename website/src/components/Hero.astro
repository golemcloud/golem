---
import { Image } from "astro:assets";
import { hero } from "../data/homepage";
import heroArt from "../assets/hero/golem-thinker.png";

const { headingLines, expanderHtml, ctas, images } = hero;
const heroImage = images[0];
---

<section class="hero">
  <div class="container hero-inner">
    <div class="hero-text">
      <div class="hero-top">
        <h1 class="hero-heading">
          {
            headingLines.map((line, i) => (
              <>
                {i > 0 && <br />}
                {line}
              </>
            ))
          }
        </h1>
        <p class="hero-expander" set:html={expanderHtml} />
      </div>
      <div class="hero-ctas">
        <a href={ctas.primary.href} class="btn btn-primary">{ctas.primary.label}</a>
        <a href={ctas.secondary.href} class="btn btn-secondary">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path
              d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
            ></path>
          </svg>
          {ctas.secondary.label}
        </a>
      </div>
    </div>
    {
      heroImage && (
        <div class="hero-art">
          <Image
            src={heroArt}
            alt={heroImage.alt}
            widths={[460, 920]}
            sizes="(min-width: 880px) 460px, 100vw"
          />
        </div>
      )
    }
  </div>
</section>

<style>
  .hero {
    padding: clamp(4rem, 9vw, 7.5rem) 0 clamp(3.5rem, 7vw, 5.5rem);
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: "";
    position: absolute;
    top: -30%;
    left: 70%;
    width: 900px;
    height: 700px;
    transform: translateX(-50%);
    background: radial-gradient(ellipse, rgba(245, 176, 62, 0.1), transparent 60%);
    pointer-events: none;
    z-index: -1;
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: start;
  }
  @media (min-width: 880px) {
    .hero-inner {
      grid-template-columns: minmax(0, 1.15fr) minmax(0, 1fr);
      gap: 3rem;
      align-items: stretch;
    }
    .hero-text {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }
  }
  .hero-text {
    text-align: left;
  }
  .hero-top {
    display: flex;
    flex-direction: column;
  }
  .hero-heading {
    font-size: clamp(2.4rem, 5vw, 3.75rem);
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1.05;
    margin-bottom: 1.5rem;
    margin-top: 0.65rem;
    background: linear-gradient(to bottom, #ffffff 30%, #b0b0bc 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .hero-expander {
    font-size: clamp(1.02rem, 1.5vw, 1.18rem);
    line-height: 1.55;
    color: var(--text-secondary);
    margin: 0 0 2rem;
    max-width: 580px;
  }
  .hero-expander :global(strong) {
    color: var(--text);
    font-weight: 500;
  }
  .hero-expander :global(.closer) {
    display: inline-block;
    margin-top: 0.4em;
    color: var(--accent);
    font-weight: 500;
  }
  .hero-ctas {
    display: flex;
    justify-content: flex-start;
    gap: 0.85rem;
    flex-wrap: wrap;
  }
  .hero-art {
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .hero-art img {
    max-width: 100%;
    width: 100%;
    height: auto;
    display: block;
    border-radius: 12px;
  }
  @media (min-width: 880px) {
    .hero-art img {
      max-width: 460px;
    }
  }
  .break-on-md {
    display: none;
  }
  @media (min-width: 720px) {
    :global(.break-on-md) {
      display: inline;
    }
  }
</style>
