---
// Markup only — copy lives in src/data/careers.ts.
import ContentPage from "../layouts/ContentPage.astro";
import { meta, hero, sections } from "../data/careers";
---

<ContentPage
  eyebrow={hero.eyebrow}
  title={hero.title}
  lead={hero.lead}
  description={meta.description}
>
  {
    sections.map((s) => (
      <>
        <h2>{s.heading}</h2>
        <Fragment set:html={s.bodyHtml} />
      </>
    ))
  }
</ContentPage>
