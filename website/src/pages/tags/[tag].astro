---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";

export async function getStaticPaths() {
  const allPosts = await getCollection("blog", ({ data }) =>
    import.meta.env.PROD ? !data.draft : true
  );
  const tags = new Set<string>();
  for (const p of allPosts) for (const t of p.data.tags) tags.add(t);
  const tagSlug = (t: string) => t.toLowerCase().replace(/\s+/g, "-");
  return Array.from(tags).map((tag) => ({
    params: { tag: tagSlug(tag) },
    props: { tag, posts: allPosts.filter((p) => p.data.tags.includes(tag)) },
  }));
}

const { tag, posts } = Astro.props;
const sortedPosts = posts.sort((a: any, b: any) => {
  const da = a.data.date?.valueOf() ?? -Infinity;
  const db = b.data.date?.valueOf() ?? -Infinity;
  if (da !== db) return db - da;
  return a.data.title.localeCompare(b.data.title);
});
const fmt = (d?: Date) =>
  d
    ? new Intl.DateTimeFormat("en-US", { year: "numeric", month: "short", day: "numeric" }).format(
        d
      )
    : "";
---

<BaseLayout title={`${tag} — Golem Blog`} description={`Posts tagged ${tag}`}>
  <Nav />
  <main class="tag-main">
    <div class="container tag-container">
      <header class="tag-header">
        <span class="eyebrow">Tag</span>
        <h1 class="tag-title">{tag}</h1>
        <p class="tag-lead">{sortedPosts.length} post{sortedPosts.length === 1 ? "" : "s"}</p>
      </header>
      <ul class="post-list">
        {
          sortedPosts.map((p: any) => (
            <li class="post-row">
              <a href={`/blog/${p.data.slug ?? p.id}`} class="post-link">
                <div class="post-row-meta mono">
                  {p.data.date && <span>{fmt(p.data.date)}</span>}
                  {p.data.author && (
                    <>
                      <span class="dot">·</span>
                      <span>{p.data.author}</span>
                    </>
                  )}
                </div>
                <div class="post-row-title">{p.data.title}</div>
              </a>
            </li>
          ))
        }
      </ul>
      <p class="back"><a href="/tags">← All tags</a> · <a href="/blog">All posts</a></p>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .tag-main {
    padding: clamp(3rem, 6vw, 5rem) 0 clamp(4rem, 7vw, 6rem);
  }
  .tag-container {
    max-width: 820px;
  }
  .tag-header {
    margin-bottom: 2.5rem;
  }
  .tag-title {
    font-size: clamp(2rem, 4vw, 2.6rem);
    font-weight: 600;
    color: var(--text);
    letter-spacing: -0.022em;
    margin: 0.5rem 0 0.5rem;
  }
  .tag-lead {
    color: var(--text-secondary);
    font-size: 0.95rem;
  }
  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--border);
  }
  .post-row {
    border-bottom: 1px solid var(--border);
  }
  .post-link {
    display: block;
    padding: 1.4rem 0;
    color: var(--text);
    text-decoration: none;
  }
  .post-link:hover {
    background: linear-gradient(to right, transparent, var(--bg-card), transparent);
  }
  .post-row-meta {
    font-size: 0.74rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.35rem;
    display: flex;
    gap: 0.5rem;
  }
  .dot {
    opacity: 0.6;
  }
  .post-row-title {
    font-size: 1.12rem;
    font-weight: 500;
    color: var(--text);
    line-height: 1.35;
  }
  .post-link:hover .post-row-title {
    color: var(--accent);
  }
  .back {
    margin-top: 2.5rem;
    font-size: 0.92rem;
  }
  .back a {
    color: var(--text-secondary);
    text-decoration: none;
    margin-right: 0.5rem;
  }
  .back a:hover {
    color: var(--accent);
  }
</style>
