---
// Markup only — copy lives in src/data/about.ts.
import ContentPage from "../layouts/ContentPage.astro";
import { meta, hero, sections } from "../data/about";
---

<ContentPage
  eyebrow={hero.eyebrow}
  title={hero.title}
  lead={hero.lead}
  description={meta.description}
>
  {
    sections.map((s) => (
      <>
        <h2>{s.heading}</h2>
        {s.bodyHtml && <Fragment set:html={s.bodyHtml} />}
        {s.founders?.map((f) => (
          <>
            <h3>{f.name}</h3>
            <Fragment set:html={f.bioHtml} />
          </>
        ))}
      </>
    ))
  }
</ContentPage>
