///|
let counter : Ref[Int] = Ref::new(0)

///|
async fn[X] suspend(f : ((X) -> Unit) -> Unit) -> X noraise = "%async.suspend"

///|
fn run_async(f : async () -> Unit noraise) -> Unit = "%async.run"

///|
let cont : Ref[((Unit) -> Unit)?] = Ref::new(None)

///|
async fn async_incr(index : Int) -> Unit noraise {
  ignore(index)
  counter.val += 1
  suspend(k => cont.val = Some(k))
}

///|
fn main {
  run_async(async_fn_with_large_state)
  // use a trampoline loop to avoid stack overflow
  while cont.val is Some(k) {
    cont.val = None
    k(())
  }
  println(counter.val)
}

