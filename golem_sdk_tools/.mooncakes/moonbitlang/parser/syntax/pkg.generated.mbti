  params : @list.List[TypeDeclBinder]
  components : TypeDesc
  attrs : @list.List[@attribute.Attribute]
  mut doc : DocString
  type_vis : Visibility
  deriving : @list.List[DerivingDirective]
  loc : @basic.Location
  is_declare : Bool
}
pub fn TypeDecl::json_repr(Self) -> Json

pub(all) struct TypeDeclBinder {
  name : String?
  loc : @basic.Location
}
pub fn TypeDeclBinder::json_repr(Self) -> Json

pub(all) enum TypeDesc {
  Abstract
  Extern
  Newtype(Type)
  Error(ExceptionDecl)
  Variant(@list.List[ConstrDecl])
  Record(@list.List[FieldDecl])
  TupleStruct(@list.List[Type])
  Alias(Type)
}
pub fn TypeDesc::json_repr(Self, @basic.Location) -> Json

pub(all) struct TypeName {
  name : LongIdent
  is_object : Bool
  loc : @basic.Location
}
pub fn TypeName::json_repr(Self) -> Json

pub(all) struct TypeVarBinder {
  name : String
  name_loc : @basic.Location
  constraints : @list.List[TypeVarConstraint]
}
pub fn TypeVarBinder::json_repr(Self) -> Json

pub(all) struct TypeVarConstraint {
  trait_ : LongIdent
  loc : @basic.Location
}
pub fn TypeVarConstraint::json_repr(Self) -> Json

pub(all) enum UsingKind {
  Value
  Type
  Trait
}

pub(all) struct Var {
  name : LongIdent
  loc : @basic.Location
}
pub fn Var::json_repr(Self) -> Json

pub(all) enum Visibility {
  Default
  Pub(attr~ : String?, loc~ : @basic.Location)
  Priv(loc~ : @basic.Location)
}
pub fn Visibility::json_repr(Self, @basic.Location) -> Json

pub(all) struct WhereClause {
  fields : @list.List[FieldDef]
  loc : @basic.Location
}
pub fn WhereClause::json_repr(Self) -> Json

// Type aliases
pub type Impls = @list.List[Impl]

pub type Parameters = @list.List[Parameter]

pub type TestName = (String, @basic.Location)?

