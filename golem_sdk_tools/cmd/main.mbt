///|
fn main {
  let args = @env.args()
  if args.length() < 2 {
    println(
      "Usage: golem_sdk_tools <command> <args>\nCommands:\n  reexports <sdk-path> <target-dir>\n  agents <package-dir>",
    )
    return
  }
  if args[1] == "reexports" {
    if args.length() < 4 {
      println("Usage: golem_sdk_tools reexports <sdk-path> <target-dir>")
      return
    }
    run_reexports(args[2], args[3]) catch {
      e => println("Error: \{e}")
    }
  } else if args[1] == "agents" {
    if args.length() < 3 {
      println("Usage: golem_sdk_tools agents <package-dir>")
      return
    }
    run_agents(args[2]) catch {
      e => println("Error: \{e}")
    }
  } else {
    println("Unknown command: \{args[1]}")
  }
}

///|
/// Runs the `agents` subcommand: parses agent source files and generates `golem_agents.mbt`, `golem_derive.mbt`, and `golem_clients.mbt`.
fn run_agents(package_dir : String) -> Unit raise {
  let entries = @fs.read_dir(package_dir)
  let files : Array[(String, String)] = []
  for entry in entries {
    if entry.has_suffix(".mbt") &&
      entry != "golem_agents.mbt" &&
      entry != "golem_reexports.mbt" &&
      entry != "golem_derive.mbt" &&
      entry != "golem_clients.mbt" {
      let path = "\{package_dir}/\{entry}"
      let content = @fs.read_file_to_string(path)
      files.push((entry, content))
    }
  }
  let agents = @lib.parse_agents(files)
  if agents.length() == 0 {
    println("No agents found in \{package_dir}")
    return
  }
  if agents[0].has_init {
    println(
      "Warning: existing fn init found in package. Remove it to avoid conflicts with generated code.",
    )
  }
  let impls = @lib.generate_agent_registration(agents)
  let formatted = @formatter.impls_to_string(impls)
  let output = "// Generated by golem_sdk_tools — DO NOT EDIT!\n\n" +
    formatted
  let output_path = "\{package_dir}/golem_agents.mbt"
  @fs.write_string_to_file(output_path, output)
  println("Generated \{output_path} with \{agents.length()} agent(s)")
  // Generate golem_derive.mbt for value types and multimodal enums
  let value_types = @lib.parse_value_types(files)
  let multimodal_enums = @lib.parse_multimodal_enums(files)
  if value_types.length() > 0 || multimodal_enums.length() > 0 {
    let all_impls : Array[@syntax.Impl] = []
    if value_types.length() > 0 {
      @lib.generate_value_type_impls(value_types).each(fn(i) {
        all_impls.push(i)
      })
    }
    if multimodal_enums.length() > 0 {
      @lib.generate_multimodal_impls(multimodal_enums).each(fn(i) {
        all_impls.push(i)
      })
    }
    let derive_formatted = @formatter.impls_to_string(
      @list.List::from_array(all_impls),
    )
    let derive_output = "// Generated by golem_sdk_tools — DO NOT EDIT!\n\n" +
      derive_formatted
    let derive_path = "\{package_dir}/golem_derive.mbt"
    @fs.write_string_to_file(derive_path, derive_output)
    println(
      "Generated golem_derive.mbt with \{value_types.length()} type(s) and \{multimodal_enums.length()} multimodal enum(s)",
    )
  }
  // Generate golem_clients.mbt for RPC client stubs
  let client_impls = @lib.generate_client_code(agents)
  let client_formatted = @formatter.impls_to_string(client_impls)
  let client_output = "// Generated by golem_sdk_tools — DO NOT EDIT!\n\n" +
    client_formatted
  let client_path = "\{package_dir}/golem_clients.mbt"
  @fs.write_string_to_file(client_path, client_output)
  println("Generated golem_clients.mbt with \{agents.length()} client(s)")
  // Auto-add RPC-related imports to moon.pkg
  let pkg_path = "\{package_dir}/moon.pkg"
  let mut pkg_content = @fs.read_file_to_string(pkg_path)
  pkg_content = @lib.ensure_pkg_import(
    pkg_content, "golemcloud/golem_sdk/rpc", "@rpc",
  )
  pkg_content = @lib.ensure_pkg_import(
    pkg_content, "golemcloud/golem_sdk/interface/golem/core/types", "@rpcTypes",
  )
  pkg_content = @lib.ensure_pkg_import(
    pkg_content, "golemcloud/golem_sdk/interface/wasi/clocks/wallClock", "@wallClock",
  )
  // Check if any agent uses multimodal types and auto-add import
  let uses_multimodal = has_multimodal_agent(agents)
  if uses_multimodal || multimodal_enums.length() > 0 {
    pkg_content = @lib.ensure_pkg_import(
      pkg_content, "golemcloud/golem_sdk/agents/types", "@types",
    )
    println("Ensured agents/types import in moon.pkg")
  }
  @fs.write_string_to_file(pkg_path, pkg_content)
}

///|
/// Checks if any agent uses multimodal types in its constructor or methods.
fn has_multimodal_agent(agents : Array[@lib.AgentInfo]) -> Bool {
  for a in agents {
    for p in a.constructor_params {
      if @lib.is_multimodal_type(p.1) {
        return true
      }
    }
    for m in a.methods {
      for p in m.params {
        if @lib.is_multimodal_type(p.1) {
          return true
        }
      }
      match m.return_type {
        Some(pt) => if @lib.is_multimodal_type(pt) { return true }
        None => ()
      }
    }
  }
  false
}

///|
/// Runs the `reexports` subcommand: parses SDK gen sources and generates `golem_reexports.mbt` plus updates `moon.pkg`.
fn run_reexports(sdk_path : String, target_dir : String) -> Unit raise {
  let gen_dir = "\{sdk_path}/gen"
  let entries = @fs.read_dir(gen_dir)
  let fns : Array[@lib.FnSignature] = []
  for entry in entries {
    if entry.has_suffix(".mbt") {
      let content = @fs.read_file_to_string("\{gen_dir}/\{entry}")
      let file_fns = @lib.parse_mbt_source(content)
      for fn_ in file_fns {
        fns.push(fn_)
      }
    }
  }
  let impls = @lib.generate_reexports(fns, "gen")
  let formatted = @formatter.impls_to_string(impls)
  let output = "// Generated by golem_sdk_tools — DO NOT EDIT!\n\n" +
    formatted
  let output_path = "\{target_dir}/golem_reexports.mbt"
  @fs.write_string_to_file(output_path, output)
  println("Generated \{output_path} with \{fns.length()} functions")
  // Update target moon.pkg with link section from SDK's gen/moon.pkg
  let gen_pkg_content = @fs.read_file_to_string("\{gen_dir}/moon.pkg")
  let exports = @lib.transform_exports(@lib.parse_pkg_exports(gen_pkg_content))
  let target_pkg_path = "\{target_dir}/moon.pkg"
  let target_pkg_content = @fs.read_file_to_string(target_pkg_path)
  let updated = @lib.update_pkg_link(target_pkg_content, exports)
  @fs.write_string_to_file(target_pkg_path, updated)
  println("Updated \{target_pkg_path} with \{exports.length()} exports")
}
