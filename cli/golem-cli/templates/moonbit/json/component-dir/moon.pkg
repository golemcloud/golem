import {
  "golemcloud/golem_sdk/agents" @agents,
  "golemcloud/golem_sdk/schema" @schema,
  "golemcloud/golem_sdk/schema_model" @model,
  "golemcloud/golem_sdk/interface/golem/agent/common" @common,
  "golemcloud/golem_sdk/interface/golem/core/types" @types,
  "golemcloud/golem_sdk/rpc" @rpc,
  "golemcloud/golem_sdk/interface/golem/agent/host" @agentHost,
  "golemcloud/golem_sdk/interface/wasi/clocks/wallClock" @wallClock,
  "golemcloud/golem_sdk/gen" @gen,
  "moonbitlang/core/json" @json,
}

options(
  "is-main": true,
  link: {
    "wasm": {
      "export-memory-name": "memory",
      "exports": [
        "cabi_realloc:cabi_realloc",
        "wasmExportDiscoverAgentTypes:golem:agent/guest@2.0.0#discover-agent-types",
        "wasmExportDiscoverAgentTypesPostReturn:cabi_post_golem:agent/guest@2.0.0#discover-agent-types",
        "wasmExportGetDefinition:golem:agent/guest@2.0.0#get-definition",
        "wasmExportGetDefinitionPostReturn:cabi_post_golem:agent/guest@2.0.0#get-definition",
        "wasmExportInitialize:golem:agent/guest@2.0.0#initialize",
        "wasmExportInitializePostReturn:cabi_post_golem:agent/guest@2.0.0#initialize",
        "wasmExportInvoke:golem:agent/guest@2.0.0#invoke",
        "wasmExportInvokePostReturn:cabi_post_golem:agent/guest@2.0.0#invoke",
        "wasmExportLoad:golem:api/load-snapshot@1.5.0#load",
        "wasmExportLoadPostReturn:cabi_post_golem:api/load-snapshot@1.5.0#load",
        "wasmExportSave:golem:api/save-snapshot@1.5.0#save",
        "wasmExportSavePostReturn:cabi_post_golem:api/save-snapshot@1.5.0#save",
      ],
      "heap-start-address": 16,
    },
  },
)
